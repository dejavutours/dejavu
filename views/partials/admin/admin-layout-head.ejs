    color: #fff !important;
    padding: 4px 14px;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
    text-decoration: none !important;
  }
  .mc-toggle-btn:hover { background: rgba(255,255,255,0.3); }
  .mc-form-body {
    background: #fff;
    padding: 18px 20px 22px;
    border: 1px solid #e2e8f0;
    border-top: none;
    border-radius: 0 0 10px 10px;
  }

  /* collapsed state: hide the body, round the header fully */
  .sm-form-container.collapsed .mc-form-body,
  .cm-form-container.collapsed .mc-form-body,
  .bm-form-container.collapsed .mc-form-body { display: none; }
  .sm-form-container.collapsed .mc-form-header,
  .cm-form-container.collapsed .mc-form-header,
  .bm-form-container.collapsed .mc-form-header { border-radius: 10px; }

  /* ── Filter Bar ── */
  .mc-filter-bar {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 11px 16px;
    margin-bottom: 16px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  }
  .mc-search-wrap { position: relative; flex: 1; min-width: 160px; }
