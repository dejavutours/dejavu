  /* ── Form Panel ── */
  .mc-form-header {
    background: linear-gradient(135deg, var(--admin-primary, #1a4b8e) 0%, #2563eb 100%);
    color: #fff;
    padding: 11px 18px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-radius: 10px 10px 0 0;
  }
  .mc-form-header h6 { margin: 0; font-size: 0.9rem; font-weight: 600; }
  .mc-toggle-btn {
    background: rgba(255,255,255,0.18);
