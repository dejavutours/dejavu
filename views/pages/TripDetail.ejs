  // Handle BNPL form submission
  document.getElementById("bnplForm")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const submitBtn = document.getElementById("submitBNPL");
    const bnplName = document.getElementById("bnplName").value.trim();
    const bnplPhone = document.getElementById("bnplPhone").value.trim();
    const bnplCountryCode = document.getElementById("bnplCountryCode").value;
    const bnplEmail = document.getElementById("bnplEmail").value.trim();
    const nameError = document.getElementById("bnplNameError");
    const phoneError = document.getElementById("bnplPhoneError");
    let isValid = true;
    
    if (!bnplName) {
      nameError.style.display = "block";
      isValid = false;
    } else {
      nameError.style.display = "none";
    }
    if (!/^\d{10}$/.test(bnplPhone)) {
      phoneError.style.display = "block";
      isValid = false;
    } else {
      phoneError.style.display = "none";
    }
    
    submitBtn.disabled = !isValid;
    if (!isValid) return;
    submitBtn.disabled = true;
    
    try {
      // Get booking details from form
      const citySelect = document.getElementById("selectedCity");
      const dateSelect = document.getElementById("selectedDate");
      const transportSelect = document.getElementById("selectedTransport");
      const adultsInput = document.querySelector('input[name="adults"]') || document.getElementById("adults");
      const childrenInput = document.querySelector('input[name="children"]') || document.getElementById("children");
      
      if (!citySelect.value || !dateSelect.value || !transportSelect.value) {
        showContactModal("Please complete all booking details first.");
        submitBtn.disabled = false;
        return;
      }
      
      // Get person details - we need to collect them from the form
      // For BNPL, we'll use the first person's details from the form if available
      // Otherwise, we'll use the name and phone from BNPL form
      const personDetails = [];
      const adults = parseInt(adultsInput?.value || 1);
      const children = parseInt(childrenInput?.value || 0);
      
      // Try to get person details from form, or create default from BNPL form
      const personDetailsInputs = document.querySelectorAll('[name^="personDetails"]');
      if (personDetailsInputs.length > 0) {
        // Person details exist in form
        for (let i = 0; i < adults + children; i++) {
          const firstName = document.querySelector(`[name="personDetails[${i}][firstName]"]`)?.value?.trim() || (i === 0 ? bnplName.split(' ')[0]?.trim() : '');
          let surname = document.querySelector(`[name="personDetails[${i}][Surname]"]`)?.value?.trim() || '';
          // If surname is empty and this is first person, use firstName as surname
          if (!surname && i === 0) {
            const nameParts = bnplName.split(' ').filter(part => part.trim());
            surname = nameParts.slice(1).join(' ').trim() || firstName || 'Guest';
          }
          // Ensure surname is never empty
          if (!surname) {
            surname = firstName || 'Guest';
          }
          const gender = document.querySelector(`[name="personDetails[${i}][Gender]"]`)?.value || 'Male';
          const birthdate = document.querySelector(`[name="personDetails[${i}][dateofbirth]"]`)?.value || '1990-01-01';
          let phone = document.querySelector(`[name="personDetails[${i}][mobileno]"]`)?.value || `${bnplCountryCode}${bnplPhone}`;
          // Clean phone number - remove non-digits except + at start
          phone = phone.replace(/[^\d+]/g, '');
          const altphone = (document.querySelector(`[name="personDetails[${i}][alternateNumber]"]`)?.value || '').replace(/[^\d+]/g, '');
          
          // Validate phone format
          if (!/^\+?\d{10,15}$/.test(phone)) {
            phone = `${bnplCountryCode}${bnplPhone}`.replace(/[^\d+]/g, '');
          }
          
          if (firstName && surname && phone && /^\+?\d{10,15}$/.test(phone)) {
            personDetails.push({
              firstName,
              surname,
              gender,
              birthdate,
              phone,
              altphone: altphone || '',
            });
          }
        }
      } else {
        // Create default person detail from BNPL form
        const nameParts = bnplName.split(' ').filter(part => part.trim());
        const firstName = nameParts[0] || bnplName || 'Guest';
        // Ensure surname is never empty - use firstName if no surname provided
        const surname = nameParts.slice(1).join(' ').trim() || firstName;
        
        // Validate and format phone number
        const fullPhone = `${bnplCountryCode}${bnplPhone}`;
        // Remove any non-digit characters except + at start
        const cleanPhone = fullPhone.replace(/[^\d+]/g, '');
        
        // Ensure we have at least one valid person detail
        if (firstName && cleanPhone && /^\+?\d{10,15}$/.test(cleanPhone)) {
          personDetails.push({
            firstName: firstName,
            surname: surname,
            gender: 'Male',
            birthdate: '1990-01-01', // Default date - will be validated on server
            phone: cleanPhone,
            altphone: '',
          });
        }
      }
      
      // Validate personDetails array is not empty
      if (personDetails.length === 0) {
        showContactModal("Unable to create person details. Please ensure name and phone are valid.");
        submitBtn.disabled = false;
        return;
      }
      
      // Validate each person detail before sending
      for (let i = 0; i < personDetails.length; i++) {
        const person = personDetails[i];
        if (!person.firstName || !person.surname || !person.phone) {
          showContactModal(`Person ${i + 1} details are incomplete. Please check all fields.`);
          submitBtn.disabled = false;
          return;
        }
        // Validate phone format
        if (!/^\+?\d{10,15}$/.test(person.phone)) {
          showContactModal(`Person ${i + 1} phone number is invalid. Please enter a valid 10-15 digit number.`);
          submitBtn.disabled = false;
          return;
        }
      }
      
      // Get prices from selected city and transport
      const selectedCity = deptCities.find((city) => city.City === citySelect.value);
      const selectedTransport = selectedCity?.price.find(t => t.transferType === transportSelect.value);
      
      if (!selectedTransport) {
        showContactModal("Unable to get pricing information. Please try again.");
        submitBtn.disabled = false;
        return;
      }
      
      const csrfToken = document.querySelector('input[name="_csrf"]')?.value || '';
      const userId = document.getElementById("userId")?.value || '';
      
      // Submit to payment/order endpoint with bnpl type
      const response = await fetch("/payment/order", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "CSRF-Token": csrfToken,
        },
        body: JSON.stringify({
          tourId: trip._id,
          userId: userId,
          transportType: transportSelect.value,
          joiningFrom: citySelect.value,
          travelDate: dateSelect.value,
          adults: adults,
          children: children,
          personDetails: personDetails,
          Adultprice: selectedTransport.adultPrice,
          childprice: selectedTransport.childPrice,
          name: bnplName,
          email: bnplEmail || '',
          contact: `${bnplCountryCode}${bnplPhone}`,
          paymentType: 'bnpl',
        }),
      });
      
      // Check if response is ok
      if (!response.ok) {
        let errorMessage = "Failed to submit booking request. Please try again or contact support.";
        try {
          const errorData = await response.json();
          errorMessage = errorData.message || errorData.error || errorMessage;
        } catch (e) {
          // If response is not JSON, use status text
          errorMessage = `Server error (${response.status}). Please try again or contact support.`;
        }
        const bnplModal = bootstrap.Modal.getInstance(document.getElementById("bnplModal"));
        if (bnplModal) {
          bnplModal.hide();
        }
        setTimeout(() => {
          showContactModal(errorMessage);
        }, 300);
        submitBtn.disabled = false;
        return;
      }
      
      const result = await response.json();
      if (result.success) {
        const bnplModal = bootstrap.Modal.getInstance(document.getElementById("bnplModal"));
        if (bnplModal) {
          bnplModal.hide();
        }
        // Wait a bit for modal to close before showing success
        setTimeout(() => {
          bootstrap.Modal.getOrCreateInstance(document.getElementById("bnplSuccessModal")).show();
        }, 300);
      } else {
        // Close BNPL modal first, then show error
        const bnplModal = bootstrap.Modal.getInstance(document.getElementById("bnplModal"));
        if (bnplModal) {
          bnplModal.hide();
        }
        setTimeout(() => {
          showContactModal(result.message || "Failed to submit booking request. Please try again or contact support.");
        }, 300);
      }
    } catch (error) {
      console.error("Error submitting BNPL request:", error);
      // Close BNPL modal first, then show error
      const bnplModal = bootstrap.Modal.getInstance(document.getElementById("bnplModal"));
      if (bnplModal) {
        bnplModal.hide();
      }
      setTimeout(() => {
        // Check if it's a network error or server error
        let errorMessage = "An error occurred. Please try again or contact support.";
        if (error.message && error.message.includes('fetch')) {
          errorMessage = "Network error. Please check your connection and try again.";
        }
        showContactModal(errorMessage);
      }, 300);
    } finally {
      submitBtn.disabled = false;
    }
  });

