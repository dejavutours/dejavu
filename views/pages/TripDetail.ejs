  .quick-call-modal-btn { font-size: 0.87rem; padding: 12px 20px; border-radius: 10px; }
}

@media (max-width: 400px) {
  .qcm-header-inner { padding: 18px 14px 14px; }
  .qcm-icon-ring { width: 44px; height: 44px; }
  .qcm-icon-ring i { font-size: 1.2rem; }
  .qcm-header-inner h5 { font-size: 0.92rem; }
  .qcm-social-proof { gap: 8px; flex-wrap: wrap; }
  .quick-call-modal-body { padding: 14px 14px 4px; }
  .quick-call-modal-body .form-control, .quick-call-modal-body .form-select { font-size: 0.82rem; padding: 8px 10px; }
  .quick-call-modal-body .form-select { max-width: 72px; }
  .quick-call-modal-footer { padding: 10px 14px 16px; }
  .quick-call-modal-btn { font-size: 0.83rem; padding: 11px 16px; }
}

/* ── Recommended Trips ── */
.recommended-trips-section { background: #f3f4f6; }

.recommended-trips-title {
  font-size: 1.35rem;
  font-weight: 700;
  color: #1A3C6C;
  margin-bottom: 4px;
}
.recommended-trips-subtitle {
  font-size: 0.85rem;
  color: #6c757d;
}

.recommended-trips-slider { position: relative; }

.recommended-trips-track {
  display: flex;
  gap: 14px;
  overflow-x: auto;
  scroll-behavior: smooth;
  padding: 4px 2px 12px;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.recommended-trips-track::-webkit-scrollbar { display: none; }

/* Card — matches page's custom-card style */
.recommended-trip-card {
  min-width: 260px;
  max-width: 260px;
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid #e5e7eb;
  cursor: pointer;
  transition: box-shadow 0.2s, transform 0.2s;
  flex-shrink: 0;
}
.recommended-trip-card:hover {
  box-shadow: 0 6px 20px rgba(0,0,0,0.1);
  transform: translateY(-3px);
}

.trip-card-image {
  position: relative;
  height: 160px;
  overflow: hidden;
}
.trip-card-image img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.3s;
}
.recommended-trip-card:hover .trip-card-image img { transform: scale(1.04); }

.trip-card-group-label {
  position: absolute;
  top: 8px; left: 8px;
  background: rgba(26,75,142,0.88);
  color: #fff;
  padding: 3px 7px;
  border-radius: 5px;
  font-size: 0.7rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 3px;
}

.trip-card-price-badge {
  position: absolute;
  bottom: 8px; right: 8px;
  background: #EF4F5F;
  color: #fff;
  padding: 4px 8px;
  border-radius: 6px;
  font-size: 0.82rem;
  font-weight: 700;
}

.trip-card-content { padding: 10px 12px 12px; }

.trip-card-title {
  font-size: 0.88rem;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8px;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-clamp: 2;
  overflow: hidden;
}

.trip-card-meta {
  display: flex;
  justify-content: space-between;
  font-size: 0.75rem;
  color: #6b7280;
  gap: 6px;
}
.trip-card-duration, .trip-card-state {
  display: flex;
  align-items: center;
  gap: 3px;
  min-width: 0;
}
.trip-card-duration i, .trip-card-state i {
  color: #1a4b8e;
  font-size: 0.7rem;
  flex-shrink: 0;
}
.trip-card-state span {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Scroll nav arrows */
.recommended-trips-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-60%);
  background: #fff;
  border: 1.5px solid #e5e7eb;
  border-radius: 50%;
  width: 36px; height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 10;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  color: #1a4b8e;
  font-size: 1rem;
  transition: background 0.18s, border-color 0.18s;
}
.recommended-trips-nav:hover { background: #1a4b8e; color: #fff; border-color: #1a4b8e; }
.recommended-trips-prev { left: -14px; }
.recommended-trips-next { right: -14px; }

/* View All button */
.recommended-view-more {
  font-size: 0.88rem;
  font-weight: 600;
  padding: 0.5rem 1.5rem;
}

/* ── Plan Next Adventure banner ── */
.plan-next-trip-section { margin-top: 2rem; }

.plan-next-trip-card {
  background: linear-gradient(120deg, #1A3C6C 0%, #1a4b8e 100%);
  border-radius: 14px;
  padding: 1.75rem 2rem;
}
.plan-next-trip-content {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.plan-next-trip-icon {
  flex-shrink: 0;
  width: 56px; height: 56px;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  border: 1.5px solid rgba(255,255,255,0.25);
}
.plan-next-trip-icon i { font-size: 1.5rem; color: #fff; }

.plan-next-trip-text { flex: 1; min-width: 0; }
.plan-next-trip-title {
  font-size: 1.2rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 4px;
  line-height: 1.3;
}
.plan-next-trip-subtitle {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.78);
  margin: 0;
  line-height: 1.5;
}

.plan-next-trip-actions {
  display: flex;
  gap: 10px;
  flex-shrink: 0;
}
.plan-next-trip-btn {
  padding: 0.6rem 1.2rem;
  border-radius: 8px;
  font-weight: 600;
  font-size: 0.88rem;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
  transition: opacity 0.18s, transform 0.18s;
}
.plan-next-trip-btn:hover { opacity: 0.9; transform: translateY(-1px); }
.plan-next-trip-btn.btn-primary {
  background: #fff;
  color: #1A3C6C;
  border: none;
}
.plan-next-trip-btn.btn-primary:hover { background: #f0f4ff; color: #1A3C6C; }
.plan-next-trip-btn.btn-outline-success {
  background: #25D366;
  color: #fff;
  border: none;
}
.plan-next-trip-btn.btn-outline-success:hover { background: #20b559; color: #fff; }

/* Responsive */
@media (max-width: 991px) {
  .recommended-trips-nav { display: none; }
  .recommended-trip-card { min-width: 240px; max-width: 240px; }
  .trip-card-image { height: 145px; }

  .plan-next-trip-content { gap: 1rem; }
  .plan-next-trip-title { font-size: 1.1rem; }
  .plan-next-trip-subtitle { font-size: 0.82rem; }
  .plan-next-trip-btn { font-size: 0.82rem; padding: 0.55rem 0.9rem; }
}

@media (max-width: 768px) {
  .recommended-trip-card { min-width: 220px; max-width: 220px; }
  .trip-card-image { height: 135px; }

  .plan-next-trip-card { padding: 1.25rem 1.25rem; }
  .plan-next-trip-content {
    flex-direction: column;
    text-align: center;
    gap: 0.875rem;
  }
  .plan-next-trip-icon { width: 48px; height: 48px; }
  .plan-next-trip-icon i { font-size: 1.25rem; }
  .plan-next-trip-actions { width: 100%; }
  .plan-next-trip-btn { flex: 1; justify-content: center; }
}

@media (max-width: 576px) {
  .recommended-trip-card { min-width: 200px; max-width: 200px; }
  .trip-card-image { height: 120px; }
  .trip-card-content { padding: 8px 10px 10px; }
  .trip-card-title { font-size: 0.84rem; }
  .trip-card-meta { font-size: 0.72rem; }
  .plan-next-trip-icon { display: none; }
  .plan-next-trip-title { font-size: 1rem; }
  .plan-next-trip-subtitle { font-size: 0.8rem; }
  .plan-next-trip-btn { font-size: 0.8rem; padding: 0.5rem 0.75rem; }
}
  </style>
</head>
<body>
  <%- include('../partials/header', {isSearch: false}); %>
  <div class="container-xl pt-4">
    <section class="image-slider swiper">
      <div class="swiper-wrapper">
        <% if (trips.bannerimages && trips.bannerimages.length > 0) { %>
        <% trips.bannerimages.forEach((img, index) => { %>
        <div class="swiper-slide">
          <img src="<%= img %>" alt="Banner Image <%= index + 1 %>" loading="<%= index === 0 ? 'eager' : 'lazy' %>" onerror="this.onerror=null; this.src='/images/placholderbanner.jpg';" />
        </div>
        <% }); %>
        <% } else { %>
        <div class="swiper-slide">
          <img src="<%= trips.imageurl %>" alt="Main Image" loading="eager" onerror="this.onerror=null; this.src='/images/placholderbanner.jpg';">
        </div>
        <% } %>
      </div>
      <div class="swiper-pagination"></div>
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
      <div class="trip-hero-overlay">
        <div class="d-flex gap-2 flex-wrap align-items-center">
          <% if (trips.days && trips.days.trim() !== '') { %>
          <span class="badge bg-white text-dark"><i class="bi bi-clock me-1"></i><%= trips.days %></span>
          <% } %>
          <% if (trips.deptcities && trips.deptcities.length > 0 && trips.deptcities[0].City !== 'Unknown' && trips.deptcities[0].price && trips.deptcities[0].price[0]) { %>
          <span class="badge bg-primary">From ₹<%= trips.deptcities[0].price[0].adultPrice?.toLocaleString('en-IN') %></span>
          <% } %>
        </div>
      </div>
    </section>
  </div>
  <div class="container-lg pt-3 pt-lg-4">
    <section class="row g-3 mt-0">
      <div class="col-lg-7 col-xl-8 detailSec">
        <div class="custom-card p-3 p-lg-4">
          <h1 class="trek-title fw-bold"><%= trips.name %></h1>
          <article class="subtitle text-muted"><i class="bi bi-geo-alt-fill me-1 text-danger"></i><%- trips.destinations %></article>
          <div class="d-flex d-lg-none gap-2 pt-2 trip-cta-btns">
            <a href="/dreamtrip" class="btn btn-outline-dark rounded-pill flex-fill" target="_blank">Inquire Now</a>
            <button class="btn btn-app-primary rounded-pill flex-fill" data-bs-toggle="modal" data-bs-target="#quickCallModal">Request Call Back</button>
          </div>
        </div>
        <article class="custom-card p-3 p-lg-4">
          <h3>About</h3>
          <div class="about-wrapper position-relative">
            <div class="abouts"><%- trips.about %></div>
          </div>
        </article>
        <article class="custom-card p-3 p-lg-4">
          <div class="trip-stat-grid">
            <% if (trips.days && trips.days.trim() !== '') { %>
            <div class="trip-stat-item">
              <div class="trip-stat-icon"><i class="bi bi-calendar-event"></i></div>
              <div class="trip-stat-label">Duration</div>
              <div class="trip-stat-value"><%= trips.days %></div>
            </div>
            <% } %>
            <% if (trips.tripType && trips.tripType.trim() !== '') { %>
            <div class="trip-stat-item">
              <div class="trip-stat-icon"><i class="bi bi-bar-chart"></i></div>
              <div class="trip-stat-label">Difficulty</div>
              <div class="trip-stat-value"><%= trips.tripType %></div>
            </div>
            <% } %>
            <% if (trips.altitude && trips.altitude.trim() !== '') { %>
            <div class="trip-stat-item">
              <div class="trip-stat-icon"><i class="bi bi-signpost"></i></div>
              <div class="trip-stat-label">Altitude</div>
              <div class="trip-stat-value"><%= trips.altitude %></div>
            </div>
            <% } %>
            <% if (trips.bestSession && trips.bestSession.length > 0) { %>
            <div class="trip-stat-item">
              <div class="trip-stat-icon"><i class="bi bi-cloud-sun"></i></div>
              <div class="trip-stat-label">Best Season</div>
              <div class="trip-stat-value"><%= trips.bestSession.join(', ') %></div>
            </div>
            <% } %>
            <% if (trips.state && trips.state.trim() !== '') { %>
            <div class="trip-stat-item">
              <div class="trip-stat-icon"><i class="bi bi-geo-alt"></i></div>
              <div class="trip-stat-label">Region</div>
              <div class="trip-stat-value"><%= trips.state %>, <%= trips.tripCountry || 'India' %></div>
            </div>
            <% } %>
          </div>
        </article>
        <article class="custom-card p-3 p-lg-4">
          <h3>Departure City</h3>
          <div class="position-relative">
            <div class="d-flex gap-3 overflow-auto py-2" id="carouselTrack" style="scrollbar-width:none;-ms-overflow-style:none;">
              <% if (trips.deptcities && trips.deptcities.length > 0 && trips.deptcities[0].City !== 'Unknown') { %>
                <% trips.deptcities.forEach((city, index) => { %>
                <div class="tour-booking-city-card <%= index === 0 ? 'active' : '' %>"
                     data-city="<%= city.City %>"
                     data-state="<%= city.State %>"
                     data-price="<%= city.price && city.price[0] ? city.price[0].adultPrice : 0 %>"
                     data-duration="<%= city.tripDuration %>"
                     data-cutoff="<%= city.bookingCutoffDays || '0' %>"
                     data-partial="<%= city.partialPayment || '0' %>">
                  <img src="<%= city.image %>" alt="<%= city.City %>" loading="lazy" onerror="this.onerror=null; this.src='/images/placeholder.jpg';" />
                  <div class="tour-booking-city-card-body">
                    <h6><%= city.City %></h6>
                    <small><i class="bi bi-clock me-1"></i><%= city.tripDuration %></small>
                    <div class="city-price">₹<%= city.price && city.price[0] ? city.price[0].adultPrice?.toLocaleString('en-IN') : 'N/A' %>/person</div>
                  </div>
                </div>
                <% }); %>
              <% } else { %>
                <p class="text-muted fst-italic py-2">No departure cities available.</p>
              <% } %>
            </div>
            <button id="prevBtn" class="carousel-control-prev d-none" type="button" onclick="slideLeft()">
              <span class="carousel-control-prev-icon" aria-hidden="true"></span>
              <span class="visually-hidden">Previous</span>
            </button>
            <button id="nextBtn" class="carousel-control-next d-none" type="button" onclick="slideRight()">
              <span class="carousel-control-next-icon" aria-hidden="true"></span>
              <span class="visually-hidden">Next</span>
            </button>
          </div>
          <% if (trips.deptcities && trips.deptcities.length > 0 && trips.deptcities[0].City !== 'Unknown') { %>
          <div class="booking-section-label" style="margin-top:14px;">Travelling Options</div>
          <div class="transport-options d-flex flex-wrap gap-2" id="transportOptions" role="radiogroup" aria-label="Transport Types"></div>
          <div>
            <div class="booking-section-label">Available Dates</div>
            <div class="tour-booking-year-tabs" id="yearTabs"></div>
            <div class="tour-booking-month-tabs" id="monthTabs"></div>
            <div class="tour-booking-date-selector" id="dateSelector"></div>
          </div>
          <% } %>
        </article>
        <% if (trips && trips.itinerary && trips.itinerary.length > 0) { %>
          <article class="custom-card p-3 p-lg-4">
            <div class="itin-header">
              <h3 class="itin-title">Itinerary</h3>
              <div class="itin-actions">
                <% if (trips.documentUrl) { %>
                <button type="button" class="itin-action-btn" onclick="downloadItinerary()">
                  <i class="bi bi-download"></i> Get PDF
                </button>
                <% } %>
                <button type="button" class="itin-action-btn" id="itinExpandBtn" onclick="toggleAllItinerary()">
                  <i class="bi bi-arrows-expand" id="itinExpandIcon"></i>
                  <span id="itinExpandLabel">Expand All</span>
                </button>
              </div>
            </div>
            <div class="accordion" id="accordionPanelsStayOpenExample">
              <% trips.itinerary.forEach((item, index) => { %>
                <% if (!item.day || !item.header || !item.description) return; %>
                <div class="accordion-item itin-item">
                  <h3 class="accordion-header">
                    <button class="accordion-button itin-acc-btn <%= index === 0 ? '' : 'collapsed' %>"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#itinerary-<%= index %>"
                      aria-expanded="<%= index === 0 ? 'true' : 'false' %>"
                      aria-controls="itinerary-<%= index %>">
                      <span class="itin-day-badge">Day <%= index + 1 %></span>
                      <span class="itin-btn-text"><%= item.header %></span>
                    </button>
                  </h3>
                  <div id="itinerary-<%= index %>"
                    class="accordion-collapse collapse<%= index === 0 ? ' show' : '' %>">
                    <div class="accordion-body"><%- item.description %></div>
                  </div>
                </div>
              <% }); %>
            </div>
          </article>
        <% } %>
        <article class="pt-4 mt-3 mt-lg-0">
          <h3>More Information</h3>
          <div class="position-relative more-info-tabs-wrap">
          <div class="tab-menu more-info-tabs d-flex overflow-auto gap-3 mb-3 scroll-hide h-scroll">
            <% if (trips.package_cost) { %>
            <button class="tab text-nowrap active" onclick="showTab('package')"><i class="bi bi-wallet2"></i> Package Cost</button>
            <% } %>
            <% if (trips.activities) { %>
            <button class="tab text-nowrap" onclick="showTab('attractions')"><i class="bi bi-star-fill"></i> Main Attractions</button>
            <% } %>
            <% if (trips.things_to_carry) { %>
            <button class="tab text-nowrap" onclick="showTab('carry')"><i class="bi bi-backpack"></i> Things to Carry</button>
            <% } %>
            <% if (trips.bookncancel) { %>
            <button class="tab text-nowrap" onclick="showTab('bookncancel')"><i class="bi bi-info-circle"></i> Cancellation Policy</button>
            <% } %>
            <% if (trips.includenexclude) { %>
            <button class="tab text-nowrap" onclick="showTab('includenexclude')"><i class="bi bi-check-circle"></i> Inclusion & Exclusion</button>
            <% } %>
            <% if (trips.infonfaq) { %>
            <button class="tab text-nowrap" onclick="showTab('infonfaq')"><i class="bi bi-question-circle"></i> Info & FAQs</button>
            <% } %>
          </div>
          </div><!-- end more-info-tabs-wrap -->
          <% if (trips.package_cost) { %>
          <div id="package" class="tab-content active"><%- trips.package_cost %></div>
          <% } %>
          <% if (trips.activities) { %>
          <div id="attractions" class="tab-content"><%- trips.activities %></div>
          <% } %>
          <% if (trips.things_to_carry) { %>
          <div id="carry" class="tab-content"><%- trips.things_to_carry %></div>
          <% } %>
          <% if (trips.bookncancel) { %>
          <div id="bookncancel" class="tab-content"><%- trips.bookncancel %></div>
          <% } %>
          <% if (trips.includenexclude) { %>
          <div id="includenexclude" class="tab-content"><%- trips.includenexclude %></div>
          <% } %>
          <% if (trips.infonfaq) { %>
          <div id="infonfaq" class="tab-content"><%- trips.infonfaq %></div>
          <% } %>
        </article>
      </div>
      <aside class="col-lg-5 col-xl-4 align-self-start stickySec">
        <div class="actionCard card border-0 p-3 d-flex flex-row flex-wrap gap-2 align-items-center mb-3">
          <span class="fw-semibold w-100 mb-1" style="font-size:0.95rem; color:#1A3C6C;"><i class="bi bi-chat-dots-fill me-1"></i> Still Got Queries?</span>
          <a class="btn btn-outline-success rounded-pill btn-sm flex-grow-1"
          href="https://wa.me/+918511117891?text=Hello%20I%20am%20interested%20in%20the%20following%20trip%20<%= encodeURIComponent(trips.name) %>%20tour.%20could%20you%20please%20share%20more%20details."
          target="_blank" aria-label="Contact via WhatsApp for <%= trips.name %>">
            <i class="bi bi-whatsapp me-1"></i> WhatsApp
          </a>
          <button class="btn btn-app-stroked-primary rounded-pill btn-sm flex-grow-1" data-bs-toggle="modal" data-bs-target="#quickCallModal"><i class="bi bi-telephone-forward me-1"></i> Call Back</button>
          <a class="btn btn-app-primary rounded-pill btn-sm flex-grow-1" href="/dreamtrip" target="_blank" title="Plan your dream trip"><i class="bi bi-calendar-check me-1"></i> Plan trip</a>
        </div>
        <form class="card border-0 overflow-hidden" id="proceedToBook" action="/bookingTour/<%- trips._id %>" method="GET">
          <div class="sidebar-card-header">
            <div class="sidebar-trip-name">Book Your Trip</div>
            <div class="d-flex align-items-center justify-content-between mt-1">
              <strong style="font-size:1.05rem;"><%= trips.name %></strong>
              <% if (trips.deptcities && trips.deptcities.length > 0 && trips.deptcities[0].City !== 'Unknown' && trips.deptcities[0].price && trips.deptcities[0].price[0]) { %>
              <span class="sidebar-price-pill">₹<%= trips.deptcities[0].price[0].adultPrice?.toLocaleString('en-IN') %><small>/person</small></span>
              <% } %>
            </div>
          </div>
          <div class="card-body d-flex flex-column gap-0 p-0">
            <div class="tour-booking-summary-card">
              <div class="sidebar-summary-title">Booking Summary</div>
              <div class="booking-summary-item">
                <span>Departure City</span>
                <span class="booking-summary-city">Not selected</span>
              </div>
              <div class="booking-summary-item">
                <span>Tour Date</span>
                <span class="booking-summary-date">Not selected</span>
              </div>
              <div class="booking-summary-item">
                <span>Duration</span>
                <span class="booking-summary-duration">Not selected</span>
              </div>
              <div class="booking-summary-item">
                <span>Price</span>
                <span class="booking-summary-price">Not selected</span>
              </div>
              <div class="booking-summary-item">
                <span>Transport</span>
                <span class="booking-summary-transport">Not selected</span>
              </div>
              <% if(trips.seats){ %>
              <div class="booking-summary-item">
                <span>Seats Available</span>
                <span class="booking-summary-seats text-success fw-bold"><%= trips.seats %> left!</span>
              </div>
              <% } %>
            </div>
            <label for="selectedCity" class="form-label visually-hidden">Joining from</label>
            <select class="form-select mb-3 visually-hidden" id="selectedCity" name="city" onchange="updateCityFromDropdown()">
              <% if (trips.deptcities && trips.deptcities.length > 0 && trips.deptcities[0].City !== 'Unknown') { %>
              <% trips.deptcities.forEach((city) => { %>
