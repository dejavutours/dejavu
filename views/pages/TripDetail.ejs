<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/headtag', {isNiceSelect: false}); %>
  <title><%= trips.name %> - Trip Details | Deja-vu Tours</title>
  <!-- Dynamic meta description for SEO -->
  <!-- JSON-LD for SEO -->
  <meta name="description" content="<%= trips.about ? trips.about.replace(/<[^>]+>/g, '').substring(0, 160) : 'Discover ' + trips.name + ' with Deja-vu Tours. Book your trip today!' %>" />
  <meta property="og:title" content="<%= trips.name %> - Deja-vu Tours" />
  <meta property="og:description" content="<%= trips.about ? trips.about.replace(/<[^>]+>/g, '').substring(0, 160) : 'Explore ' + trips.name + ' with Deja-vu Tours. Book your adventure now!' %>" />
  <meta property="og:image" content="<%= trips.bannerimages && trips.bannerimages.length > 0 ? trips.bannerimages[0] : trips.imageurl || 'https://www.dejavutours.in/images/pavagadh-trekking.jpg' %>" />
  <meta property="og:url" content="https://www.dejavutours.in/tripdetail/<%= trips.name %>" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Deja-vu Tours" />
  <link rel="canonical" href="https://www.dejavutours.in/tripdetail/<%= trips.name %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Event",
      "name": "<%= trips.name %>",
      "description": "<%= trips.about ? trips.about.replace(/<[^>]+>/g, '').substring(0, 200) : 'Join our exciting trip to ' + trips.destinations %>",
      "startDate": "<%= trips.deptcities && trips.deptcities[0] && trips.deptcities[0].dates && trips.deptcities[0].dates[0] ? new Date(trips.deptcities[0].dates[0].dates.split(', ')[0] + ' ' + trips.deptcities[0].dates[0].Month + ' ' + trips.deptcities[0].dates[0].Year).toISOString() : '' %>",
      "location": {
        "@type": "Place",
        "name": "<%= trips.destinations %>",
        "address": {
          "@type": "PostalAddress",
          "addressRegion": "<%= trips.state %>",
          "addressCountry": "IN"
        }
      },
      "organizer": {
        "@type": "Organization",
        "name": "Deja-vu Tours Treks and Travel",
        "url": "https://www.dejavutours.in"
      },
      "offers": {
        "@type": "Offer",
        "price": "<%= trips.deptcities && trips.deptcities[0] && trips.deptcities[0].price && trips.deptcities[0].price[0] ? trips.deptcities[0].price[0].adultPrice : trips.price || 'Contact for details' %>",
        "priceCurrency": "INR",
        "availability": "<%= trips.deptcities && trips.deptcities.length > 0 && trips.deptcities[0].City !== 'Unknown' ? 'InStock' : 'OutOfStock' %>",
        "url": "https://www.dejavutours.in/bookingTour/<%= trips._id %>"
      }
    }
  </script>
  <style>
    :root {
  --primary-blue: #1a4b8e;
  --light-gray: #f8f9fa;
  --shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  --transition: 0.3s ease;
  --error-red: #dc3545;
  --premium-gold: #FFD700;
  --dark-gray: #333333;
}

body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
.normal-hight { line-height: normal; }

/* Image slider styling */
.image-slider {
  width: 100%;
  border-radius: 12px;
  overflow: hidden;
  position: relative;
  height: 360px;
}

@media (min-width: 992px) {
  .image-slider { height: 500px; }
}
.swiper-slide { width: 100%; height: 100%; }
.image-slider img { width: 100%; height: 100%; object-fit: cover; }
.image-slider::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 55%;
  background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, transparent 100%);
  z-index: 1;
  pointer-events: none;
}
.trip-hero-overlay {
  position: absolute;
  bottom: 0; left: 0;
  z-index: 2;
  padding: 1.25rem 1.5rem;
  color: #fff;
}

.swiper-button-next,
.swiper-button-prev {
  color: white;
  background: rgba(0, 0, 0, 0.3);
  width: 40px;
  height: 40px;
  border-radius: 50%;
  transition: background var(--transition);
}

.swiper-button-next:hover,
.swiper-button-prev:hover {
  background: rgba(0, 0, 0, 0.5);
}

.swiper-button-next:after,
.swiper-button-prev:after { font-size: 20px; }

.swiper-pagination-bullet {
  background: white;
  opacity: 0.7;
  transition: opacity var(--transition);
}

.swiper-pagination-bullet-active { opacity: 1; }

/* Trip stat grid */
.trip-stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
.trip-stat-item { background: #f8f9fa; border-radius: 12px; padding: 0.75rem; text-align: center; border-top: 3px solid #EF4F5F; }
.trip-stat-icon { font-size: 1.4rem; color: #EF4F5F; margin-bottom: 0.25rem; }
.trip-stat-label { font-size: 0.7rem; color: #6c757d; text-transform: uppercase; letter-spacing: 0.05em; }
.trip-stat-value { font-size: 0.9rem; font-weight: 600; color: #212529; }

/* Itinerary accordion enhancements */
.accordion-item { border-left: 3px solid transparent; transition: border-color 0.2s; }
.accordion-item:has(.accordion-button:not(.collapsed)) { border-left-color: var(--primary-blue); }
.itinerary-day-badge { display: inline-flex; align-items: center; justify-content: center; width: 24px; height: 24px; background: var(--primary-blue); color: #fff; border-radius: 50%; font-size: 0.7rem; font-weight: 700; margin-right: 0.5rem; flex-shrink: 0; }
.itin-header { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px; margin-bottom:16px; }
.itin-title { font-size:1.1rem; font-weight:700; color:#111; margin:0; }
.itin-actions { display:flex; gap:8px; flex-shrink:0; }
.itin-action-btn { display:inline-flex; align-items:center; gap:5px; padding:6px 14px; border:1.5px solid #d1d5db; border-radius:50px; background:#fff; color:#374151; font-size:0.8rem; font-weight:500; cursor:pointer; white-space:nowrap; transition:background 0.15s; }
.itin-action-btn:hover { background:#f3f4f6; }
.itin-item { border:1px solid #e5e7eb; border-radius:10px; overflow:hidden; margin-bottom:8px; border-left:1px solid #e5e7eb; }
.itin-acc-btn { background:#fff; gap:10px; padding:12px 14px; box-shadow:none !important; }
.itin-acc-btn:not(.collapsed) { background:#f8f9fa; box-shadow:none !important; }
.itin-acc-btn::after { margin-left:auto; flex-shrink:0; }
.itin-day-badge { display:inline-flex; align-items:center; justify-content:center; background:#4b5563; color:#fff; border-radius:7px; padding:3px 10px; font-size:0.72rem; font-weight:700; letter-spacing:0.02em; white-space:nowrap; flex-shrink:0; }
.itin-btn-text { font-size:0.9rem; font-weight:500; color:#111; line-height:1.3; }
.itin-acc-btn.collapsed .itin-btn-text { color:#374151; }

/* FAB polish — sizing handled in Mobile Booking Styles block above */

/* More info tabs scroll fade */
.more-info-tabs-wrap::after {
  content: '';
  position: absolute;
  right: 0; top: 0; bottom: 0;
  width: 40px;
  background: linear-gradient(to right, transparent, #fff);
  pointer-events: none;
  z-index: 1;
}

/* Mobile sheet drag handle */
.sheet-drag-handle {
  width: 36px; height: 4px;
  background: #d1d5db;
  border-radius: 2px;
  margin: 10px auto 2px;
  flex-shrink: 0;
}

header .subtitle { color: #6c757d; font-size: 0.875rem; }

.abouts:not(.expanded) {
  max-height: 150px;
  overflow: hidden;
  text-overflow: ellipsis;
  -o-text-overflow: ellipsis;
  -ms-text-overflow: ellipsis;
}

.about-mask {
  height: 40px;
  pointer-events: none;
  background-image: linear-gradient(to bottom, rgba(255, 255, 255, 0) 0%, #fff 90%);
  z-index: 1;
}

.about-read-more-btn { text-underline-offset: 2px; }

/* Section heading accent */
.detailSec article > h3 {
  display: inline-block;
  padding-bottom: 6px;
  border-bottom: 3px solid #EF4F5F;
  margin-bottom: 1rem;
}

/* Payment option cards — styled like real payment mode tiles */
.tour-booking-payment-option {
  border: 1.5px solid #e2e8f0;
  border-radius: 10px;
  padding: 11px 14px;
  margin-bottom: 8px;
  cursor: pointer;
  transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
  display: flex;
  align-items: center;
  gap: 10px;
  background: #fff;
}
.tour-booking-payment-option:has(input:checked) {
  border-color: #16a34a;
  background: #f0fdf4;
  box-shadow: 0 0 0 2px rgba(22,163,74,0.12);
}
.tour-booking-payment-option label {
  cursor: pointer; margin: 0; width: 100%;
  display: flex; align-items: center; justify-content: space-between;
}
.tour-booking-payment-option label .pay-amount {
  font-weight: 700; color: #16a34a; font-size: 0.95rem;
}
.tour-booking-payment-option input[type="radio"] { accent-color: #16a34a; width: 16px; height: 16px; flex-shrink: 0; }

/* Mobile payment option cards */
.mobile-payment-option {
  border: 1.5px solid #e2e8f0;
  border-radius: 10px;
  padding: 11px 14px;
  margin-bottom: 8px;
  cursor: pointer;
  transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
  display: flex;
  align-items: center;
  gap: 10px;
  background: #fff;
}
.mobile-payment-option:has(input:checked) {
  border-color: #16a34a;
  background: #f0fdf4;
  box-shadow: 0 0 0 2px rgba(22,163,74,0.12);
}
.mobile-payment-option label { cursor: pointer; margin: 0; width: 100%; display: flex; justify-content: space-between; align-items: center; }
.mobile-payment-option label .payment-price { font-weight: 700; color: #16a34a; }
.mobile-payment-option input[type="radio"] { accent-color: #16a34a; width: 16px; height: 16px; flex-shrink: 0; }

/* City card styling */
.tour-booking-city-card {
  width: 148px;
  flex-shrink: 0;
  text-align: center;
  background: #fff;
  padding: 0;
  border: 2px solid #e5e7eb;
  border-radius: 14px;
  cursor: pointer;
  overflow: hidden;
  transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
  position: relative;
}
.tour-booking-city-card:hover {
  border-color: #1a4b8e;
  box-shadow: 0 4px 16px rgba(26,75,142,0.15);
  transform: translateY(-3px);
}
.tour-booking-city-card.active {
  border-color: #1a4b8e;
  box-shadow: 0 4px 16px rgba(26,75,142,0.2);
}
.tour-booking-city-card.active::after {
  content: '✓';
  position: absolute;
  top: 7px; right: 8px;
  font-size: 0.72rem;
  font-weight: 700;
  color: #fff;
  background: #1a4b8e;
  width: 20px; height: 20px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  line-height: 1;
}
.tour-booking-city-card img {
  width: 100%;
  height: 90px;
  object-fit: cover;
  display: block;
}
.tour-booking-city-card-body {
  padding: 9px 10px 10px;
}
.tour-booking-city-card h6 {
  font-size: 0.88rem;
  margin: 0 0 3px;
  font-weight: 600;
  color: #111827;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.tour-booking-city-card small {
  font-size: 0.75rem;
  color: #6b7280;
  line-height: 1.2;
  display: block;
}
.tour-booking-city-card .city-price {
  font-size: 0.82rem;
  font-weight: 700;
  color: #16a34a;
  margin-top: 3px;
}

/* Carousel track */
#carouselTrack {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  scroll-behavior: smooth;
  scrollbar-width: none;
  -ms-overflow-style: none;
  padding: 6px 2px 10px;
  white-space: nowrap;
}

#carouselTrack::-webkit-scrollbar { display: none; }

/* Carousel controls */
.carousel-control-prev,
.carousel-control-next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 50%;
  width: 36px;
  height: 36px;
  transition: background var(--transition);
  opacity: 0.9;
}

.carousel-control-prev:hover,
.carousel-control-next:hover {
  background: rgba(0, 0, 0, 0.6);
  opacity: 1;
}

.carousel-control-prev { left: -15px; }
.carousel-control-next { right: -15px; }

/* Departure city and available dates */
.tour-booking-departure-section { margin-top: 1.5rem; }

/* Section sub-headings inside departure card */
.booking-section-label {
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #6b7280;
  margin-bottom: 10px;
  margin-top: 22px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.booking-section-label::before {
  content: '';
  width: 3px;
  height: 12px;
  background: #1a4b8e;
  border-radius: 2px;
  display: inline-block;
  flex-shrink: 0;
}

/* Year/month pill tabs */
.tour-booking-year-tabs,
.tour-booking-month-tabs {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 10px;
}

.tour-booking-year-tab,
.tour-booking-month-tab {
  background: #f3f4f6;
  border: 1.5px solid transparent;
  padding: 5px 14px;
  cursor: pointer;
  font-weight: 500;
  font-size: 0.82rem;
  border-radius: 20px;
  color: #374151;
  transition: all var(--transition);
  white-space: nowrap;
}
.tour-booking-year-tab:hover,
.tour-booking-month-tab:hover {
  border-color: #1a4b8e;
  color: #1a4b8e;
  background: #f0f4ff;
}
.tour-booking-year-tab.active,
.tour-booking-month-tab.active {
  background: #1a4b8e;
  color: #fff;
  border-color: #1a4b8e;
  box-shadow: 0 2px 6px rgba(26,75,142,0.25);
}

/* Date grid */
.tour-booking-date-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  padding: 4px 0 8px;
}

.tour-booking-date-item {
  min-width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8px;
  font-size: 0.88rem;
  font-weight: 500;
  border: 1.5px solid #e5e7eb;
  border-radius: 10px;
  background: #fff;
  cursor: pointer;
  transition: all var(--transition);
  color: #374151;
}
.tour-booking-date-item:hover {
  border-color: #1a4b8e;
  color: #1a4b8e;
  background: #f0f4ff;
}
.tour-booking-date-item.active {
  background: #1a4b8e;
  color: #fff;
  border-color: #1a4b8e;
  box-shadow: 0 2px 8px rgba(26,75,142,0.3);
  font-weight: 700;
}

/* ── Sidebar card shell ── */
.stickySec > form.card {
  border: none !important;
  border-radius: 1rem !important;
  overflow: hidden;
  box-shadow: 0 4px 24px rgba(0,0,0,0.10) !important;
}

/* Money-green header — like Zomato/Swiggy treat payment confirmation */
.sidebar-card-header {
  background: linear-gradient(135deg, #15803d 0%, #166534 100%);
  padding: 1rem 1.25rem 0.9rem;
  color: #fff;
}
.sidebar-card-header .sidebar-trip-name {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  opacity: 0.75;
  margin-bottom: 3px;
}
.sidebar-card-header strong { font-size: 1rem; font-weight: 700; display: block; line-height: 1.3; }
.sidebar-card-header .sidebar-price-pill {
  display: inline-flex;
  align-items: baseline;
  gap: 2px;
  background: rgba(255,255,255,0.18);
  border: 1px solid rgba(255,255,255,0.3);
  color: #fff;
  border-radius: 6px;
  padding: 3px 10px;
  font-size: 1.05rem;
  font-weight: 800;
  margin-top: 2px;
  backdrop-filter: blur(4px);
}
.sidebar-card-header .sidebar-price-pill small { font-size: 0.68rem; font-weight: 400; opacity: 0.8; }

/* Booking summary rows */
.tour-booking-summary-card {
  background: #fff;
  border: none;
  border-bottom: 1px solid #f0f0f0;
  border-radius: 0;
  padding: 1rem 1.25rem 0.75rem;
}

.sidebar-summary-title {
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #9ca3af;
  margin-bottom: 0.65rem;
}

.booking-summary-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
  font-size: 0.83rem;
  border-bottom: 1px solid #f5f5f5;
}
.booking-summary-item:last-child { border-bottom: none; }
.booking-summary-item span:first-child { color: #9ca3af; font-size: 0.78rem; }
.booking-summary-item span:last-child { font-weight: 600; color: #111827; text-align: right; max-width: 58%; }
.booking-summary-item .booking-summary-price { color: #16a34a; font-weight: 700; font-size: 0.9rem; }

/* Payment options section */
.tour-booking-payment-options {
  padding: 0.85rem 1.25rem 0.5rem;
  background: #fafafa;
  border-top: 1px solid #f0f0f0;
}
.sidebar-payment-title {
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #9ca3af;
  margin-bottom: 0.6rem;
}

/* Proceed button — green = money action */
.tour-booking-proceed-btn {
  width: 100%;
  padding: 14px;
  font-size: 1rem;
  font-weight: 700;
  border-radius: 10px;
  background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
  color: #fff;
  border: none;
  letter-spacing: 0.02em;
  transition: opacity var(--transition), box-shadow var(--transition);
  box-shadow: 0 4px 14px rgba(22,163,74,0.4);
}
.tour-booking-proceed-btn:hover { opacity: 0.93; color: #fff; box-shadow: 0 6px 20px rgba(22,163,74,0.5); }
.tour-booking-proceed-btn:disabled { background: #d1d5db; box-shadow: none; cursor: not-allowed; color: #9ca3af; opacity: 1; }

/* Still Got Queries card */
.actionCard {
  border: 1px solid #e3eaf5 !important;
  border-radius: 1rem !important;
  background: #fff;
}
.actionCard .btn { font-size: 0.8rem; }

/* Modal and form styling */
.trip-details-form-select,
.booking-modal-select {
  border: 1px solid #dee2e6;
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 0.95rem;
  color: #333;
  background-color: white;
  box-shadow: var(--shadow);
  transition: border-color var(--transition), box-shadow var(--transition);
}

.trip-details-form-select:focus,
.booking-modal-select:focus {
  border-color: var(--primary-blue);
  box-shadow: 0 0 0 0.2rem rgba(26, 75, 142, 0.25);
  outline: none;
}

.trip-details-form-select:disabled,
.booking-modal-select:disabled {
  background-color: #e9ecef;
  cursor: not-allowed;
}

.trip-details-form-select.is-invalid,
.booking-modal-select.is-invalid {
  border-color: var(--error-red);
}

/* ── Contact / inquiry modal — same shell as quickCallModal ── */
.contact-modal-content {
  border: none;
  border-radius: 22px;
  overflow: hidden;
  box-shadow: 0 8px 16px rgba(0,0,0,0.2);
  max-width: 450px;
  margin: 0 auto;
}
/* Navy gradient header — mirrors quickCallModal header */
.contact-modal-header {
  background: linear-gradient(150deg, #1A3C6C 0%, #0f2647 60%, #15437a 100%);
  padding: 28px 24px 22px;
  text-align: center;
  position: relative;
}
.contact-modal-close {
  position: absolute;
  top: 12px; right: 12px;
  background: none;
  border: none;
  color: rgba(255,255,255,0.7);
  font-size: 1rem;
  cursor: pointer;
  padding: 4px;
  line-height: 1;
  z-index: 1;
}
.contact-modal-close:hover { color: #fff; }
/* Icon ring — mirrors .qcm-icon-ring */
.contact-modal-icon-ring {
  width: 56px; height: 56px;
  background: rgba(255,255,255,0.14);
  border: 2px solid rgba(255,255,255,0.22);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 14px;
}
.contact-modal-icon-ring i { font-size: 1.5rem; color: #fff; }
.contact-modal-header h5 {
  color: #fff;
  font-size: 1.05rem;
  font-weight: 700;
  margin: 0 0 5px;
  line-height: 1.3;
}
.contact-modal-header p {
  color: rgba(255,255,255,0.72);
  font-size: 0.82rem;
  margin: 0;
}

/* Modal body */
.contact-modal-body {
  padding: 20px 22px 4px;
  background: #fff;
}
.contact-modal-message {
  font-size: 0.85rem;
  color: #4b5563;
  line-height: 1.55;
  margin-bottom: 14px;
}
/* WhatsApp CTA — primary */
.contact-modal-wa-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #25D366;
  color: #fff;
  border-radius: 10px;
  padding: 12px 16px;
  text-decoration: none;
  font-weight: 600;
  font-size: 0.9rem;
  margin-bottom: 8px;
  transition: background 0.18s;
}
.contact-modal-wa-btn:hover { background: #20b559; color: #fff; }
.contact-modal-wa-btn i { font-size: 1.1rem; flex-shrink: 0; }
.contact-modal-wa-btn small { font-size: 0.72rem; opacity: 0.88; display: block; font-weight: 400; }
/* Call / secondary action */
.contact-modal-call-btn {
  display: flex;
