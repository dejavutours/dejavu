  <%- include('../partials/footer'); %>
  <%- include('../partials/scripttag', {isNiceSelect: true}); %>
  <script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.js"></script>
  <!-- <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script> -->
  <script>
    // Utility to debounce functions
    const debounce = (func, wait) => {
      let timeout;
      return (...args) => {
        clearTimeout(timeout);
        timeout = setTimeout(() => func.apply(this, args), wait);
      };
    };

    // Show toast notification
    const showToast = (message, type = 'primary') => {
      const toast = document.createElement('div');
      toast.className = `toast align-items-center text-bg-${type} border-0`;
      toast.setAttribute('role', 'alert');
      toast.setAttribute('aria-live', 'assertive');
      toast.setAttribute('aria-atomic', 'true');
      toast.innerHTML = `
        <div class="d-flex">
          <div class="toast-body">${message}</div>
          <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
      `;
      document.body.appendChild(toast);
      const bsToast = new bootstrap.Toast(toast);
      bsToast.show();
      setTimeout(() => toast.remove(), 3000);
    };

    // Initialize Bootstrap tooltips
    const initTooltips = () => {
      document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
        new bootstrap.Toast(el);
      });
    };

    // Handle filter updates — keys must match backend expectations exactly
    const updateFilterValue = () => {
      const get = (name) => Array.from(document.querySelectorAll(`#filterDrawer input[name="${name}"]:checked`)).map(i => i.value);
      const categories = {
        'Tour category': get('category'),
        'Tour type': get('type'),
        'Departure city': get('city')
      };
      document.getElementById('filterValue').value = JSON.stringify(categories);
      updateFilterBadge();
    };

    const updateFilterBadge = () => {
      const total = document.querySelectorAll('#filterDrawer input[type=checkbox]:checked').length;
      const badge = document.getElementById('filterCountBadge');
      if (badge) { badge.textContent = total; badge.style.display = total > 0 ? 'inline-flex' : 'none'; }
    };

    // Submit tour list form
    const submitTourList = () => {
      document.getElementById('tourList').submit();
    };

    // ── Share popover ──
    let _shareCurrentTrip = '';

    function openSharePopover(triggerEl, trip) {
      _shareCurrentTrip = trip.name;
      document.getElementById('sharePopoverName').textContent = trip.name;
      document.getElementById('sharePopoverSub').textContent = trip.dest || '';
      const imgEl = document.getElementById('sharePopoverImg');
      imgEl.onerror = function() { this.src = '/images/placeholder.jpg'; };
      imgEl.src = trip.img && trip.img.trim() ? trip.img : '/images/placeholder.jpg';
      imgEl.alt = trip.name;
      document.getElementById('shareCopiedMsg').textContent = '';

      const popover = document.getElementById('sharePopover');
      // Center on screen
      popover.style.left = '50%';
      popover.style.top = '50%';
      popover.style.transform = 'translate(-50%, -50%)';
      document.getElementById('shareBackdrop').classList.add('open');
      popover.classList.add('open');
    }

    function closeSharePopover() {
      document.getElementById('sharePopover').classList.remove('open');
      document.getElementById('shareBackdrop').classList.remove('open');
      _shareCurrentTrip = '';
    }

    function shareCopyLink() {
      const url = window.location.origin + '/tripdetail/' + encodeURIComponent(_shareCurrentTrip);
      navigator.clipboard.writeText(url).then(function() {
        const msg = document.getElementById('shareCopiedMsg');
        msg.textContent = '✓ Link copied to clipboard';
        setTimeout(function() { msg.textContent = ''; }, 2500);
      });
    }

    function shareViaWhatsApp() {
      const url = window.location.origin + '/tripdetail/' + encodeURIComponent(_shareCurrentTrip);
      const text = 'Check out this trip: *' + _shareCurrentTrip + '*\n' + url;
      window.open('https://wa.me/?text=' + encodeURIComponent(text), '_blank');
      closeSharePopover();
    }

    // Close share popover on Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeSharePopover();
        imCloseLightbox();
      }
    });

    function setRegion(val) {
      document.getElementById('regionFilterInput').value = val;
      updateFilterValue();
      submitTourList();
    }

    function openFilterDrawer() {
      document.getElementById('filterOverlay').classList.add('open');
      document.getElementById('filterDrawer').classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeFilterDrawer() {
      document.getElementById('filterOverlay').classList.remove('open');
      document.getElementById('filterDrawer').classList.remove('open');
      document.body.style.overflow = '';
    }

    function clearFilters() {
      document.querySelectorAll('#filterDrawer input[type=checkbox]').forEach(function(cb) { cb.checked = false; });
    }

    function applyFilters() {
      updateFilterValue();
      closeFilterDrawer();
      submitTourList();
    }

    const removeChip = (chip) => {
      const chipProperty = document.getElementById(chip);
      if (chipProperty) chipProperty.checked = false;
      updateFilterValue();
      submitTourList();
    };

    // Handle search chip removal
    const removeSearchChip = () => {
      document.getElementById('searchValue').value = '';
      document.getElementById('searchEntry').value = '';
      updateFilterValue();
      submitTourList();
    };

    // // Handle share functionality
    // const handleShare = (name, state, imageurl) => {
    //   const shareUrl = `${window.location.origin}/tripdetail/${name}`;
    //   const shareData = {
    //     title: `${decodeURIComponent(name)} - ${state}`,
    //     text: `Check out this amazing trip: ${decodeURIComponent(name)} in ${state}, India!`,
    //     url: shareUrl
    //   };
    //   if (navigator.share) {
    //     navigator.share(shareData)
    //       .then(() => showToast('Shared successfully!'))
    //       .catch(() => fallbackToClipboard(shareUrl));
    //   } else {
    //     fallbackToClipboard(shareUrl);
    //   }
    // };

    // // Fallback to clipboard for share
    // const fallbackToClipboard = (url) => {
    //   navigator.clipboard.writeText(url)
    //     .then(() => showToast('Link copied to clipboard!'))
    //     .catch(() => showToast('Failed to copy link.', 'danger'));
    // };

    // ── Unified crop state ──
    let _tlCropper = null;
    let _tlCropModal = null;
    let _tlCropMode = 'banner';        // 'main' or 'banner'
    let _tlBannerQueue = [];           // File[] waiting to crop
    let _tlBannerIndex = 0;
    let _tlBannerBlobs = [];           // Final blobs/Files to upload

    const _tlGetAspectRatio = () => {
      const v = document.getElementById('tlCropRatio').value;
      return v === 'free' ? NaN : parseFloat(v);
    };

    const _tlInitCropper = (src) => {
      const img = document.getElementById('tlCropImage');
      // destroy() restores the img to its original state before we swap src
      if (_tlCropper) { _tlCropper.destroy(); _tlCropper = null; }
      img.onload = () => {
        _tlCropper = new Cropper(img, {
          aspectRatio: _tlGetAspectRatio(),
          viewMode: 1,
          autoCropArea: 0.85,
          movable: true,
          zoomable: true,
          rotatable: true,
          background: true,
          responsive: true
        });
      };
      img.src = src;
    };

    const _tlShowCropModal = (src, title, queueLabel) => {
      document.getElementById('tlCropModalLabel').textContent = title;
      document.getElementById('tlCropQueueLabel').textContent = queueLabel || '';
      if (!_tlCropModal) _tlCropModal = new bootstrap.Modal(document.getElementById('tlCropModal'));
      _tlCropModal.show();
      // Raise backdrops above the image management modal
      setTimeout(() => {
        document.querySelectorAll('.modal-backdrop').forEach(bd => {
          if (!bd.classList.contains('tl-crop-backdrop')) bd.classList.add('tl-crop-backdrop');
        });
        // Undo any nice-select wrapping on the ratio select so it behaves as native
        const ratioSel = document.getElementById('tlCropRatio');
        if (ratioSel && typeof $ !== 'undefined') {
          try { $(ratioSel).niceSelect('destroy'); } catch(e) {}
        }
      }, 60);
      // Init Cropper after modal is fully visible so it gets correct container dimensions
      document.getElementById('tlCropModal').addEventListener('shown.bs.modal', function onShown() {
        document.getElementById('tlCropModal').removeEventListener('shown.bs.modal', onShown);
        _tlInitCropper(src);
      });
    };

    // Called when admin changes the ratio selector inside the modal
    const _tlOnRatioChange = () => {
      if (!_tlCropper) return;
      _tlCropper.setAspectRatio(_tlGetAspectRatio());
    };

    // ── Fullscreen toggle ──
    let _tlIsFullscreen = false;
    const _tlToggleFullscreen = () => {
      const modal = document.getElementById('tlCropModal');
      const icon  = document.getElementById('tlCropFullscreenIcon');
      _tlIsFullscreen = !_tlIsFullscreen;
      modal.classList.toggle('tl-fullscreen', _tlIsFullscreen);
      icon.className = _tlIsFullscreen ? 'bi bi-fullscreen-exit' : 'bi bi-fullscreen';
      // Cropper needs to re-calculate container size after resize
      setTimeout(() => { if (_tlCropper) _tlCropper.resize(); }, 50);
    };

    // ── Main image crop ──
    const _tlStartMainCrop = (file) => {
      _tlCropMode = 'main';
      // Store file in input first so Skip can read it
      const dt = new DataTransfer();
      dt.items.add(file);
      document.getElementById('mainImageInput').files = dt.files;
      document.getElementById('tlCropRatio').value = 'free';
      const reader = new FileReader();
      reader.onload = (e) => _tlShowCropModal(e.target.result, 'Crop Main Image', '');
      reader.readAsDataURL(file);
    };

    // ── Banner crop queue ──
    const _tlStartBannerQueue = (files) => {
      const invalid = files.find(f => !f.type.startsWith('image/'));
      if (invalid) { showToast('Please upload only valid image files.', 'danger'); return; }
      const oversized = files.find(f => f.size > 5 * 1024 * 1024);
      if (oversized) { showToast('Each banner image must be under 5 MB.', 'danger'); return; }

      _tlCropMode = 'banner';
      _tlBannerQueue = files;
      _tlBannerIndex = 0;
      _tlBannerBlobs = [];
      // Default ratio to 16:9 for banners
      document.getElementById('tlCropRatio').value = '1.777';
      _tlBannerLoadNext();
    };

    const _tlBannerLoadNext = () => {
      if (_tlBannerIndex >= _tlBannerQueue.length) {
        if (_tlCropper) { _tlCropper.destroy(); _tlCropper = null; }
        if (_tlCropModal) _tlCropModal.hide();
        _tlRenderPendingPreviews();
        return;
      }
      const file = _tlBannerQueue[_tlBannerIndex];
      const label = `Image ${_tlBannerIndex + 1} of ${_tlBannerQueue.length}`;
      const reader = new FileReader();
      reader.onload = (e) => {
        if (_tlBannerIndex === 0) {
          // First image — show modal fresh
          _tlShowCropModal(e.target.result, 'Crop Banner Image', label);
        } else {
          // Subsequent images — modal already open, just swap image
          document.getElementById('tlCropModalLabel').textContent = 'Crop Banner Image';
          document.getElementById('tlCropQueueLabel').textContent = label;
          _tlInitCropper(e.target.result);
        }
      };
      reader.readAsDataURL(file);
    };

    // ── Confirm crop ──
    const _tlCropConfirm = () => {
      if (!_tlCropper) return;
      const canvas = _tlCropper.getCroppedCanvas({ maxWidth: 1920, maxHeight: 1080 });
      canvas.toBlob((blob) => {
        const blobUrl = URL.createObjectURL(blob);
        const sizeLabel = _fmtSize(blob.size);
        const dimLabel = `${canvas.width} × ${canvas.height}px`;
        if (_tlCropMode === 'main') {
          // Replace main image file input + update preview + dirty state
          const file = new File([blob], `main-image-${Date.now()}.jpg`, { type: 'image/jpeg' });
          const dt = new DataTransfer();
          dt.items.add(file);
          document.getElementById('mainImageInput').files = dt.files;
          document.getElementById('mainImagePreviewImg').src = blobUrl;
          document.getElementById('mainImageCard').classList.add('is-dirty');
          document.getElementById('mainImageMeta').textContent = `Cropped · ${dimLabel} · ${sizeLabel}`;
          document.getElementById('mainImageCropBtn').style.display = 'inline-flex';
          _imSetDirty(true);
          if (_tlCropper) { _tlCropper.destroy(); _tlCropper = null; }
          if (_tlCropModal) _tlCropModal.hide();
        } else {
          // Banner queue — store blob, continue to next
          _tlBannerBlobs.push(blob);
          _tlBannerIndex++;
          _tlBannerLoadNext();
        }
      }, 'image/jpeg', 0.9);
    };

    // ── Skip (use original file unchanged) ──
    const _tlCropSkip = () => {
      if (_tlCropMode === 'main') {
        // File already set in input from _tlStartMainCrop; just update preview + dirty
        const file = document.getElementById('mainImageInput').files[0];
        if (file) {
          document.getElementById('mainImagePreviewImg').src = URL.createObjectURL(file);
          document.getElementById('mainImageCard').classList.add('is-dirty');
          document.getElementById('mainImageMeta').textContent = `Original · ${_fmtSize(file.size)}`;
          document.getElementById('mainImageCropBtn').style.display = 'inline-flex';
          _imSetDirty(true);
        }
        if (_tlCropper) { _tlCropper.destroy(); _tlCropper = null; }
        if (_tlCropModal) _tlCropModal.hide();
      } else {
        _tlBannerBlobs.push(_tlBannerQueue[_tlBannerIndex]);
        _tlBannerIndex++;
        _tlBannerLoadNext();
      }
    };

    // ── Render pending banner thumbnails after crop queue finishes ──
    const _tlRenderPendingPreviews = () => {
      const preview = document.getElementById('bannerImagesPreview');
      preview.querySelectorAll('.im-banner-thumb.is-dirty').forEach(el => el.remove());

      _tlBannerBlobs.forEach((blob, i) => {
        const url = URL.createObjectURL(blob);
        const isFile = blob instanceof File;
        const sizeLabel = _fmtSize(blob.size);
        const meta = isFile ? `Original · ${sizeLabel}` : `Cropped · ${sizeLabel}`;
        const thumb = _makeBannerThumb(
          url,
          `Pending ${i + 1}`,
          meta,
          true,
          // Crop button: re-crop this specific blob
          () => {
            _tlCropMode = 'banner';
            _tlBannerQueue = [isFile ? blob : new File([blob], `banner-${i}.jpg`, { type: 'image/jpeg' })];
            _tlBannerIndex = 0;
            const oldBlob = blob;
            _tlBannerBlobs.splice(i, 1);   // temporarily remove while re-cropping
            document.getElementById('tlCropRatio').value = '1.777';
            const reader = new FileReader();
            reader.onload = (e) => {
              _tlShowCropModal(e.target.result, `Re-crop Banner Image (${i + 1})`, '');
            };
            reader.readAsDataURL(_tlBannerQueue[0]);
            // On confirm, the queue will push to _tlBannerBlobs and call _tlBannerLoadNext
            // Since queue length=1 and index starts at 0, it will finish immediately after confirm
            _tlBannerIndex = 0;
          },
          // Remove button
          () => {
            _tlBannerBlobs.splice(i, 1);
            thumb.remove();
            if (_tlBannerBlobs.length === 0) _imSetDirty(
              document.getElementById('mainImageInput').files[0] != null
            );
          }
        );
        preview.appendChild(thumb);
      });
      _imSetDirty(true);
    };

    // ── Dirty-state helpers ──
    let _imDirty = false;
    const _imSetDirty = (val) => {
      _imDirty = val;
      const btn = document.getElementById('saveImages');
      if (!btn) return;
      if (val) btn.classList.add('is-dirty');
      else btn.classList.remove('is-dirty');
    };

    // ── Format file size ──
    const _fmtSize = (bytes) => bytes < 1024 * 1024
      ? (bytes / 1024).toFixed(0) + ' KB'
      : (bytes / (1024 * 1024)).toFixed(1) + ' MB';

    // ── Image preview lightbox ──
    const imOpenLightbox = (src, meta) => {
      const lb   = document.getElementById('imPreviewLightbox');
      const img  = document.getElementById('imPreviewLightboxImg');
      const info = document.getElementById('imPreviewLightboxMeta');
      img.src = src;
      // Show real pixel dimensions once image loads
      img.onload = () => {
        info.textContent = `${img.naturalWidth} × ${img.naturalHeight}px` + (meta ? `  ·  ${meta}` : '');
      };
      info.textContent = meta || '';
      lb.classList.add('open');
      document.body.style.overflow = 'hidden';
    };
    const imCloseLightbox = () => {
      document.getElementById('imPreviewLightbox').classList.remove('open');
      document.getElementById('imPreviewLightboxImg').src = '';
      document.body.style.overflow = '';
    };

    // ── Build a banner thumb element ──
    const _makeBannerThumb = (imgSrc, label, meta, isPending, onCrop, onRemove) => {
      const div = document.createElement('div');
      div.className = 'im-banner-thumb ' + (isPending ? 'is-dirty' : 'is-saved');
      div.innerHTML = `
        <img src="${imgSrc}" alt="${label}" title="${label}">
        ${isPending ? '<span class="im-pending-badge">Pending</span>' : ''}
        <div class="im-thumb-actions">
          <button type="button" class="btn btn-dark btn-sm py-0 px-1 preview-thumb-btn" title="Preview" style="opacity:0.82;"><i class="bi bi-eye"></i></button>
          ${isPending ? `<button type="button" class="btn btn-warning btn-sm py-0 px-1 crop-thumb-btn" title="Crop"><i class="bi bi-crop"></i></button>` : ''}
          <button type="button" class="btn btn-danger btn-sm py-0 px-1 remove-thumb-btn" title="Remove"><i class="bi bi-trash"></i></button>
        </div>
        <div class="im-thumb-meta">${meta}</div>
      `;
      div.querySelector('.preview-thumb-btn').addEventListener('click', () => imOpenLightbox(imgSrc, meta));
      if (isPending) div.querySelector('.crop-thumb-btn').addEventListener('click', onCrop);
      div.querySelector('.remove-thumb-btn').addEventListener('click', onRemove);
      return div;
    };

    // ── Image management ──
    const openImageModal = (tripId) => {
      const imageModal = new bootstrap.Modal(document.getElementById('imageManagementModal'));
      const allTours = <%- JSON.stringify(tourPackages || []) %>;

      const tour = allTours.find(t => t._id === tripId);
      if (!tour) return;

      // Reset all state
      _tlBannerQueue = [];
      _tlBannerIndex = 0;
      _tlBannerBlobs = [];
      _imSetDirty(false);
      if (_tlCropper) { _tlCropper.destroy(); _tlCropper = null; }
      if (_tlCropModal) _tlCropModal.hide();

      document.getElementById('tripIdForImages').value = tripId;

      // Main image
      const mainImg = document.getElementById('mainImagePreviewImg');
      mainImg.src = tour.imageurl || '/images/default.jpg';
      document.getElementById('mainImageCard').classList.remove('is-dirty');
      document.getElementById('mainImageCropBtn').style.display = 'none';
      document.getElementById('mainImageMeta').textContent = 'Saved image';
      document.getElementById('mainImageInput').value = '';

      // Banner images — saved ones
      document.getElementById('bannerImagesInput').value = '';
      const preview = document.getElementById('bannerImagesPreview');
      preview.innerHTML = '';
      (tour.bannerimages || []).forEach((url) => {
        const thumb = _makeBannerThumb(url, url.split('/').pop(), 'Saved', false, null, () => {
          removeBannerImage(tripId, url);
          thumb.remove();
          _imSetDirty(true);
        });
        preview.appendChild(thumb);
      });

      imageModal.show();
    };

    // Remove banner image
    const removeBannerImage = async (tripId, imageUrl) => {
      if (!confirm('Are you sure you want to remove this banner image?')) return;
      try {
        const response = await fetch('/admin/removeBannerImage', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': '<%= csrfToken %>'
          },
          body: JSON.stringify({ tripId, imageUrl })
        });
        const result = await response.json();
        if (result.success) {
          document.querySelector(`#bannerImagesPreview img[src="${imageUrl}"]`)?.parentElement.remove();
          showToast('Banner image removed successfully');
        } else {
          showToast(`Failed to remove banner image: ${result.message}`, 'danger');
        }
      } catch (error) {
        showToast('Error removing banner image.', 'danger');
      }
    };

    // Save images
    const saveImages = async () => {
      const tripId = document.getElementById('tripIdForImages').value;
      const mainImageInput = document.getElementById('mainImageInput');
      const bannerImagesInput = document.getElementById('bannerImagesInput');

      if (mainImageInput.files[0]) {
        if (!mainImageInput.files[0].type.startsWith('image/')) {
          showToast('Please upload a valid image for the main image.', 'danger');
          return;
        }
        if (mainImageInput.files[0].size > 5 * 1024 * 1024) {
          showToast('Main image must be under 5 MB.', 'danger');
          return;
        }
        const mainFormData = new FormData();
        mainFormData.append('image', mainImageInput.files[0]);
        mainFormData.append('tripId', tripId);
        try {
          const response = await fetch('/admin/updateImageUrl', {
            method: 'POST',
            headers: { 'X-CSRF-Token': '<%= csrfToken %>' },
            body: mainFormData
          });
          const result = await response.json();
          if (!result.success) {
            showToast(`Error updating main image: ${result.message}`, 'danger');
            return;
          }
        } catch (error) {
          showToast('Error updating main image.', 'danger');
          return;
        }
      }

      if (_tlBannerBlobs.length > 0 || bannerImagesInput.files.length > 0) {
        const blobsToUpload = _tlBannerBlobs.length > 0
          ? _tlBannerBlobs
          : Array.from(bannerImagesInput.files);
        const bannerFormData = new FormData();
        for (let i = 0; i < blobsToUpload.length; i++) {
          bannerFormData.append('image', blobsToUpload[i], `banner-${Date.now()}-${i}.jpg`);
        }
        bannerFormData.append('tripId', tripId);
        try {
          const response = await fetch('/admin/updateBannerImages', {
            method: 'POST',
            headers: { 'X-CSRF-Token': '<%= csrfToken %>' },
            body: bannerFormData
          });
          const result = await response.json();
          if (!result.success) {
            showToast(`Error updating banner images: ${result.message}`, 'danger');
            return;
          }
          _tlBannerBlobs = [];
        } catch (error) {
          showToast('Error updating banner images.', 'danger');
          return;
        }
      }

      _imSetDirty(false);
      showToast('Images updated successfully!');
      submitTourList();
      bootstrap.Modal.getInstance(document.getElementById('imageManagementModal')).hide();
    };

    // Validate quick call form
    const validateQuickCallForm = () => {
      const guestName = document.getElementById('guestName');
      const mobileNo = document.getElementById('mobileNo');
      const submitBtn = document.getElementById('submitQuickCall');

      const isNameValid = guestName.value.trim().length > 0;
      const isMobileValid = /^\d{8,15}$/.test(mobileNo.value.trim());

      guestName.classList.toggle('is-invalid', !isNameValid);
      mobileNo.classList.toggle('is-invalid', !isMobileValid);
      submitBtn.disabled = !(isNameValid && isMobileValid);

      return isNameValid && isMobileValid;
    };

    // Submit quick call form
    const submitQuickCall = async () => {
      if (!validateQuickCallForm()) return;

      const formData = {
        guestName: document.getElementById('guestName').value.trim(),
        mobileNo: `${document.getElementById('countryCode').value}${document.getElementById('mobileNo').value.trim()}`,
        tripId: document.getElementById('tripId').value,
        responded: false,
        markAsSpam: false,
        requestedDate: new Date().toISOString()
      };

      try {
        const response = await fetch('/quick-call/request', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': '<%= csrfToken %>'
          },
          body: JSON.stringify(formData)
        });
        if (response.ok) {
          bootstrap.Modal.getInstance(document.getElementById('quickCallModal')).hide();
          const successModal = new bootstrap.Modal(document.getElementById('quickCallSuccessModal'));
          successModal.show();
          document.getElementById('quickCallForm').reset();
          validateQuickCallForm();
        } else {
          showToast('Failed to submit request.', 'danger');
        }
      } catch (error) {
        showToast('Error submitting request.', 'danger');
      }
    };

    // Initialize on DOM load
    document.addEventListener('DOMContentLoaded', () => {
      initTooltips();

      // Initialize filter chips
      const filterChips = '<%= filterChips || "" %>'.split(',').filter(Boolean);
      filterChips.forEach(chip => {
        const chipProperty = document.getElementById(chip);
        if (chipProperty) chipProperty.checked = true;
      });
      const searchValue = '<%= Searchvalue || "" %>';
      if (searchValue) {
        document.getElementById('searchValue').value = searchValue;
        document.getElementById('searchEntry').value = searchValue;
      }

      // Event delegation for package cards
      document.querySelectorAll('.package-card').forEach(card => {
        card.addEventListener('click', (e) => {
          const target = e.target.closest('a, button');
          if (!target) {
            const tourName = card.dataset.tripName || card.querySelector('.trip-card-name, .card-title')?.textContent;
            if (tourName) window.location.href = `/tripdetail/${encodeURIComponent(tourName)}`;
            return;
          }

          if (target.classList.contains('whatsapp-btn')) {
            e.stopPropagation();
            return;
          }

          if (target.dataset.action === 'view') {
            e.stopPropagation();
            const tourName = card.dataset.tripName || card.querySelector('.trip-card-name')?.textContent;
            if (tourName) window.location.href = `/tripdetail/${encodeURIComponent(tourName)}`;
            return;
          }

          if (target.classList.contains('request-callback-btn')) {
            e.stopPropagation();
            document.getElementById('tripId').value = target.dataset.tripId;
          }

          if (target.dataset.action === 'share') {
            e.stopPropagation();
            openSharePopover(target, {
              name: target.dataset.tripName || card.dataset.tripName || '',
              img:  target.dataset.tripImg || '',
              dest: target.dataset.tripDest || ''
            });
          }

          if (target.classList.contains('edit-tour')) {
            e.stopPropagation();
            window.location.href = `/admin/addtours?tripid=${target.dataset.id}`;
          }

          if (target.classList.contains('manage-images')) {
            e.stopPropagation();
            openImageModal(target.dataset.id);
          }

          if (target.classList.contains('change-status')) {
            e.stopPropagation();
            const tripId = target.dataset.id;
            const currentStatus = target.dataset.active === 'true';
            const newStatus = !currentStatus;
            fetch('/admin/changeTripStatus', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': '<%= csrfToken %>'
              },
              body: JSON.stringify({ tripId, isActive: newStatus })
            })
              .then(response => response.json())
              .then(result => {
                if (result.success) {
                  target.textContent = newStatus ? 'Disable' : 'Enable';
                  target.dataset.active = newStatus;
                  card.classList.toggle('inactive', !newStatus);
                  showToast(`Trip status changed to ${newStatus ? 'Enabled' : 'Disabled'}`);
                } else {
                  showToast(`Failed to change status: ${result.message}`, 'danger');
                }
              })
              .catch(() => showToast('Error changing status.', 'danger'));
          }

          if (target.classList.contains('delete-tour')) {
            e.stopPropagation();
            if (confirm('Are you sure you want to delete this trip? This action cannot be undone.')) {
              fetch('/admin/deleteTripDetail', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  'X-CSRF-Token': '<%= csrfToken %>'
                },
                body: JSON.stringify({ tripId: target.dataset.id })
              })
                .then(response => response.json())
                .then(result => {
                  if (result.success) {
                    card.remove();
                    showToast('Trip deleted successfully');
                  } else {
                    showToast(`Failed to delete trip: ${result.message}`, 'danger');
                  }
                })
                .catch(() => showToast('Error deleting trip.', 'danger'));
            }
          }
        });
      });

      // Filter drawer logic
      document.getElementById('filterButton')?.addEventListener('click', openFilterDrawer);

      // Chip removal
      document.querySelectorAll('.active-filter-chip-remove').forEach(closeBtn => {
        closeBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          const chip = closeBtn.closest('[data-chip]').dataset.chip;
          if (chip === '<%= Searchvalue %>') {
            removeSearchChip();
          } else {
            removeChip(chip);
          }
        });
      });

      // Pre-check drawer pills from active server-side filters
      const activeChips = <%- JSON.stringify(filterChips || []) %>;
      activeChips.forEach(function(chip) {
        const el = document.querySelector(`#filterDrawer input[value="${chip}"]`);
        if (el) el.checked = true;
      });
      updateFilterBadge();

      // Region filter handled via setRegion() on pill buttons

      // Search input with debounce
      document.getElementById('searchEntry')?.addEventListener('keypress', debounce((e) => {
        if (e.key === 'Enter') {
          document.getElementById('searchValue').value = e.target.value;
          updateFilterValue();
          submitTourList();
        }
      }, 300));

      // Quick call form logic
      document.getElementById('guestName')?.addEventListener('input', validateQuickCallForm);
      document.getElementById('mobileNo')?.addEventListener('input', validateQuickCallForm);
      document.getElementById('submitQuickCall')?.addEventListener('click', submitQuickCall);

      // ── Image management wiring ──
      const mainImageInput = document.getElementById('mainImageInput');

      // Replace button opens file picker
      document.getElementById('mainImageReplaceBtn')?.addEventListener('click', () => mainImageInput?.click());
      // Preview button on main image card
      document.getElementById('mainImagePreviewBtn')?.addEventListener('click', () => {
        const src  = document.getElementById('mainImagePreviewImg')?.src;
        const meta = document.getElementById('mainImageMeta')?.textContent || '';
        if (src) imOpenLightbox(src, meta);
      });
      // Crop-again button on main image card (shown after first crop/skip)
      document.getElementById('mainImageCropBtn')?.addEventListener('click', () => {
        const file = mainImageInput?.files[0];
        if (file) _tlStartMainCrop(file);
      });

      mainImageInput?.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (!file) return;
        if (!file.type.startsWith('image/')) {
          showToast('Please upload a valid image file.', 'danger');
          mainImageInput.value = '';
          return;
        }
        if (file.size > 5 * 1024 * 1024) {
          showToast('Main image must be under 5 MB.', 'danger');
          mainImageInput.value = '';
          return;
        }
        _tlStartMainCrop(file);
      });

      // Add banner images button opens file picker
      document.getElementById('bannerImagesAddBtn')?.addEventListener('click', () =>
        document.getElementById('bannerImagesInput')?.click()
      );
      document.getElementById('bannerImagesInput')?.addEventListener('change', (e) => {
        if (e.target.files.length > 0) _tlStartBannerQueue(Array.from(e.target.files));
      });

      document.getElementById('saveImages')?.addEventListener('click', saveImages);

      // ── Crop modal controls ──
      document.getElementById('tlCropConfirmBtn')?.addEventListener('click', _tlCropConfirm);
      document.getElementById('tlCropSkipBtn')?.addEventListener('click', _tlCropSkip);
      document.getElementById('tlCropCancelBtn')?.addEventListener('click', _tlCropSkip);
      document.getElementById('tlCropRatio')?.addEventListener('change', _tlOnRatioChange);
      document.getElementById('tlCropFullscreenBtn')?.addEventListener('click', _tlToggleFullscreen);

      // Destroy cropper + reset fullscreen when modal hides (escape / close btn)
      document.getElementById('tlCropModal')?.addEventListener('hidden.bs.modal', () => {
        if (_tlCropper) { _tlCropper.destroy(); _tlCropper = null; }
        document.querySelectorAll('.tl-crop-backdrop').forEach(bd => bd.classList.remove('tl-crop-backdrop'));
        // Reset fullscreen state
        if (_tlIsFullscreen) {
          _tlIsFullscreen = false;
          document.getElementById('tlCropModal').classList.remove('tl-fullscreen');
          const icon = document.getElementById('tlCropFullscreenIcon');
          if (icon) icon.className = 'bi bi-fullscreen';
        }
      });
    });
  </script>
</body>

</html>