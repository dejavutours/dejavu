<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/headtag', {isNiceSelect: true}); %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css">
  <style>
    /* Defining CSS variables for consistent theming */
    :root {
      --primary-blue: #1a4b8e;
      --light-gray: #f8f9fa;
      --shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
      --transition: 0.3s ease;
      --error-red: #dc3545;
      --premium-gold: #FFD700;
      --dark-gray: #333333;
    }

    /* Search bar */
    .search-container { margin-top:18px; }
    .search-bar { flex:1; min-width:0; }
    /* Mobile search input shrink */
    @media (max-width:480px) {
      .search-input { font-size:0.78rem; padding:10px 8px 10px 32px; }
      .search-icon { left:10px; }
    }

    /* Search bar styling */
    .search-container .search-bar {
      display: flex;
      flex-grow: 1;
      max-width: 800px;
      border: 1px solid #e0e0e0;
      border-radius: 8px;
      background-color: white;
      box-shadow: var(--shadow);
    }

    .search-container .select-wrapper {
      min-width: 70px;
      border-right: 1px solid #e0e0e0;
      position: relative;
    }

    .search-container .select {
      width: 100%;
      padding: 12px 30px 12px 15px;
      border: none;
      font-size: 0.9rem;
      cursor: pointer;
      color: var(--dark-gray);
      background-color: white;
    }

    .search-container .select-wrapper::after {
      content: "▼";
      font-size: 10px;
      color: #888;
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
    }

    .search-container .input-wrapper {
      flex-grow: 1;
      display: flex;
      align-items: center;
      position: relative;
    }

    .search-container .search-icon {
      position: absolute;
      left: 15px;
      width: 16px;
      height: 16px;
      color: #9e9e9e;
    }

    .search-container .search-input {
      width: 100%;
      padding: 12px 15px 12px 40px;
      border: none;
      font-size: 0.9rem;
      outline: none;
      color: var(--dark-gray);
    }

    .search-container .search-input::placeholder {
      color: #9e9e9e;
    }

    /* Filters button */
    .filters-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      --bs-btn-font-size: 0.85rem;
      --bs-btn-padding-x: 16px;
      --bs-btn-padding-y: 10px;
      --bs-btn-bg: #fff;
      --bs-btn-border-color: #d1d5db;
      --bs-btn-hover-bg: var(--primary-blue);
      --bs-btn-hover-border-color: var(--primary-blue);
      --bs-btn-hover-color: #fff;
      border-radius: 10px;
      font-weight: 600;
      color: #374151;
    }
    @media (max-width:576px) {
      .filters-btn { --bs-btn-padding-x:12px; --bs-btn-padding-y:9px; }
    }

    /* Package card styling */
    .package-card {
      text-decoration: none;
      color: inherit;
      box-shadow: var(--shadow);
      transition: box-shadow var(--transition), transform var(--transition);
      position: relative;
      border-radius: 8px;
    }

    .package-card:hover {
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
      transform: translateY(-4px);
    }

    .package-card.inactive {
      opacity: 0.7;
      border: 2px solid #d1d5db;
    }

    .card-image-container {
      height: 200px;
      overflow: hidden;
      margin: 0.75rem;
      border-radius: 8px;
    }

    .card-image {
      max-height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .package-card:hover .card-image {
      transform: scale(1.05);
    }

    .card-title {
      font-weight: 500;
      font-size: 1.25rem;
      color: var(--dark-gray);
    }

    /* Admin status badge */
    .status-badge {
      position: absolute;
      top: 10px;
      left: 10px;
      background-color: #28a745;
      color: white;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 0.75rem;
      font-weight: bold;
      z-index: 1;
    }

    .status-badge.inactive {
      background-color: var(--error-red);
    }

    /* Chip styling */
    .chip {
      display: inline-flex;
      align-items: center;
      padding: 6px 12px;
      margin: 4px 8px 4px 0;
      font-size: 0.85rem;
      border-radius: 16px;
      background-color: var(--light-gray);
      color: var(--dark-gray);
      border: 1px solid #d1d5db;
      cursor: pointer;
    }

    .chip .close {
      margin-left: 6px;
      font-size: 1rem;
      color: #6b7280;
    }

    .chip .close:hover {
      color: #000;
    }

    /* Quick Call Modal Styling */
    .quick-call-modal-content {
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
      border: none;
      max-width: 400px;
      margin: 0 auto;
    }

    .quick-call-modal-header {
      background: var(--primary-blue);
      background-image: url('/images/quick-call-bg.jpg');
      background-size: cover;
      background-position: center;
      position: relative;
      border-bottom: none;
      padding: 30px 20px;
      min-height: 140px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .quick-call-modal-header::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(26, 75, 142, 0.7);
    }

    .quick-call-modal-header .btn-close {
      position: absolute;
      top: 12px;
      right: 12px;
      z-index: 1;
      filter: brightness(0) invert(1);
    }

    .modal-body-content {
      position: relative;
      z-index: 1;
      text-align: center;
    }

    .quick-call-modal-header .modal-title {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 8px;
      line-height: 1.3;
      color: white;
    }

    .quick-call-modal-header p {
      font-size: 0.9rem;
      margin-bottom: 0;
      line-height: 1.4;
      color: white;
    }

    .quick-call-modal-body {
      padding: 20px 24px;
      background: #fff;
      border-bottom-left-radius: 16px;
      border-bottom-right-radius: 16px;
    }

    .quick-call-modal-body .form-label {
      font-size: 0.85rem;
      color: var(--dark-gray);
      text-align: left;
      margin-bottom: 6px;
      font-weight: 500;
    }

    .quick-call-modal-body .form-control,
    .quick-call-modal-body .form-select {
      border-radius: 8px;
      border: 1px solid #d1d5db;
      padding: 8px 12px;
      font-size: 0.9rem;
      box-shadow: none;
      transition: border-color var(--transition), box-shadow var(--transition);
    }

    .quick-call-modal-body .form-select {
      max-width: 90px;
      padding-right: 30px;
      background-size: 10px;
    }

    .quick-call-modal-body .form-control:focus,
    .quick-call-modal-body .form-select:focus {
      border-color: var(--primary-blue);
      box-shadow: 0 0 0 2px rgba(26, 75, 142, 0.2);
      outline: none;
    }

    .quick-call-modal-body .form-control.is-invalid,
    .quick-call-modal-body .form-select.is-invalid {
      border-color: var(--error-red);
    }

    .quick-call-modal-body .invalid-feedback {
      color: var(--error-red);
      font-size: 0.75rem;
      margin-top: 4px;
    }

    .quick-call-modal-body .notes {
      margin-top: 16px;
    }

    .quick-call-modal-body .note-icon {
      color: var(--primary-blue);
      margin-right: 8px;
      font-size: 1rem;
    }

    .quick-call-modal-body .notes span {
      font-size: 0.8rem;
      color: #6b7280;
    }

    .quick-call-modal-footer {
      padding: 16px 24px;
      border-top: none;
      display: flex;
      justify-content: center;
      background: #fff;
      border-bottom-left-radius: 16px;
      border-bottom-right-radius: 16px;
    }

    .quick-call-modal-btn {
      background: var(--premium-gold);
      color: var(--dark-gray);
      padding: 10px 24px;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 500;
      transition: background var(--transition), transform var(--transition);
      display: flex;
      align-items: center;
      width: 100%;
      justify-content: center;
    }

    .quick-call-modal-btn:hover {
      background: #e6c200;
      transform: translateY(-2px);
    }

    .quick-call-modal-btn:disabled {
      background: #d1d5db;
      color: #6b7280;
      cursor: not-allowed;
    }

    .quick-call-modal-btn i {
      font-size: 1rem;
    }

    /* Action buttons */
    .call-now-btn, .whatsapp-btn, .request-callback-btn {
      --bs-btn-font-size: 0.875rem;
      --bs-btn-padding-y: 0.375rem;
      --bs-btn-padding-x: 0.75rem;
      border-radius: 6px;
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    .call-now-btn {
      --bs-btn-bg: var(--primary-blue);
      --bs-btn-color: #fff;
    }

    .whatsapp-btn {
      --bs-btn-border-color: #25d366;
      --bs-btn-color: #25d366;
      --bs-btn-hover-bg: #25d366;
      --bs-btn-hover-color: #fff;
    }

    .request-callback-btn {
      --bs-btn-bg: var(--premium-gold);
      --bs-btn-color: var(--dark-gray);
      --bs-btn-hover-bg: #e6c200;
    }

    /* Admin buttons */
    .edit-tour, .manage-images, .change-status, .delete-tour {
      --bs-btn-font-size: 0.875rem;
      --bs-btn-padding-y: 0.375rem;
      --bs-btn-padding-x: 0.75rem;
    }

    /* Share button */
    /* .share-btn {
      position: absolute;
      top: 10px;
      right: 10px;
      background: rgba(255, 255, 255, 0.9);
      border-radius: 50%;
      padding: 6px;
      box-shadow: var(--shadow);
    } */

    /* Toast notification */
    .toast {
      position: fixed;
      bottom: 20px;
      right: 20px;
      z-index: 1055;
      border-radius: 8px;
    }

    /* ── Image management modal ── */
    #imageManagementModal .modal-dialog { max-width: 760px; }
    #filtersModal .modal-dialog { max-width: 800px; }

    /* Main image card */
    .im-main-card {
      border: 2px solid #e5e7eb;
      border-radius: 12px;
      overflow: hidden;
      background: #f8f9fa;
      position: relative;
    }
    .im-main-card img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      display: block;
    }
    .im-main-card.is-dirty { border-color: #ef4444; }
    .im-main-card .im-main-actions {
      position: absolute;
      top: 8px;
      right: 8px;
      display: flex;
      gap: 6px;
    }
    .im-main-card .im-meta {
      padding: 6px 10px;
      font-size: 0.72rem;
      color: #6b7280;
      background: #fff;
      border-top: 1px solid #e5e7eb;
    }

    /* Banner image thumbnails */
    .im-banner-thumb {
      position: relative;
      border: 2px solid #e5e7eb;
      border-radius: 10px;
      overflow: hidden;
      background: #f8f9fa;
      width: 160px;
      flex-shrink: 0;
      transition: border-color 0.15s;
    }
    .im-banner-thumb img {
      width: 160px;
      height: 100px;
      object-fit: cover;
      display: block;
    }
    .im-banner-thumb.is-dirty { border-color: #ef4444; }
    .im-banner-thumb.is-saved { border-color: #d1d5db; }
    .im-banner-thumb .im-thumb-actions {
      position: absolute;
      top: 5px;
      right: 5px;
      display: flex;
      gap: 4px;
    }
    .im-banner-thumb .im-thumb-meta {
      padding: 3px 6px;
      font-size: 0.65rem;
      color: #6b7280;
      background: rgba(255,255,255,0.95);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 156px;
    }
    .im-banner-thumb .im-pending-badge {
      position: absolute;
      top: 5px;
      left: 5px;
      background: #f59e0b;
      color: #fff;
      font-size: 0.58rem;
      font-weight: 700;
      padding: 2px 5px;
      border-radius: 4px;
      text-transform: uppercase;
    }

    /* ── Image preview lightbox ── */
    #imPreviewLightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.88);
      z-index: 1200;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      padding: 16px;
    }
    #imPreviewLightbox.open { display: flex; }
    #imPreviewLightbox img {
      max-width: min(96vw, 1200px);
      max-height: calc(100vh - 100px);
      object-fit: contain;
      border-radius: 8px;
      box-shadow: 0 8px 48px rgba(0,0,0,0.6);
      display: block;
    }
    #imPreviewLightboxMeta {
      margin-top: 12px;
      color: rgba(255,255,255,0.75);
      font-size: 0.8rem;
      text-align: center;
    }
    #imPreviewLightboxClose {
      position: fixed;
      top: 14px;
      right: 18px;
      background: rgba(255,255,255,0.12);
      border: none;
      color: #fff;
      font-size: 1.3rem;
      width: 38px;
      height: 38px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background 0.15s;
    }
    #imPreviewLightboxClose:hover { background: rgba(255,255,255,0.22); }

    /* Preview (eye) button on main card */
    .im-preview-btn {
      background: rgba(0,0,0,0.45);
      border: none;
      color: #fff;
      border-radius: 6px;
      width: 30px;
      height: 30px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 0.85rem;
      transition: background 0.15s;
      flex-shrink: 0;
    }
    .im-preview-btn:hover { background: rgba(0,0,0,0.7); }

    /* Dirty save button */
    #saveImages.is-dirty {
      background: #ef4444;
      border-color: #ef4444;
      animation: im-pulse 1.4s ease-in-out infinite;
    }
    @keyframes im-pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.5); }
      50%       { box-shadow: 0 0 0 6px rgba(239,68,68,0); }
    }

    @media (max-width:576px) {
      .im-banner-thumb { width: 130px; }
      .im-banner-thumb img { width: 130px; height: 82px; }
      .im-main-card img { height: 160px; }
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
      .card-image-container {
        height: 150px;
      }

      .card-title {
        font-size: 1.1rem;
      }
    }

    @media (max-width: 576px) {
      .search-container .search-bar {
        max-width: 100%;
      }

      .quick-call-modal-content {
        max-width: 100%;
        margin: 10px;
      }

      .quick-call-modal-header {
        min-height: 120px;
        padding: 20px 16px;
      }

      .quick-call-modal-header .modal-title {
        font-size: 1.1rem;
      }

      .quick-call-modal-header p {
        font-size: 0.85rem;
      }

      .quick-call-modal-header .btn-close {
        top: 10px;
        right: 10px;
      }

      .quick-call-modal-body {
        padding: 16px 20px;
      }

      .quick-call-modal-body .form-label {
        font-size: 0.8rem;
      }

      .quick-call-modal-body .form-control,
      .quick-call-modal-body .form-select {
        font-size: 0.85rem;
        padding: 6px 10px;
      }

      .quick-call-modal-body .form-select {
        max-width: 80px;
      }

      .quick-call-modal-body .invalid-feedback {
        font-size: 0.7rem;
      }

      .quick-call-modal-body .notes .note-icon {
        font-size: 0.9rem;
        margin-right: 6px;
      }

      .quick-call-modal-body .notes span {
        font-size: 0.75rem;
      }

      .quick-call-modal-footer {
        padding: 12px 20px;
      }

      .quick-call-modal-btn {
        font-size: 0.85rem;
        padding: 8px 20px;
      }

      .call-now-btn, .whatsapp-btn, .request-callback-btn {
        --bs-btn-font-size: 0.75rem;
        --bs-btn-padding-y: 0.25rem;
        --bs-btn-padding-x: 0.5rem;
      }

      #imageManagementModal .modal-dialog,
      #filtersModal .modal-dialog {
        max-width: 100%;
        margin: 0.5rem;
      }

    }

    @media (max-width: 400px) {
      .quick-call-modal-header {
        min-height: 110px;
        padding: 16px 12px;
      }

      .quick-call-modal-header .modal-title {
        font-size: 1rem;
      }

      .quick-call-modal-header p {
        font-size: 0.8rem;
      }

      .quick-call-modal-body {
        padding: 12px 16px;
      }

      .quick-call-modal-body .form-label {
        font-size: 0.75rem;
      }

      .quick-call-modal-body .form-control,
      .quick-call-modal-body .form-select {
        font-size: 0.8rem;
        padding: 6px 8px;
      }

      .quick-call-modal-body .form-select {
        max-width: 70px;
      }

      .quick-call-modal-body .invalid-feedback {
        font-size: 0.65rem;
      }

      .quick-call-modal-body .notes .note-icon {
        font-size: 0.85rem;
        margin-right: 5px;
      }

      .quick-call-modal-body .notes span {
        font-size: 0.7rem;
      }

      .quick-call-modal-footer {
        padding: 10px 16px;
      }

      .quick-call-modal-btn {
        font-size: 0.8rem;
        padding: 8px 16px;
      }
    }

    /* ── Banner crop pending preview ── */
    .banner-pending-preview { border: 2px solid #FFD700; border-radius: 8px; position: relative; }
    .banner-pending-badge { position: absolute; top: 4px; left: 4px; background: #FFD700; color: #333; font-size: 0.6rem; font-weight: 700; padding: 2px 6px; border-radius: 4px; line-height: 1.4; }

    /* ── Crop modal — sits above imageManagementModal (Bootstrap ~1055) ── */
    #tlCropModal { z-index: 1100; }
    .tl-crop-backdrop { z-index: 1099 !important; }

    /* Default: tall modal, flex column so container fills space */
    #tlCropModal .modal-dialog {
      max-width: 820px;
      height: calc(100vh - 56px);
      max-height: 780px;
      margin: 28px auto;
      display: flex;
      flex-direction: column;
    }
    #tlCropModal .modal-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    #tlCropModal .modal-header { flex-shrink: 0; padding: 10px 16px; min-height: 0; }
    #tlCropModal .modal-body   { flex: 1; padding: 0; display: flex; flex-direction: column; overflow: hidden; }
    #tlCropModal .modal-footer { flex-shrink: 0; padding: 8px 16px; }

    /* Crop container fills all available space in the modal body */
    #tlCropContainer {
      flex: 1;
      min-height: 0;
      overflow: hidden;
      background: #111;
      position: relative;
    }
    #tlCropContainer img { display: block; max-width: 100%; }

    /* ── Fullscreen mode ── */
    #tlCropModal.tl-fullscreen {
      padding: 0 !important;
    }
    #tlCropModal.tl-fullscreen .modal-dialog {
      width: 100vw;
      max-width: 100vw;
      height: 100vh;
      max-height: 100vh;
      margin: 0;
      border-radius: 0;
    }
    #tlCropModal.tl-fullscreen .modal-content {
      border-radius: 0;
    }

    /* Header inline controls */
    .tl-crop-header-controls {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-left: auto;
      margin-right: 8px;
    }

    /* Ratio selector — native, not nice-select */
    #tlCropRatio {
      -webkit-appearance: auto !important;
      -moz-appearance: auto !important;
      appearance: auto !important;
      display: inline-block !important;
      width: auto !important;
      padding: 4px 8px;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      font-size: 0.8rem;
      background: #fff !important;
      cursor: pointer;
      height: 32px;
    }
    /* Kill any nice-select wrapper Bootstrap picks up inside the crop modal */
    #tlCropModal .nice-select { display: none !important; }

    /* Fullscreen toggle button */
    #tlCropFullscreenBtn {
      background: none;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      width: 32px;
      height: 32px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: #374151;
      font-size: 0.85rem;
      flex-shrink: 0;
    }
    #tlCropFullscreenBtn:hover { background: #f3f4f6; }

    /* ── Filter count badge ── */
    .filter-count-badge { display:inline-flex; align-items:center; justify-content:center; width:18px; height:18px; border-radius:50%; background:#EF4F5F; color:#fff; font-size:0.65rem; font-weight:700; margin-left:4px; }

    /* ── Active filter bar ── */
    .active-filter-bar { display:flex; flex-wrap:wrap; align-items:center; gap:8px; padding:10px 0 2px; }
    .active-filter-label { font-size:0.78rem; font-weight:600; color:#6b7280; white-space:nowrap; }
    .active-filter-chip { display:inline-flex; align-items:center; gap:6px; background:#eef2f8; border:1px solid #c7d7ef; color:#1A3C6C; font-size:0.78rem; font-weight:600; padding:4px 10px 4px 12px; border-radius:50px; }
    .active-filter-chip-remove { background:none; border:none; color:#1A3C6C; font-size:0.7rem; cursor:pointer; padding:0; line-height:1; opacity:0.7; }
    .active-filter-chip-remove:hover { opacity:1; }
    .active-filter-chip.search-chip { background:#fef3f2; border-color:#fecaca; color:#b91c1c; }
    .active-filter-chip.search-chip .active-filter-chip-remove { color:#b91c1c; }
    .active-filter-clear-all { font-size:0.78rem; font-weight:600; color:#EF4F5F; text-decoration:none; margin-left:4px; white-space:nowrap; }
    .active-filter-clear-all:hover { text-decoration:underline; }

    /* ── Region pill tabs ── */
    .region-pill-tabs { display:flex; gap:5px; align-items:center; padding:4px 6px; flex-shrink:0; }
    .region-pill { padding:6px 14px; border-radius:50px; border:1.5px solid #d1d5db; background:#fff; color:#374151; font-size:0.78rem; font-weight:600; cursor:pointer; transition:all 0.15s; white-space:nowrap; }
    .region-pill.active { background:#1A3C6C; color:#fff; border-color:#1A3C6C; }
    .region-pill:hover:not(.active) { background:#f3f4f6; }
    @media (max-width:480px) {
      .region-pill { padding:5px 10px; font-size:0.72rem; }
    }

    /* ── Filter drawer ── */
    .filter-drawer-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:1040; }
    .filter-drawer-overlay.open { display:block; }
    .filter-drawer { position:fixed; top:0; right:0; height:100%; width:380px; max-width:95vw; background:#fff; z-index:1050; transform:translateX(100%); transition:transform 0.28s cubic-bezier(0.32,0.72,0,1); display:flex; flex-direction:column; box-shadow:-4px 0 24px rgba(0,0,0,0.12); }
    .filter-drawer.open { transform:translateX(0); }
    .filter-drawer-head { padding:18px 20px; border-bottom:1px solid #e5e7eb; display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
    .filter-drawer-head h5 { font-size:1rem; font-weight:700; color:#111; margin:0; }
    .filter-drawer-body { padding:20px; overflow-y:auto; flex:1; }
    .filter-section-label { font-size:0.7rem; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:10px; margin-top:20px; display:block; }
    .filter-pill-group { display:flex; flex-wrap:wrap; gap:8px; }
    .filter-pill input[type=checkbox] { display:none; }
    .filter-pill label { padding:5px 14px; border-radius:50px; border:1.5px solid #d1d5db; background:#fff; color:#374151; font-size:0.8rem; font-weight:500; cursor:pointer; transition:all 0.15s; display:inline-block; }
    .filter-pill input[type=checkbox]:checked + label { background:#1A3C6C; color:#fff; border-color:#1A3C6C; }
    .filter-drawer-foot { padding:14px 20px; border-top:1px solid #e5e7eb; display:flex; gap:10px; flex-shrink:0; }
    .filter-drawer-foot .btn-clear { flex:1; padding:10px; border-radius:10px; border:1.5px solid #d1d5db; background:#fff; color:#374151; font-weight:600; font-size:0.88rem; cursor:pointer; }
    .filter-drawer-foot .btn-apply { flex:2; padding:10px; border-radius:10px; background:#1A3C6C; color:#fff; font-weight:600; font-size:0.88rem; border:none; cursor:pointer; }
    .filter-drawer-foot .btn-apply:hover { background:#0f2647; }

    /* ── Trip cards ── */
    .trip-card { border-radius:16px; overflow:hidden; border:none; box-shadow:0 2px 16px rgba(0,0,0,0.07); transition:transform 0.2s ease, box-shadow 0.2s ease; background:#fff; cursor:pointer; position:relative; display:flex; flex-direction:column; }
    .trip-card:hover { transform:translateY(-6px); box-shadow:0 16px 40px rgba(0,0,0,0.14); }
    .trip-card.inactive { opacity:0.65; }

    /* Image */
    .trip-card-img-wrap { position:relative; height:220px; overflow:hidden; flex-shrink:0; }
    .trip-card-img-wrap img { width:100%; height:100%; object-fit:cover; transition:transform 0.5s ease; display:block; }
    .trip-card:hover .trip-card-img-wrap img { transform:scale(1.08); }
    .trip-card-img-overlay { position:absolute; inset:0; background:linear-gradient(160deg, rgba(0,0,0,0) 40%, rgba(0,0,0,0.55) 100%); }

    /* State badge — bottom left over image */
    .trip-card-state-badge { position:absolute; bottom:10px; left:12px; background:rgba(255,255,255,0.15); backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.35); color:#fff; font-size:0.68rem; font-weight:700; padding:3px 10px; border-radius:50px; letter-spacing:0.03em; }

    /* Trending / popular badge — top right */
    .trip-card-trending { position:absolute; top:10px; right:10px; background:linear-gradient(135deg,#FF6B35,#FF4500); color:#fff; font-size:0.62rem; font-weight:700; padding:3px 9px; border-radius:50px; letter-spacing:0.05em; text-transform:uppercase; }

    /* Card body */
    .trip-card-body { padding:16px 16px 14px; display:flex; flex-direction:column; flex:1; }
    .trip-card-name { font-size:1rem; font-weight:700; color:#0d1b2a; margin-bottom:2px; line-height:1.35; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .trip-card-dest { font-size:0.75rem; color:#8a94a6; margin-bottom:12px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; display:flex; align-items:center; gap:4px; }

    /* Duration + price row */
    .trip-card-meta { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; gap:8px; }
    .trip-card-duration { display:inline-flex; align-items:center; gap:5px; font-size:0.72rem; color:#374151; background:#f0f4ff; border-radius:50px; padding:4px 11px; font-weight:600; border:1px solid #dde5ff; }

    /* Price — the conversion hero */
    .trip-card-price-wrap { display:flex; flex-direction:column; align-items:flex-end; flex-shrink:0; }
    .trip-card-price-label { font-size:0.58rem; color:#8a94a6; font-weight:600; text-transform:uppercase; letter-spacing:0.07em; line-height:1; margin-bottom:2px; }
    .trip-card-price { font-size:1.15rem; font-weight:800; color:#EF4F5F; line-height:1; }
    .trip-card-price small { font-size:0.6rem; font-weight:500; color:#8a94a6; }

    /* Actions */
    .trip-card-actions { display:flex; gap:8px; align-items:stretch; margin-top:auto; }
    .trip-card-view-btn {
      flex:1; padding:11px 0; border-radius:10px;
      background:#1A3C6C; color:#fff;
      font-size:0.85rem; font-weight:700; border:none; cursor:pointer;
      text-align:center; letter-spacing:0.04em;
      display:flex; align-items:center; justify-content:center; gap:6px;
      transition:background 0.18s;
    }
    .trip-card-view-btn::after { content:'→'; font-size:1rem; font-weight:400; }
    .trip-card-view-btn:hover { background:#0f2749; }
    .trip-card-wa-btn, .trip-card-call-btn, .trip-card-share-btn { width:42px; border-radius:10px; background:#f4f6f9; border:1.5px solid #e2e6ed; color:#4b5563; display:flex; align-items:center; justify-content:center; font-size:0.92rem; flex-shrink:0; text-decoration:none; cursor:pointer; transition:background 0.15s, border-color 0.15s; }
    .trip-card-wa-btn:hover, .trip-card-call-btn:hover, .trip-card-share-btn:hover { background:#e8ecf2; border-color:#cbd2db; color:#1A3C6C; }

    /* ── Share popover ── */
    .share-popover-backdrop { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.28); z-index:1060; }
    .share-popover-backdrop.open { display:block; }
    .share-popover {
      display:none; position:fixed; z-index:1061;
      background:#fff; border-radius:20px;
      box-shadow:0 16px 56px rgba(0,0,0,0.18), 0 2px 8px rgba(0,0,0,0.06);
      padding:22px 22px 18px;
      width:340px; max-width:calc(100vw - 32px);
    }
    .share-popover.open { display:block; }
    .share-popover-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
    .share-popover-title { font-size:1rem; font-weight:700; color:#111; margin:0; }
    .share-popover-close { background:none; border:none; width:28px; height:28px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.9rem; color:#6b7280; cursor:pointer; transition:background 0.15s; flex-shrink:0; }
    .share-popover-close:hover { background:#f3f4f6; color:#111; }

    /* Trip preview card — matches reference: image left, name+subtitle right, border */
    .share-popover-trip { display:flex; align-items:center; gap:14px; border:1px solid #e5e7eb; border-radius:14px; padding:12px 14px; margin-bottom:18px; }
    .share-popover-trip-img { width:52px; height:52px; border-radius:10px; object-fit:cover; flex-shrink:0; background:#e5e7eb; }
    .share-popover-trip-info { flex:1; min-width:0; }
    .share-popover-trip-name { font-size:0.92rem; font-weight:700; color:#111; margin:0 0 2px; line-height:1.3; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .share-popover-trip-sub { font-size:0.75rem; color:#6b7280; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

    /* Action row — two equal columns, text+icon, no coloured backgrounds */
    .share-popover-actions { display:grid; grid-template-columns:1fr 1fr; gap:0; border:1px solid #e5e7eb; border-radius:12px; overflow:hidden; }
    .share-popover-btn { display:flex; align-items:center; justify-content:center; gap:8px; padding:13px 0; background:#fff; color:#222; font-size:0.82rem; font-weight:600; cursor:pointer; border:none; transition:background 0.15s; }
    .share-popover-btn:first-child { border-right:1px solid #e5e7eb; }
    .share-popover-btn:hover { background:#f7f8fa; }
    .share-popover-btn i { font-size:1rem; color:#555; }
    .share-popover-copied { font-size:0.72rem; color:#16a34a; text-align:center; margin-top:10px; height:14px; font-weight:500; }

    /* Page section header */
    .page-hero-label { font-size:0.72rem; font-weight:700; color:#EF4F5F; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:6px; }
    .page-hero-title { font-size:1.85rem; font-weight:800; color:#0d1b2a; line-height:1.2; margin-bottom:0; }

    /* Mobile responsive card tightening */
    @media (max-width:576px) {
      .page-hero-title { font-size:1.4rem; }
      .trip-card-img-wrap { height:190px; }
      .trip-card-body { padding:12px 13px 13px; }
      .trip-card-name { font-size:0.92rem; }
      .trip-card-dest { font-size:0.72rem; margin-bottom:10px; }
      .trip-card-meta { margin-bottom:12px; }
      .trip-card-price { font-size:1rem; }
      .trip-card-view-btn { font-size:0.8rem; padding:10px 0; }
      .trip-card-wa-btn, .trip-card-call-btn, .trip-card-share-btn { width:36px; font-size:0.88rem; }
    }
  </style>
</head>

<body>
  <%- include('../partials/header', {isSearch: false}); %>
  <!-- Main header -->
  <header class="container-xl py-3 pt-4">
    <p class="page-hero-label">Our curated tour packages</p>
    <h1 class="page-hero-title">Where are you planning to go next?</h1>
    <div class="search-container d-flex align-items-center gap-2 pt-3">
      <div class="search-bar d-flex align-items-center flex-1" style="flex:1;min-width:0;border:1px solid #e0e0e0;border-radius:10px;background:#fff;box-shadow:0 2px 8px rgba(0,0,0,0.06);overflow:hidden;">
        <div class="region-pill-tabs">
          <button type="button" class="region-pill <%= (!regionFilter || regionFilter === 'ALL') ? 'active' : '' %>" onclick="setRegion('ALL')">All</button>
          <button type="button" class="region-pill <%= regionFilter === 'India' ? 'active' : '' %>" onclick="setRegion('India')">India</button>
          <button type="button" class="region-pill <%= regionFilter === 'International' ? 'active' : '' %>" onclick="setRegion('International')">International</button>
        </div>
        <div class="input-wrapper" style="flex:1;min-width:0;display:flex;align-items:center;position:relative;">
          <i class="bi bi-search search-icon"></i>
          <input id="searchEntry" type="text" class="search-input" placeholder="Search destinations, trips..." aria-label="Search tours" value="<%= Searchvalue || '' %>">
        </div>
      </div>
      <button class="btn filters-btn flex-shrink-0" id="filterButton" aria-label="Open filters">
        <i class="bi bi-sliders2-vertical"></i> <span class="d-none d-sm-inline">Filters</span>
        <span id="filterCountBadge" class="filter-count-badge" style="display:<%= filterChips && filterChips.length > 0 ? 'inline-flex' : 'none' %>;"><%= filterChips ? filterChips.length : 0 %></span>
      </button>
    </div>
    <!-- Active filter bar -->
    <% if ((filterChips && filterChips.length > 0) || Searchvalue) { %>
    <div class="active-filter-bar mt-3" id="chipContainer">
      <span class="active-filter-label">Active filters:</span>
      <% filterChips.forEach(function(chip) { %>
      <span class="active-filter-chip" data-chip="<%= chip %>">
        <%= chip.charAt(0).toUpperCase() + chip.slice(1) %>
        <button type="button" class="active-filter-chip-remove close" aria-label="Remove filter">&#x2715;</button>
      </span>
      <% }); %>
      <% if (Searchvalue) { %>
      <span class="active-filter-chip search-chip" data-chip="<%= Searchvalue %>">
        <i class="bi bi-search" style="font-size:0.7rem;"></i> <%= Searchvalue %>
        <button type="button" class="active-filter-chip-remove close" aria-label="Remove search">&#x2715;</button>
      </span>
      <% } %>
      <a href="/triplist" class="active-filter-clear-all">Clear all</a>
    </div>
    <% } %>
  </header>

  <!-- Main content -->
  <main class="container-xl">
    <%
      const isAdmin = (profile?.email === process.env.GMAIL_ADMIN) || (profile?.email === process.env.GMAIL_ADMIN_TWO);
      let displayedPackages = isAdmin ? tourPackages : tourPackages.filter(tour => tour.isActive);
    %>
    <p class="mb-3" style="font-size:0.8rem;color:#8a94a6;font-weight:500;">
      <span style="color:#0d1b2a;font-weight:700;"><%= displayedPackages.length %></span> trips found
      <% if (regionFilter && regionFilter !== 'ALL') { %> in <span style="color:#1A3C6C;font-weight:700;"><%= regionFilter %></span><% } %>
    </p>
    <div class="row g-3">
      <% displayedPackages.forEach(function(tour) { %>
      <article class="col-sm-6 col-lg-4 mb-2">
        <div class="trip-card package-card <%= !tour.isActive ? 'inactive' : '' %>"
             data-trip-name="<%= tour.name %>"
             data-trip-id="<%= tour._id %>"
             role="button"
             aria-label="View details for <%= tour.name %>">
          <!-- Admin status badge -->
          <% if (isAdmin) { %>
          <span class="status-badge <%= !tour.isActive ? 'inactive' : '' %>">
            <%= tour.isActive ? 'Published' : 'Draft' %>
          </span>
          <% } %>
          <div class="trip-card-img-wrap">
            <img src="<%= tour.imageurl %>"
                 alt="<%= tour.name %>"
                 loading="lazy"
                 onerror="this.src='/images/placeholder.jpg';">
            <div class="trip-card-img-overlay"></div>
            <% if (tour.state) { %>
            <span class="trip-card-state-badge"><i class="bi bi-geo-alt-fill me-1"></i><%= tour.state %></span>
            <% } %>
            <% if (tour.category && ['adventure','trekking','safari','offbeat','himalaya'].some(c => (tour.category||'').toLowerCase().includes(c))) { %>
            <span class="trip-card-trending">&#9733; Popular</span>
            <% } %>
          </div>
          <div class="trip-card-body">
            <div class="trip-card-name"><%= tour.name %></div>
            <div class="trip-card-dest"><i class="bi bi-map" style="font-size:0.65rem;opacity:0.6;"></i><%- tour.destinations %></div>
            <div class="trip-card-meta">
              <span class="trip-card-duration"><i class="bi bi-calendar3" style="color:#4f6ef7;font-size:0.72rem;"></i> <%- tour.days %></span>
              <div class="trip-card-price-wrap">
                <span class="trip-card-price-label">Starting from</span>
                <span class="trip-card-price">₹<%- tour.price %><small>/person</small></span>
              </div>
            </div>
            <% if (isAdmin) { %>
            <div class="mb-2 d-flex align-items-center gap-2 flex-wrap">
              <button class="btn btn-primary btn-sm edit-tour" data-id="<%= tour._id %>">Edit</button>
              <button class="btn btn-primary btn-sm manage-images" data-id="<%= tour._id %>">Manage Images</button>
              <button class="btn btn-warning btn-sm change-status" data-id="<%= tour._id %>" data-active="<%= tour.isActive !== false %>">
                <%= tour.isActive !== false ? 'Disable' : 'Enable' %>
              </button>
              <button class="btn btn-danger btn-sm delete-tour" data-id="<%= tour._id %>">Delete</button>
            </div>
            <% } %>
            <div class="trip-card-actions">
              <button class="trip-card-view-btn" data-action="view">View Trip</button>
              <a class="trip-card-wa-btn whatsapp-btn"
                 href="https://wa.me/+918511117891?text=Hello%20I%20am%20interested%20in%20the%20trip%20*<%= encodeURIComponent(tour.name) %>*%20tour.%20Could%20you%20please%20share%20more%20details."
                 target="_blank"
                 title="WhatsApp"
                 aria-label="WhatsApp for <%= tour.name %>">
                <i class="bi bi-whatsapp"></i>
              </a>
              <button class="trip-card-call-btn request-callback-btn"
                      data-bs-toggle="modal"
                      data-bs-target="#quickCallModal"
                      data-trip-id="<%= tour._id %>"
                      title="Request Call"
                      aria-label="Request call for <%= tour.name %>">
                <i class="bi bi-telephone-fill"></i>
              </button>
              <button class="trip-card-share-btn"
                      data-action="share"
                      data-trip-name="<%= tour.name %>"
                      data-trip-img="<%= tour.imageurl %>"
                      data-trip-dest="<%= tour.state || '' %>"
                      title="Share"
                      aria-label="Share <%= tour.name %>">
                <i class="bi bi-share-fill"></i>
              </button>
            </div>
          </div>
        </div>
      </article>
      <% }); %>
    </div>
  </main>

  <!-- Share popover (single instance, positioned by JS) -->
  <div class="share-popover-backdrop" id="shareBackdrop" onclick="closeSharePopover()"></div>
  <div class="share-popover" id="sharePopover" role="dialog" aria-modal="true" aria-label="Share trip">
    <div class="share-popover-header">
      <p class="share-popover-title">Share this Page</p>
      <button type="button" class="share-popover-close" onclick="closeSharePopover()" aria-label="Close">&#x2715;</button>
    </div>
    <div class="share-popover-trip">
      <img class="share-popover-trip-img" id="sharePopoverImg" src="" alt="">
      <div class="share-popover-trip-info">
        <p class="share-popover-trip-name" id="sharePopoverName"></p>
        <p class="share-popover-trip-sub" id="sharePopoverSub"></p>
      </div>
    </div>
    <div class="share-popover-actions">
      <button type="button" class="share-popover-btn" id="shareCopyBtn" onclick="shareCopyLink()">
        <i class="bi bi-link-45deg"></i> Copy Link
      </button>
      <button type="button" class="share-popover-btn" id="shareWaBtn" onclick="shareViaWhatsApp()">
        <i class="bi bi-whatsapp"></i> Whatsapp
      </button>
    </div>
    <p class="share-popover-copied" id="shareCopiedMsg"></p>
  </div>

  <!-- Hidden form inputs for filter submission (keep existing form logic) -->
  <form id="tourList" action="/triplist" method="GET" style="display:none;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input id="filterValue" name="filterValue" type="hidden">
    <input id="searchValue" name="searchValue" type="hidden">
    <input id="regionFilterInput" name="regionFilter" type="hidden" value="<%= regionFilter || 'ALL' %>">
  </form>

  <!-- Filter Drawer -->
  <div class="filter-drawer-overlay" id="filterOverlay" onclick="closeFilterDrawer()"></div>
  <div class="filter-drawer" id="filterDrawer">
    <div class="filter-drawer-head">
      <h5>Filters</h5>
      <div style="display:flex;align-items:center;gap:16px;">
        <button type="button" style="background:none;border:none;color:#EF4F5F;font-size:0.82rem;font-weight:600;cursor:pointer;" onclick="clearFilters()">Clear all</button>
        <button type="button" style="background:none;border:none;font-size:1.1rem;cursor:pointer;color:#6b7280;" onclick="closeFilterDrawer()">&#x2715;</button>
      </div>
    </div>
    <div class="filter-drawer-body">
      <p class="filter-section-label" style="margin-top:0;">Tour Category</p>
      <div class="filter-pill-group">
        <% ['adventure','heritage','wildlife','safari','trekking','camping','sightseeing','offbeat','backpacking','spiritual','summer','leisure','himalaya','festival','winter','monsoon'].forEach(function(cat){ %>
        <span class="filter-pill">
          <input type="checkbox" id="cat_<%= cat %>" name="category" value="<%= cat %>">
          <label for="cat_<%= cat %>"><%= cat.charAt(0).toUpperCase() + cat.slice(1) %></label>
        </span>
        <% }); %>
      </div>
      <p class="filter-section-label">Tour Type</p>
      <div class="filter-pill-group">
        <% ['family','solo','couple','bachelors','students'].forEach(function(t){ %>
        <span class="filter-pill">
          <input type="checkbox" id="type_<%= t %>" name="type" value="<%= t %>">
          <label for="type_<%= t %>"><%= t.charAt(0).toUpperCase() + t.slice(1) %></label>
        </span>
        <% }); %>
      </div>
      <p class="filter-section-label">Departure City</p>
      <div class="filter-pill-group">
        <% ['ahmedabad','mumbai','bhuj','vadodara','pune','rajkot','surat','delhi'].forEach(function(city){ %>
        <span class="filter-pill">
          <input type="checkbox" id="city_<%= city %>" name="city" value="<%= city %>">
          <label for="city_<%= city %>"><%= city.charAt(0).toUpperCase() + city.slice(1) %></label>
        </span>
        <% }); %>
      </div>
    </div>
    <div class="filter-drawer-foot">
      <button type="button" class="btn-clear" onclick="clearFilters()">Clear</button>
      <button type="button" class="btn-apply" onclick="applyFilters()">Show Trips</button>
    </div>
  </div>

  <!-- Image preview lightbox (z-index:1200, above everything) -->
  <div id="imPreviewLightbox" role="dialog" aria-modal="true" aria-label="Image preview" onclick="imCloseLightbox()">
    <button id="imPreviewLightboxClose" onclick="imCloseLightbox()" aria-label="Close preview">&#x2715;</button>
    <img id="imPreviewLightboxImg" src="" alt="Preview" onclick="event.stopPropagation()">
    <div id="imPreviewLightboxMeta"></div>
  </div>

  <!-- Unified Crop Modal (z-index:1100, sits above Manage Trip Images modal) -->
  <div class="modal fade" id="tlCropModal" tabindex="-1" aria-labelledby="tlCropModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="tlCropModalLabel">Crop Image</h5>
          <div class="tl-crop-header-controls">
            <label for="tlCropRatio" class="visually-hidden">Crop Ratio</label>
            <select id="tlCropRatio" title="Crop ratio">
              <option value="free">Free</option>
              <option value="1">1:1</option>
              <option value="1.333">4:3</option>
              <option value="1.777">16:9</option>
              <option value="0.75">3:4</option>
            </select>
            <button type="button" id="tlCropFullscreenBtn" title="Toggle fullscreen" aria-label="Toggle fullscreen">
              <i class="bi bi-fullscreen" id="tlCropFullscreenIcon"></i>
            </button>
          </div>
          <button type="button" class="btn-close ms-0" id="tlCropCancelBtn" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div id="tlCropContainer">
            <img id="tlCropImage" src="" alt="Crop preview">
          </div>
        </div>
        <div class="modal-footer">
          <span id="tlCropQueueLabel" class="me-auto text-muted small"></span>
          <button type="button" class="btn btn-outline-secondary btn-sm" id="tlCropSkipBtn">Skip</button>
          <button type="button" class="btn btn-primary btn-sm" id="tlCropConfirmBtn">Crop &amp; Save</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Image Management Modal -->
  <div class="modal fade" id="imageManagementModal" tabindex="-1" aria-labelledby="imageManagementModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="imageManagementModalLabel">Manage Trip Images</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" id="tripIdForImages">

          <!-- Main image -->
          <div class="mb-4">
            <div class="d-flex align-items-center justify-content-between mb-2">
              <h6 class="mb-0 fw-semibold">Main Image <span class="text-danger">*</span></h6>
              <button type="button" class="btn btn-sm btn-outline-secondary" id="mainImageReplaceBtn">
                <i class="bi bi-pencil me-1"></i>Replace
              </button>
            </div>
            <div class="im-main-card" id="mainImageCard">
              <img id="mainImagePreviewImg" src="" alt="Main Image">
              <div class="im-main-actions">
                <button type="button" class="im-preview-btn" id="mainImagePreviewBtn" title="Preview full size">
                  <i class="bi bi-eye"></i>
                </button>
                <button type="button" class="btn btn-sm btn-warning" id="mainImageCropBtn" style="display:none;" title="Crop this image">
                  <i class="bi bi-crop"></i>
                </button>
              </div>
              <div class="im-meta" id="mainImageMeta">Saved image</div>
            </div>
            <input type="file" id="mainImageInput" accept="image/*" class="d-none" aria-label="Upload main image">
            <small class="text-muted d-block mt-1">Required. Max 5 MB. Click Replace to change.</small>
          </div>

          <!-- Banner images -->
          <div>
            <div class="d-flex align-items-center justify-content-between mb-2">
              <h6 class="mb-0 fw-semibold">Banner Images <span class="text-muted fw-normal">(Optional)</span></h6>
              <button type="button" class="btn btn-sm btn-outline-secondary" id="bannerImagesAddBtn">
                <i class="bi bi-plus-lg me-1"></i>Add Images
              </button>
            </div>
            <div id="bannerImagesPreview" class="d-flex flex-wrap gap-2 mb-2"></div>
            <input type="file" id="bannerImagesInput" multiple accept="image/*" class="d-none" aria-label="Upload banner images">
            <small class="text-muted">Up to 12 images. Max 5 MB each.</small>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
          <button type="button" class="btn btn-primary" id="saveImages">Save Changes</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Call Modal -->
  <div class="modal fade" id="quickCallModal" tabindex="-1" aria-labelledby="quickCallModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content quick-call-modal-content">
        <div class="modal-header quick-call-modal-header">
          <div class="modal-body-content">
            <h5 class="modal-title" id="quickCallModalLabel">Plan Your Next Adventure!</h5>
            <p>Leave your details, and we'll call you back to plan your trip!</p>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body quick-call-modal-body">
          <form id="quickCallForm">
            <input type="hidden" id="tripId" name="tripId">
            <div class="mb-3">
              <label for="guestName" class="form-label">Guest Name *</label>
