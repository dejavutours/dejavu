<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../../partials/admin/admin-layout-head'); %>
  <title>Category Management — Deja-vu Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css" rel="stylesheet" />

  <style>
    #cmLoadingOverlay {
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.75);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 9999;
    }
    .form-help {
      font-size: 0.85rem;
      color: #6b7280;
      margin-top: 0.35rem;
    }
    .drag-hint {
      font-size: 0.85rem;
      color: #6b7280;
      font-weight: 500;
    }
  </style>

</head>

<body class="admin-body">
  <%- include('../../partials/admin/admin-topbar', { pageTitle: 'Category Management' }); %>
  <%- include('../../partials/admin/admin-sidebar', { activeNav: 'categories' }); %>
  <main class="admin-content">
  <div class="cm-container" style="background:transparent; padding:0; max-width:100%;">
    <!-- Loading Overlay -->
    <div id="cmLoadingOverlay" class="d-none">
      <div class="spinner-border text-primary" style="width: 3.5rem; height: 3.5rem;">
        <span class="visually-hidden">Loading...</span>
      </div>
    </div>


    <!-- Add/Edit Form -->
    <div class="mb-4">
      <div class="mc-form-header">
        <h6 class="mb-0"><i class="bi bi-tags-fill me-2"></i><span id="cmFormTitle">Add Category</span></h6>
        <div class="d-flex align-items-center gap-2">
          <button type="button" id="cmCancelBtn" class="btn btn-outline-light btn-sm d-none">Cancel</button>
          <button type="submit" form="cmCategoryForm" id="cmSubmitBtn" class="mc-submit-btn">
            <span class="submit-text">Save</span>
            <span class="spinner-border spinner-border-sm ms-2 d-none" role="status"></span>
          </button>
          <button type="button" class="mc-toggle-btn" data-bs-toggle="collapse" data-bs-target="#categoryFormCollapse">
            <i class="bi bi-chevron-down" id="toggleIcon"></i>
          </button>
        </div>
      </div>

      <div class="collapse show mc-form-body" id="categoryFormCollapse">
        <form id="cmCategoryForm" action="/categories" method="POST" enctype="multipart/form-data">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" id="cmCategoryId" name="id" />
          <input type="hidden" id="cmOldImage" name="oldImage" />

          <div class="row g-4 align-items-start">
            <!-- Category Name -->
            <div class="col-lg-5">
              <label for="cmCategoryName" class="form-label fw-semibold">Category Name <span class="text-danger">*</span></label>
              <input type="text" id="cmCategoryName" name="name" class="form-control form-control-lg" required placeholder="e.g. Adventure, Beach, Hill Station" />
            </div>

            <!-- Image Upload -->
            <div class="col-lg-4">
              <label for="cmImage" class="form-label fw-semibold">Category Image (Recommended: 400x300)</label>
              <input type="file" id="cmImage" name="image" accept="image/*" class="form-control" />
              <div class="mt-3" id="cmImagePreviewContainer" style="display: none;">
                <div class="position-relative d-inline-block">
                  <img id="cmImagePreview" src="" alt="Preview" class="img-thumbnail rounded" style="max-height: 140px;" data-bs-toggle="modal" data-bs-target="#cmPreviewModal" />
                  <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 rounded-circle" id="cmRemoveImage">
                    <i class="fas fa-times"></i>
                  </button>
                </div>
              </div>
            </div>

            <!-- Switches -->
            <div class="col-lg-3">
              <div class="mb-4">
                <label class="form-label fw-semibold">Active Status</label>
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" id="cmIsActive" name="isActive" checked>
                  <label class="form-check-label" for="cmIsActive">Active</label>
                </div>
              </div>

              <div>
                <label class="form-label fw-semibold">Show on Homepage</label>
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" id="cmIsShowOnHomePage" name="isShowOnHomePage">
                  <label class="form-check-label" for="cmIsShowOnHomePage">Visible</label>
                </div>
                <div class="form-help">
                  If enabled, this category and its trips will appear on the homepage.
                </div>
              </div>
            </div>
          </div>
        </form>
      </div>
    </div>

    <!-- Filters -->
    <div class="mc-filter-bar mb-3">
      <div class="mc-search-wrap">
        <i class="bi bi-search mc-search-icon"></i>
        <input type="text" id="cmSearchInput" class="form-control" placeholder="Search categories...">
      </div>
      <div class="mc-select-wrap">
        <select class="form-select select2" id="cmActiveFilter">
          <option value="">All Status</option>
          <option value="true">Active Only</option>
          <option value="false">Inactive Only</option>
        </select>
      </div>
      <button id="cmClearFiltersBtn" class="btn-mc-clear"><i class="bi bi-x-circle me-1"></i>Clear</button>
      <button id="cmBulkDeleteBtn" class="btn-mc-bulk-del d-none"><i class="bi bi-trash me-1"></i>Delete Selected</button>
      <span class="drag-hint ms-auto d-none d-md-inline"><i class="bi bi-arrows-move me-1"></i>Drag cards to reorder</span>
    </div>

    <!-- Categories Grid -->
    <div class="mc-card-grid" id="cmCategoryGrid"></div>

    <div class="text-end mt-3">
      <button id="cmSaveOrderBtn" class="btn btn-success d-none">
        <i class="bi bi-save me-2"></i>Save New Order
      </button>
    </div>
  </div>

  <!-- Image Preview Modal -->
  <div class="modal fade" id="cmPreviewModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title">Image Preview</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body text-center bg-light p-4">
          <img id="cmPreviewModalImg" src="" class="img-fluid rounded shadow" style="max-height: 70vh;" />
        </div>
      </div>
    </div>
  </div>

  <%- include('../../partials/footer'); %>

  <!-- Scripts -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <!-- <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script> -->
  <script src="https://cdn.jsdelivr.net/npm/select2@4.0.13/dist/js/select2.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

  <script>
    let categories = <%- JSON.stringify(categories || []) %>;
    let filteredCategories = [...categories];
    let selectedCategories = [];
    let formModified = false;
    let sortable = null;

    $(document).ready(function () {
      $(".select2").select2({ width: '100%' });

      function initSortable() {
        const el = document.getElementById('cmCategoryGrid');
        if (sortable) sortable.destroy();
        sortable = Sortable.create(el, {
          animation: 180,
          ghostClass: 'bg-light',
          onEnd: () => $('#cmSaveOrderBtn').removeClass('d-none')
        });
      }

      function renderCategories() {
        const $grid = $('#cmCategoryGrid');
        $grid.empty();

        if (filteredCategories.length === 0) {
          $grid.append(`<div class="col-12 text-center py-5"><p class="text-muted fs-4">No categories found</p></div>`);
          return;
        }

        filteredCategories.forEach(cat => {
          const card = `
            <div class="mc-card cm-card" data-id="${cat._id}">
              <input type="checkbox" class="mc-card-check cm-checkbox" data-id="${cat._id}">
              <img src="${cat.image || '/images/default-category.jpg'}" alt="${cat.name}" class="mc-card-img">
              <div class="mc-card-body">
                <div class="mc-card-name" title="${cat.name}">${cat.name}</div>
                <div class="mc-badge-row">
                  <span class="mc-badge ${cat.isActive ? 'active' : 'inactive'}">${cat.isActive ? 'Active' : 'Inactive'}</span>
                  ${cat.isShowOnHomePage ? '<span class="mc-badge home">Home</span>' : ''}
                </div>
              </div>
              <div class="mc-card-footer">
                <input type="number" class="mc-order-input cm-order-input" value="${cat.displayOrder || 0}" min="0" data-id="${cat._id}" title="Display Order">
                <button type="button" class="mc-btn-edit" onclick="editCategory('${cat._id}')"><i class="bi bi-pencil-fill"></i></button>
                <form action="/categories/delete/${cat._id}" method="POST" class="d-inline">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="mc-btn-delete"><i class="bi bi-trash-fill"></i></button>
                </form>
              </div>
            </div>`;
          $grid.append(card);
        });

        $('.cm-checkbox').on('change', function() {
          const id = $(this).data('id');
          if ($(this).is(':checked')) selectedCategories.push(id);
          else selectedCategories = selectedCategories.filter(x => x !== id);
          $('#cmBulkDeleteBtn').toggleClass('d-none', selectedCategories.length === 0);
        });

        initSortable();
      }

      window.editCategory = function(id) {
        const cat = categories.find(c => c._id === id);
        if (!cat) return;

        $('#cmCategoryId').val(id);
        $('#cmCategoryName').val(cat.name);
        $('#cmIsActive').prop('checked', !!cat.isActive);
        $('#cmIsShowOnHomePage').prop('checked', !!cat.isShowOnHomePage);

        if (cat.image) {
          $('#cmImagePreview').attr('src', cat.image);
          $('#cmPreviewModalImg').attr('src', cat.image);
          $('#cmImagePreviewContainer, #cmRemoveImage').show();
          $('#cmOldImage').val(cat.image);
        } else {
          $('#cmImagePreviewContainer, #cmRemoveImage').hide();
          $('#cmOldImage').val('');
        }

        $('#cmSubmitBtn').addClass('update').find('.submit-text').text('Update');
        $('#cmFormTitle').text('Edit Category');
        $('#cmCancelBtn').removeClass('d-none');
        formModified = true;
        $('#categoryFormCollapse').collapse('show');
      };

      $('#cmCancelBtn').click(function() {
        $('#cmCategoryForm')[0].reset();
        $('#cmCategoryId, #cmOldImage').val('');
        $('#cmImagePreviewContainer, #cmRemoveImage').hide();
        $('#cmSubmitBtn').removeClass('update').find('.submit-text').text('Save');
        $('#cmFormTitle').text('Add Category');
        $('#cmCancelBtn').addClass('d-none');
        formModified = false;
      });

      $('#cmCategoryForm :input').on('input change', () => {
        if (!formModified) {
          formModified = true;
          $('#cmSubmitBtn').addClass('update').find('.submit-text').text('Update Category');
        }
      });

      $('#cmCategoryForm').on('submit', function(e) {
        e.preventDefault();
        $('#cmLoadingOverlay').removeClass('d-none');
        $('#cmSubmitBtn .spinner-border').removeClass('d-none');

        const fd = new FormData(this);
        fd.set('isActive', $('#cmIsActive').is(':checked'));
        fd.set('isShowOnHomePage', $('#cmIsShowOnHomePage').is(':checked'));

        $.ajax({
          url: '/categories', method: 'POST', data: fd,
          processData: false, contentType: false,
          success: res => {
            $('#cmLoadingOverlay').addClass('d-none');
            Toastify({ text: res.message, style: { background: res.success ? "#10B981" : "#EF4444" } }).showToast();
            if (res.success) location.reload();
          },
          error: () => {
            $('#cmLoadingOverlay').addClass('d-none');
            Toastify({ text: "Server error", style: { background: "#EF4444" } }).showToast();
          }
        });
      });

      $('#cmSaveOrderBtn').click(function() {
       const order = Array.from($('#cmCategoryGrid > .mc-card')).map(el => el.dataset.id);
        $('#cmLoadingOverlay').removeClass('d-none');

        $.post('/categories/update-order', {
          _csrf: '<%= csrfToken %>',
          order: order
        }, res => {
          $('#cmLoadingOverlay').addClass('d-none');
          Toastify({ text: res.message || "Order saved!", style: { background: res.success ? "#10B981" : "#EF4444" } }).showToast();
          if (res.success) {
            $('#cmSaveOrderBtn').addClass('d-none');
            categories = order.map(id => categories.find(c => c._id === id)).filter(Boolean);
            filteredCategories = [...categories];
            renderCategories();
          }
        }).fail(() => {
          $('#cmLoadingOverlay').addClass('d-none');
          Toastify({ text: "Failed to save order", style: { background: "#EF4444" } }).showToast();
        });
      });

      // Search & Filter
      let st;
      $('#cmSearchInput').on('input', () => {
        clearTimeout(st);
        st = setTimeout(() => {
          const term = $('#cmSearchInput').val().toLowerCase().trim();
          const status = $('#cmActiveFilter').val();
          filteredCategories = categories.filter(c =>
            c.name.toLowerCase().includes(term) &&
            (status === '' || String(c.isActive) === status)
          );
          renderCategories();
        }, 300);
      });

      $('#cmActiveFilter').on('change', () => $('#cmSearchInput').trigger('input'));
      $('#cmClearFiltersBtn').click(() => {
        $('#cmSearchInput').val('');
        $('#cmActiveFilter').val('').trigger('change');
      });

      // Collapse icon
      $('#categoryFormCollapse').on('show.bs.collapse', () => $('#toggleIcon').removeClass('bi-chevron-down').addClass('bi-chevron-up'));
      $('#categoryFormCollapse').on('hide.bs.collapse', () => $('#toggleIcon').removeClass('bi-chevron-up').addClass('bi-chevron-down'));

      renderCategories();
    });
  </script>
  </main>
</body>
</html>