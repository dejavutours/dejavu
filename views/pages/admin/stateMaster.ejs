<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../../partials/admin/admin-layout-head'); %>
  <title>State Management — Deja-vu Admin</title>
  <style>
    /* Scoped styles for State Management with sm- prefix */
    .sm-container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 1.5rem 1rem;
      font-family: "Inter", sans-serif;
      background: linear-gradient(to bottom, #f9fafb, #e5e7eb);
    }


    .sm-form-container { margin-bottom: 16px; overflow: hidden; }

    /* sm-order-input and sm-checkbox keep their JS selector names but use mc-* styles */

    .select2-container--default .select2-selection--single {
      border: 1px solid #d1d5db;
      border-radius: 0.375rem;
      padding: 0.25rem;
      background: #ffffff;
      height: 2.25rem;
    }

    .sm-toast {
      z-index: 10000 !important;
    }


    .sm-loading {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.6);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 9999;
    }

    .sm-loading-spinner {
      border: 4px solid #f3f3f3;
      border-top: 4px solid #1d4ed8;
      border-radius: 50%;
      width: 36px;
      height: 36px;
      animation: sm-spin 1s linear infinite;
    }

    .sm-crop-modal .modal-content {
      border-radius: 0.75rem;
      overflow: hidden;
    }

    .sm-crop-modal select#smCropRatio {
      width: 100%;
      max-width: 200px;
      margin: 0 auto;
      display: block;
    }

    .sm-crop-image {
      max-width: 100%;
      max-height: 50vh;
    }

    .sm-order-input.error {
      border-color: #ef4444;
      background-color: #fee2e2;
    }

    .sm-no-records {
      text-align: center;
      padding: 2rem;
      color: #6b7280;
      font-size: 1rem;
      font-weight: 500;
    }

    @keyframes sm-spin {
      0% {
        transform: rotate(0deg);
      }

      100% {
        transform: rotate(360deg);
      }
    }

    /* Responsive adjustments */
    @media (max-width: 640px) {
      .sm-card-grid {
        grid-template-columns: 1fr;
      }

      .sm-form .grid {
        grid-template-columns: 1fr;
      }


      .sm-filter-bar {
        flex-direction: column;
        align-items: stretch;
      }
    }

    /* Animations */
    @keyframes sm-fadeIn {
      from {
        opacity: 0;
        transform: translateY(8px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</head>

<body class="admin-body">
  <%- include('../../partials/admin/admin-topbar', { pageTitle: 'State Management' }); %>
  <%- include('../../partials/admin/admin-sidebar', { activeNav: 'states' }); %>
  <main class="admin-content">
  <%- include('../../partials/admin/admin-breadcrumb', { breadcrumbs: [{ label: 'Master Data' }, { label: 'States' }] }); %>
  <div class="sm-container" style="background:transparent; padding:0; max-width:100%;">
    <!-- Loading Overlay -->
    <div class="sm-loading" id="smLoadingOverlay">
      <div class="sm-loading-spinner"></div>
    </div>

    <!-- State Management Content -->
      <!-- Add/Update Form -->
      <div class="sm-form-container collapsed" id="smStateFormContainer">
        <div class="mc-form-header">
          <h6 class="mb-0"><i class="bi bi-geo-alt-fill me-2"></i>Add / Edit State</h6>
          <button type="button" class="mc-toggle-btn" id="smFormToggle">Show Form</button>
        </div>
        <div class="mc-form-body">
          <form id="smStateForm" action="/states" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" id="smStateId" name="id" />
            <input type="hidden" id="smOldImage" name="oldImage" />
            <div class="row g-3">
              <div class="col-md-4">
                <label for="smCountry" class="form-label">Country</label>
                <select class="select2 w-full" id="smCountry" name="countryCode" required>
                  <option value="">Select Country</option>
                </select>
              </div>
              <div class="col-md-4">
                <label for="smStateName" class="form-label">State</label>
                <select class="select2 w-full" id="smStateName" name="name" required>
                  <option value="">Select State</option>
                </select>
              </div>
              <div class="col-md-4">
                <label for="smImage" class="form-label">State Image</label>
                <div class="d-flex align-items-center gap-2">
                  <input type="file" class="form-control form-control-sm flex-grow-1" id="smImage" name="image" accept="image/*" />
                  <img id="smImagePreview" src="" alt="Preview" class="rounded" style="width:48px;height:48px;object-fit:cover;border:1px solid #e2e8f0;cursor:pointer;" onclick="$('#smPreviewModalImg').attr('src', this.src); $('#smPreviewModal').modal('show');" />
                </div>
              </div>
              <div class="col-12 d-flex align-items-center gap-3">
                <div class="form-check form-switch mb-0">
                  <input class="form-check-input" type="checkbox" id="smIsActive" name="isActive" checked>
                  <label class="form-check-label small" for="smIsActive">Active</label>
                </div>
                <div class="ms-auto d-flex gap-2">
                  <button type="button" id="smCancelBtn" class="mc-cancel-btn hidden">Cancel</button>
                  <button type="submit" id="smSubmitBtn" class="mc-submit-btn">Add State</button>
                </div>
              </div>
            </div>
          </form>
        </div>
      </div>

      <!-- Filter and Search Bar -->
      <div class="mc-filter-bar">
        <div class="mc-search-wrap">
          <i class="bi bi-search mc-search-icon"></i>
          <input type="text" id="smSearchInput" placeholder="Search states...">
        </div>
        <div class="mc-select-wrap">
          <select class="select2 w-full" id="smCountryFilter">
            <option value="">All Countries</option>
          </select>
        </div>
        <button id="smClearFiltersBtn" class="btn-mc-clear">Clear Filters</button>
        <button id="smBulkDeleteBtn" class="btn-mc-bulk-del hidden">Delete Selected</button>
      </div>

      <!-- State Cards -->
      <div class="mc-card-grid" id="smStateGrid"></div>
      <div class="flex justify-end mt-3">
        <button id="smSaveOrderBtn" class="px-4 py-1.5 bg-gradient-to-r from-green-600 to-green-700 text-white rounded-md hover:from-green-700 hover:to-green-800 text-sm font-medium hidden">
          Save Order
        </button>
      </div>

  </div>

  <!-- Image Preview Modal -->
  <div class="modal fade" id="smPreviewModal" tabindex="-1" aria-labelledby="smPreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title text-base font-semibold">Image Preview</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body text-center">
          <img id="smPreviewModalImg" src="#" class="max-h-[60vh] w-auto mx-auto transform transition-transform duration-200 hover:scale-105" />
        </div>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div class="modal fade" id="smDeleteConfirmModal" tabindex="-1" aria-labelledby="smDeleteConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title text-base font-semibold">Confirm Delete</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body text-sm" id="smDeleteModalBody">
          Are you sure you want to delete the selected state(s)?
        </div>
        <div class="modal-footer">
          <button type="button" class="px-3 py-1.5 bg-gray-200 text-gray-800 rounded-md hover:bg-gray-300 text-sm" data-bs-dismiss="modal">
            Cancel
          </button>
          <button type="button" id="smConfirmDeleteBtn" class="px-3 py-1.5 bg-red-600 text-white rounded-md hover:bg-red-700 text-sm">
            Delete
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Crop Image Modal -->
  <div class="modal fade sm-crop-modal" id="smCropModal" tabindex="-1" aria-labelledby="smCropModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title text-base font-semibold" id="smCropModalLabel">
            Crop Image
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body text-center">
          <div class="mt-2 mb-4">
            <label for="smCropRatio" class="block text-sm font-semibold text-gray-700">Crop Ratio</label>
            <select id="smCropRatio" name="cropMode" class="border border-gray-300 rounded-md p-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
              <option value="1" selected>1:1 (Square)</option>
              <option value="1.333">4:3</option>
              <option value="1.777">16:9</option>
              <option value="free">Free Crop</option>
            </select>
          </div>
          <img id="smCropImage" class="sm-crop-image" />
        </div>
        <div class="modal-footer">
          <button type="button" class="px-3 py-1.5 bg-gray-200 text-gray-800 rounded-md hover:bg-gray-300 text-sm" data-bs-dismiss="modal">
            Cancel
          </button>
          <button type="button" id="smCropConfirmBtn" class="px-3 py-1.5 bg-blue-600 text-white rounded-md hover:bg-blue-700 text-sm">
            Crop & Save
          </button>
        </div>
      </div>
    </div>
  </div>

  <%- include('../../partials/footer'); %>
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/select2@4.0.13/dist/js/select2.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
  <script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.js"></script>
  <script>
    // Initialize state
    let states = <%- JSON.stringify(states) %>;
    let filteredStates = [...states];
    let selectedStates = [];
    let cropper = null;

    // Initialize Select2 for dropdowns
    $(document).ready(function() {
      $(".select2").select2({
        placeholder: "Select an option",
        allowClear: true,
        width: '100%'
      });

      // Fetch countries from REST Countries API
      // Fetch countries from REST Countries API
function loadCountries() {
  $.ajax({
    url: 'https://restcountries.com/v3.1/all?fields=cca2,name', // Add fields parameter
    method: 'GET',
    success: function(data) {
      const countryDropdown = $('#smCountry');
      const countryFilter = $('#smCountryFilter');
      countryDropdown.empty().append('<option value="">Select Country</option>');
      countryFilter.empty().append('<option value="">All Countries</option>');
      data.sort((a, b) => a.name.common.localeCompare(b.name.common)).forEach(country => {
        const countryCode = country.cca2;
        const countryName = country.name.common;
        countryDropdown.append(`<option value="${countryCode}">${countryName}</option>`);
        countryFilter.append(`<option value="${countryCode}">${countryName}</option>`);
      });
      countryDropdown.select2();
      countryFilter.select2();
      // Set India as default
      $('#smCountry').val('IN').trigger('change');
    },
    error: function(jqXHR, textStatus, errorThrown) {
      console.error('Error:', textStatus, errorThrown, jqXHR.responseText);
      Toastify({
        text: 'Failed to load countries. Please try again.',
        className: 'sm-toast',
        style: {
          background: '#EF4444'
        },
        duration: 3000
      }).showToast();
      // Fallback to local data
      const fallbackCountries = {
        'US': 'United States',
        'IN': 'India',
        'CA': 'Canada'
      };
      const countryDropdown = $('#smCountry');
      const countryFilter = $('#smCountryFilter');
      countryDropdown.empty().append('<option value="">Select Country</option>');
      countryFilter.empty().append('<option value="">All Countries</option>');
      Object.entries(fallbackCountries).forEach(([code, name]) => {
        countryDropdown.append(`<option value="${code}">${name}</option>`);
        countryFilter.append(`<option value="${code}">${name}</option>`);
      });
      countryDropdown.select2();
      countryFilter.select2();
      // Set India as default
      $('#smCountry').val('IN').trigger('change');
    }
  });
}
loadCountries();

      // Update state dropdown based on country selection
      $('#smCountry').on('change', function() {
        const selectedCountry = $(this).val();
        const stateDropdown = $('#smStateName');
        stateDropdown.empty().append('<option value="">Select State</option>');
        if (selectedCountry) {
          $.ajax({
            url: `https://countriesnow.space/api/v0.1/countries/states`,
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
              iso2: selectedCountry
            }),
            success: function(response) {
              if (response.error) {
                Toastify({
                  text: 'No states found for this country.',
                  className: 'sm-toast',
                  style: {
                    background: '#F59E0B'
                  },
                  duration: 3000
                }).showToast();
                return;
              }
              response.data.states.forEach(state => {
                stateDropdown.append(`<option value="${state.name}">${state.name}</option>`);
              });
              stateDropdown.select2();
              updateImagePreview();
            },
            error: function() {
              Toastify({
                text: 'Failed to load states. Please try again.',
                className: 'sm-toast',
                style: {
                  background: '#EF4444'
                },
                duration: 3000
              }).showToast();
            }
          });
        } else {
          stateDropdown.select2();
          updateImagePreview();
        }
      });

      // Auto-update image preview on state selection
      $('#smStateName').on('change', updateImagePreview);

      function updateImagePreview() {
        const selectedCountry = $('#smCountry').val();
        const selectedState = $('#smStateName').val();
        if (selectedCountry && selectedState) {
          const state = states.find(s => s.countryCode === selectedCountry && s.name === selectedState);
          if (state && state.image) {
            $('#smImagePreview').attr('src', state.image).show();
            $('#smOldImage').val(state.image);
            $('#smIsActive').prop('checked', state.isActive === true || state.isActive === 'true' || state.isActive === 'on');
          } else {
            $('#smImagePreview').attr('src', '').hide();
            $('#smOldImage').val('');
            $('#smIsActive').prop('checked', true); // Default to checked for new states
          }
        } else {
          $('#smImagePreview').attr('src', '').hide();
          $('#smOldImage').val('');
          $('#smIsActive').prop('checked', true); // Default to checked for new states
        }
      }

      // Clear filters
      $('#smClearFiltersBtn').on('click', function() {
        $('#smSearchInput').val('');
        $('#smCountryFilter').val('').trigger('change');
        filteredStates = [...states];
        renderStates();
      });

      // Form submission
      $('#smStateForm').on('submit', function(e) {
        e.preventDefault();
        $('#smLoadingOverlay').show();
        const formData = new FormData(this);

        if ($('#smImage').val()) {
          formData.set('image', $('#smImage')[0].files[0]);
        } else if ($('#smOldImage').val() && $('#smStateId').val()) {
          formData.set('oldImage', $('#smOldImage').val());
        }

        // Explicitly set isActive as "true" or "false"
        formData.set('isActive', $('#smIsActive').is(':checked') ? 'true' : 'false');

        $.ajax({
          url: '/states',
          method: 'POST',
          data: formData,
          processData: false,
          contentType: false,
          success: function(response) {
            $('#smLoadingOverlay').hide();
            if (response.success) {
              Toastify({
                text: response.message,
                className: 'sm-toast',
                duration: 3000
              }).showToast();
              setTimeout(() => location.reload(), 600);
            } else {
              Toastify({
                text: response.error || 'Failed to process state.',
                className: 'sm-toast',
                style: {
                  background: '#EF4444'
                },
                duration: 3000
              }).showToast();
            }
          },
          error: function(xhr) {
            $('#smLoadingOverlay').hide();
            const message = xhr.responseJSON?.error || 'Error processing request.';
            Toastify({
              text: message,
              className: 'sm-toast',
              duration: 3000
            }).showToast();
          }
        });
      });

      // Check for active trips before delete
      async function checkActiveTrips(stateName) {
        try {
          const response = await $.ajax({
            url: '/states/check-trips',
            method: 'POST',
            data:JSON.stringify({ stateName, _csrf: '<%= csrfToken %>' }),
            contentType: 'application/json'
          });
          return response;
        } catch (error) {
          Toastify({
            text: 'Error checking active trips.',
            className: 'sm-toast',
            style: {
              background: '#EF4444'
            },
            duration: 3000
          }).showToast();
          return {
            success: false
          };
        }
      }

      // Delete state with AJAX
      $(document).on('submit', '.sm-delete-form', async function(e) {
        e.preventDefault();
        const form = $(this);
        const stateName = form.find('input[name="stateName"]').val();

        const tripCheck = await checkActiveTrips(stateName);
        if (!tripCheck.success) {
          $('#smDeleteModalBody').html(`Cannot delete state due to active trips:<br>${tripCheck.trips.map(trip => `<strong>${trip.name}</strong>`).join('<br>')}`);
          $('#smDeleteConfirmModal').modal('show');
          $('#smConfirmDeleteBtn').addClass('hidden');
          return;
        }

        $('#smDeleteModalBody').html('Are you sure you want to delete the selected state?');
        $('#smConfirmDeleteBtn').removeClass('hidden');
        $('#smDeleteConfirmModal').modal('show');
        $('#smConfirmDeleteBtn').off('click').on('click', function() {
          $('#smLoadingOverlay').show();
          $.ajax({
            url: form.attr('action'),
            method: 'POST',
            data: form.serialize(),
            success: function(response) {
              $('#smLoadingOverlay').hide();
              $('#smDeleteConfirmModal').modal('hide');
              if (response.success) {
                Toastify({
                  text: response.message,
                  className: 'sm-toast',
                  style: {
                    background: '#10B981'
                  },
                  duration: 3000
                }).showToast();
                setTimeout(() => location.reload(), 600);
              } else {
                Toastify({
                  text: response.message || 'Failed to delete state.',
                  className: 'sm-toast',
                  style: {
                    background: '#EF4444'
                  },
                  duration: 3000
                }).showToast();
              }
            },
            error: function() {
              $('#smLoadingOverlay').hide();
              $('#smDeleteConfirmModal').modal('hide');
              Toastify({
                text: 'Error deleting state.',
                className: 'sm-toast',
                style: {
                  background: '#EF4444'
                },
                duration: 3000
              }).showToast();
            }
          });
        });
      });

      // Bulk delete
      $('#smBulkDeleteBtn').on('click', async function() {
        if (selectedStates.length === 0) {
          Toastify({
            text: 'No states selected.',
            className: 'sm-toast',
            style: {
              background: '#F59E0B'
            },
            duration: 3000
          }).showToast();
          return;
        }
        const stateNames = states.filter(s => selectedStates.includes(s._id)).map(s => s.name);
        for (const stateName of stateNames) {
          const tripCheck = await checkActiveTrips(stateName);
          if (!tripCheck.success) {
            $('#smDeleteModalBody').html(`Cannot delete states due to active trips in ${stateName}:<br>${tripCheck.trips.map(trip => `<strong>${trip.name}</strong>`).join('<br>')}`);
            $('#smDeleteConfirmModal').modal('show');
            $('#smConfirmDeleteBtn').addClass('hidden');
            return;
          }
        }
        $('#smDeleteModalBody').html('Are you sure you want to delete the selected states?');
        $('#smConfirmDeleteBtn').removeClass('hidden');
        $('#smDeleteConfirmModal').modal('show');
        $('#smConfirmDeleteBtn').off('click').on('click', function() {
          $('#smLoadingOverlay').show();
          const promises = selectedStates.map(id =>
            $.ajax({
              url: `/states/delete/${id}`,
              method: 'POST',
              data: {
                _csrf: '<%= csrfToken %>'
              }
            })
          );
          Promise.all(promises)
            .then(responses => {
              $('#smLoadingOverlay').hide();
              $('#smDeleteConfirmModal').modal('hide');
              if (responses.every(res => res.success)) {
                Toastify({
                  text: 'Selected states deleted successfully.',
                  className: 'sm-toast',
                  style: {
                    background: '#10B981'
                  },
                  duration: 3000
                }).showToast();
                setTimeout(() => location.reload(), 600);
              } else {
                Toastify({
                  text: 'Failed to delete some states.',
                  className: 'sm-toast',
                  style: {
                    background: '#EF4444'
                  },
                  duration: 3000
                }).showToast();
              }
            })
            .catch(() => {
              $('#smLoadingOverlay').hide();
              $('#smDeleteConfirmModal').modal('hide');
              Toastify({
                text: 'Error deleting states.',
                className: 'sm-toast',
                style: {
                  background: '#EF4444'
                },
                duration: 3000
              }).showToast();
            });
        });
      });

      // Initialize drag-and-drop
      const stateGrid = document.getElementById('smStateGrid');
      let orderChanged = false;
      Sortable.create(stateGrid, {
        animation: 150,
        handle: '.sm-card',
        touchStartThreshold: 5,
        onEnd: function(evt) {
          orderChanged = true;
          $('#smSaveOrderBtn').removeClass('hidden');
          updateOrderInputs();
        }
      });

      // Save order with duplicate check
      $('#smSaveOrderBtn').on('click', function() {
        if (checkDuplicateOrders()) {
          Toastify({
            text: 'Duplicate display orders detected. Please fix before saving.',
            className: 'sm-toast',
            style: {
              background: '#F59E0B'
            },
            duration: 3000
          }).showToast();
          return;
        }
        const newOrder = Array.from(stateGrid.children).map(card => card.dataset.id);
        $('#smLoadingOverlay').show();
        $.ajax({
          url: '/states/update-order',
          method: 'POST',
          contentType: 'application/json',
          data: JSON.stringify({
            _csrf: '<%= csrfToken %>',
            order: newOrder
          }),
          success: function(response) {
            $('#smLoadingOverlay').hide();
            if (response.success) {
              Toastify({
                text: response.message,
                className: 'sm-toast',
                style: {
                  background: '#10B981'
                },
                duration: 3000
              }).showToast();
              orderChanged = false;
              $('#smSaveOrderBtn').addClass('hidden');
              const orderedStates = [];
              newOrder.forEach(id => {
                const state = states.find(s => s._id === id);
                if (state) orderedStates.push(state);
              });
              states = orderedStates;
              filteredStates = [...states];
              renderStates();
            } else {
              Toastify({
                text: response.message || 'Failed to update state order.',
                className: 'sm-toast',
                style: {
                  background: '#EF4444'
                },
                duration: 3000
              }).showToast();
            }
          },
          error: function(xhr) {
            $('#smLoadingOverlay').hide();
            const message = xhr.responseJSON?.error || 'Error updating state order.';
            Toastify({
              text: message,
              className: 'sm-toast',
              style: {
                background: '#EF4444'
              },
              duration: 3000
            }).showToast();
          }
        });
      });

      // Client-side search and filter
      let searchTimeout;

      function applyFilters() {
        const searchTerm = $('#smSearchInput').val().toLowerCase().trim();
        const selectedCountry = $('#smCountryFilter').val();
        filteredStates = states.filter(state => {
          const matchesSearch = state.name.toLowerCase().includes(searchTerm) ||
            state.countryCode.toLowerCase().includes(searchTerm);
          const matchesCountry = !selectedCountry || state.countryCode === selectedCountry;
          return matchesSearch && matchesCountry;
        });
        renderStates();
      }

      $('#smSearchInput').on('input', function() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(applyFilters, 300);
      });

      $('#smCountryFilter').on('change', applyFilters);

      // Render states
      function renderStates() {
        const stateGrid = $('#smStateGrid');
        stateGrid.empty();
        if (filteredStates.length === 0) {
          stateGrid.append('<p class="sm-no-records">No records found.</p>');
        } else {
          filteredStates.forEach(state => {
            const card = `
              <div class="mc-card sm-card" data-id="${state._id}">
                <input type="checkbox" class="mc-card-check sm-checkbox" data-id="${state._id}">
                <img src="${state.image || '/img/placeholder.jpg'}" alt="${state.name}" class="mc-card-img" data-src="${state.image}" onerror="this.src='/img/placeholder.jpg'">
                <div class="mc-card-body">
                  <div class="mc-card-name" title="${state.name}">${state.name}</div>
                  <div class="mc-card-meta">${state.countryCode || ''}</div>
                  <div class="mc-badge-row">
                    <span class="mc-badge ${state.isActive ? 'active' : 'inactive'}">${state.isActive ? 'Active' : 'Inactive'}</span>
                  </div>
                </div>
                <div class="mc-card-footer">
                  <input type="number" class="mc-order-input sm-order-input" value="${state.displayOrder || 0}" min="0" data-id="${state._id}" title="Display Order">
                  <button type="button" class="mc-btn-edit" onclick="editState('${state._id}')"><i class="bi bi-pencil-fill"></i></button>
                  <form action="/states/delete/${state._id}" method="POST" class="d-inline sm-delete-form" style="line-height:0;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="stateName" value="${state.name}">
                    <button type="submit" class="mc-btn-delete"><i class="bi bi-trash-fill"></i></button>
                  </form>
                </div>
              </div>
            `;
            stateGrid.append(card);
          });
        }

        $('.lazy-img').each(function() {
          const img = $(this);
          if (img[0].getBoundingClientRect().top < window.innerHeight) {
            img.attr('src', img.data('src')).removeClass('lazy-img');
          }
        });

        $('#smBulkDeleteBtn').toggle(selectedStates.length > 0);
        checkDuplicateOrders();
      }

      // Check for duplicate display orders
      function checkDuplicateOrders() {
        const orderInputs = Array.from($('.sm-order-input'));
        const orderValues = {};
        let hasDuplicates = false;
        orderInputs.forEach(input => {
          const value = parseInt(input.value) || 0;
          if (orderValues[value]) {
            input.classList.add('error');
            hasDuplicates = true;
          } else {
            input.classList.remove('error');
            orderValues[value] = true;
          }
        });
        return hasDuplicates;
      }

      // Update order inputs after drag
      function updateOrderInputs() {
        const cards = Array.from(stateGrid.children);
        cards.forEach((card, index) => {
          const id = card.dataset.id;
          const input = $(card).find('.sm-order-input');
          input.val(index);
          const state = states.find(s => s._id === id);
          if (state) state.displayOrder = index;
        });
        checkDuplicateOrders();
      }

      // Checkbox selection
      $(document).on('change', '.sm-checkbox', function() {
        const id = $(this).data('id');
        if ($(this).is(':checked')) {
          selectedStates.push(id);
        } else {
          selectedStates = selectedStates.filter(sid => sid !== id);
        }
        $('#smBulkDeleteBtn').toggle(selectedStates.length > 0);
      });

      // Inline order update
      $(document).on('change', '.sm-order-input', function() {
        const id = $(this).data('id');
        const newOrder = parseInt($(this).val()) || 0;
        orderChanged = true;
        $('#smSaveOrderBtn').removeClass('hidden');
        const state = states.find(s => s._id === id);
        if (state) state.displayOrder = newOrder;
        renderStates();
      });

      // Edit state with retry mechanism
      window.editState = async function(id, retryCount = 0) {
        const state = states.find(s => s._id === id);
        if (!state) {
          Toastify({
            text: 'State data not found.',
            className: 'sm-toast',
            style: {
              background: '#EF4444'
            },
            duration: 3000
          }).showToast();
          return;
        }

        $('#smStateId').val(id);
        $('#smCountry').val(state.countryCode).trigger('change');
        $('#smImagePreview').attr('src', state.image);
        $('#smOldImage').val(state.image);
        // Normalize isActive to boolean
        $('#smIsActive').prop('checked', state.isActive === true || state.isActive === 'true' || state.isActive === 'on');
        $('#smSubmitBtn').text('Update State').addClass('update');
        $('#smCancelBtn').removeClass('hidden');
        $('#smStateFormContainer').removeClass('collapsed');
        $('#smFormToggle').text('Hide Form');

        const maxRetries = 3;
        const retryDelay = 1000;

        async function trySetStateName() {
          if ($('#smStateName option[value="' + state.name + '"]').length > 0) {
            $('#smStateName').val(state.name).trigger('change');
          } else if (retryCount < maxRetries) {
            await new Promise(resolve => setTimeout(resolve, retryDelay));
            await trySetStateName(retryCount + 1);
          } else {
            Toastify({
              text: 'State not found in dropdown, please check country selection.',
              className: 'sm-toast',
              style: {
                background: '#F59E0B'
              },
              duration: 3000
            }).showToast();
          }
        }

        setTimeout(trySetStateName, 500);
      };

      // Cancel edit
      $('#smCancelBtn').on('click', function() {
        $('#smStateForm')[0].reset();
        $('#smCountry').val('IN').trigger('change');
        $('#smStateName').val('').trigger('change');
        $('#smStateId').val('');
        $('#smOldImage').val('');
        $('#smImagePreview').attr('src', '');
        $('#smIsActive').prop('checked', true);
        $('#smSubmitBtn').text('Add State').removeClass('update');
        $('#smCancelBtn').addClass('hidden');
        $('#smStateFormContainer').addClass('collapsed');
        $('#smFormToggle').text('Show Form');
      });

      // Image crop handling
      $('#smImage').on('change', function(event) {
        const file = event.target.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = function(e) {
            $('#smCropImage').attr('src', e.target.result);
            $('#smCropModal').modal('show');
            setTimeout(function() {
              if (cropper) cropper.destroy();
              const cropMode = $('#smCropRatio').val() || '1';
              const aspectRatio = cropMode === 'free' ? NaN : parseFloat(cropMode);
              cropper = new Cropper(document.getElementById('smCropImage'), {
                aspectRatio: aspectRatio,
                viewMode: 1,
                autoCropArea: 0.8,
                responsive: true
              });
            }, 200);
          };
          reader.readAsDataURL(file);
        }
      });

      $('#smCropRatio').on('change', function() {
        if (cropper) {
          cropper.destroy();
          const cropMode = $(this).val();
          const aspectRatio = cropMode === 'free' ? NaN : parseFloat(cropMode);
          cropper = new Cropper(document.getElementById('smCropImage'), {
            aspectRatio: aspectRatio,
            viewMode: 1,
            autoCropArea: 0.8,
            responsive: true
          });
        }
      });

      $('#smCropConfirmBtn').on('click', function() {
        if (cropper) {
          cropper.getCroppedCanvas({
            width: 300,
            height: 300
          }).toBlob(function(blob) {
            const url = URL.createObjectURL(blob);
            $('#smImagePreview').attr('src', url).show();
            const file = new File([blob], `cropped-image-${Date.now()}.jpg`, {
              type: 'image/jpeg'
            });
            const dataTransfer = new DataTransfer();
            dataTransfer.items.add(file);
            $('#smImage')[0].files = dataTransfer.files;
            $('#smOldImage').val('');
            $('#smCropModal').modal('hide');
            cropper.destroy();
            cropper = null;
          }, 'image/jpeg', 0.9);
        }
      });

      $('#smCropModal').on('hidden.bs.modal', function() {
        if (cropper) {
          cropper.destroy();
          cropper = null;
        }
      });

      // Form toggle
      $('#smFormToggle').on('click', function() {
        $('#smStateFormContainer').toggleClass('collapsed');
        $(this).text($('#smStateFormContainer').hasClass('collapsed') ? 'Show Form' : 'Hide Form');
      });


      // Lazy load images
      $(window).on('scroll', function() {
        $('.lazy-img').each(function() {
          const img = $(this);
          if (img[0].getBoundingClientRect().top < window.innerHeight) {
            img.attr('src', img.data('src')).removeClass('lazy-img');
          }
        });
      });

      // Initial render
      renderStates();
    });
  </script>
  </main>
</body>

</html>