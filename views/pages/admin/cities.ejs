<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../../partials/admin/admin-layout-head'); %>
  <title>City Management — Deja-vu Admin</title>
  
  <style>
    /* Scoped styles for City Management with cm- prefix */
    .cm-container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 1.5rem 1rem;
      font-family: 'Inter', sans-serif;
      background: linear-gradient(to bottom, #f9fafb, #e5e7eb);
    }


    .cm-form-container { margin-bottom: 16px; overflow: hidden; }

    /* cm-checkbox and cm-order-input keep JS selector names, styled via mc-* */

    .select2-container--default .select2-selection--single {
      border: 1px solid #d1d5db;
      border-radius: 0.375rem;
      padding: 0.25rem;
      background: #ffffff;
      height: 2.25rem;
    }

    .cm-toast {
      z-index: 10000 !important;
    }


    .cm-loading {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.6);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 9999;
    }

    .cm-loading-spinner {
      border: 4px solid #f3f3f3;
      border-top: 4px solid #1d4ed8;
      border-radius: 50%;
      width: 36px;
      height: 36px;
      animation: cm-spin 1s linear infinite;
    }

    .cm-crop-modal .modal-content {
      border-radius: 0.75rem;
      overflow: hidden;
    }

    .cm-crop-modal select#cmCropRatio {
      width: 100%;
      max-width: 200px;
      margin: 0 auto;
      display: block;
    }

    .cm-crop-image {
      max-width: 100%;
      max-height: 50vh;
    }

    .cm-order-input.error {
      border-color: #EF4444;
      background-color: #FEE2E2;
    }

    @keyframes cm-spin {
      0% {
        transform: rotate(0deg);
      }

      100% {
        transform: rotate(360deg);
      }
    }

    /* Responsive adjustments */
    @media (max-width: 640px) {
      .cm-card-grid {
        grid-template-columns: 1fr;
      }

      .cm-form .grid {
        grid-template-columns: 1fr;
      }


      .cm-filter-bar {
        flex-direction: column;
        align-items: stretch;
      }
    }

    /* Animations */
    @keyframes cm-fadeIn {
      from {
        opacity: 0;
        transform: translateY(8px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</head>

<body class="admin-body">
  <%- include('../../partials/admin/admin-topbar', { pageTitle: 'City Management' }); %>
  <%- include('../../partials/admin/admin-sidebar', { activeNav: 'cities' }); %>
  <main class="admin-content">
  <%- include('../../partials/admin/admin-breadcrumb', { breadcrumbs: [{ label: 'Master Data' }, { label: 'Cities' }] }); %>
  <div class="cm-container" style="background:transparent; padding:0; max-width:100%;">
    <!-- Loading Overlay -->
    <div class="cm-loading" id="cmLoadingOverlay">
      <div class="cm-loading-spinner"></div>
    </div>

    <!-- City Management Content -->
      <!-- Add/Update Form -->
      <div class="cm-form-container collapsed" id="cmCityFormContainer">
        <div class="mc-form-header">
          <h6 class="mb-0"><i class="bi bi-building me-2"></i>Add / Edit City</h6>
          <button type="button" class="mc-toggle-btn" id="cmFormToggle">Show Form</button>
        </div>
        <div class="mc-form-body">
          <form id="cmCityForm" action="/cities" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" id="cmCityId" name="id" />
            <input type="hidden" id="cmOldImage" name="oldImage" />
            <input type="hidden" id="cmCountryCode" name="countryCode" value="IN" />

            <div class="row g-3">
              <!-- Country Type -->
              <div class="col-12">
                <label class="form-label">Country Type</label>
                <div class="d-flex gap-4">
                  <label class="d-flex align-items-center gap-2 cursor-pointer">
                    <input type="radio" name="countryType" id="cmTypeIndia" value="IN" checked class="accent-blue-600" />
                    <span class="small">India</span>
                  </label>
                  <label class="d-flex align-items-center gap-2 cursor-pointer">
                    <input type="radio" name="countryType" id="cmTypeIntl" value="INTL" class="accent-blue-600" />
                    <span class="small">International</span>
                  </label>
                </div>
              </div>

              <!-- India Mode -->
              <div id="cmIndiaSection" class="col-md-6">
                <label for="cmState" class="form-label">State</label>
                <select class="select2 w-full" id="cmState" name="state">
                  <option value="">Select State</option>
                </select>
                <label for="cmCityName" class="form-label mt-2">City</label>
                <select class="select2 w-full" id="cmCityName" name="name">
                  <option value="">Select City</option>
                </select>
              </div>

              <!-- International Mode -->
              <div id="cmIntlSection" class="col-md-6 hidden">
                <div id="cmIntlCountryWrapper">
                  <label for="cmIntlCountry" class="form-label">Country</label>
                  <select class="select2 w-full" id="cmIntlCountry">
                    <option value="">Select Country</option>
                  </select>
                </div>
                <div id="cmIntlStateWrapper" class="mt-2">
                  <label for="cmIntlState" class="form-label">State / Region</label>
                  <select class="select2 w-full" id="cmIntlState">
                    <option value="">Select State / Region</option>
                  </select>
                </div>
                <div id="cmIntlCityWrapper" class="mt-2">
                  <label for="cmIntlCityName" class="form-label">City</label>
                  <select class="w-full" id="cmIntlCityName">
                    <option value="">Select or type a city</option>
                  </select>
                  <p class="text-muted small mt-1">Type to search or press Enter to add a new city.</p>
                </div>
              </div>

              <!-- Image -->
              <div class="col-md-6">
                <label for="cmImage" class="form-label">City Image</label>
                <div class="d-flex align-items-center gap-2">
                  <input type="file" class="form-control form-control-sm flex-grow-1" id="cmImage" name="image" accept="image/*" />
                  <img id="cmImagePreview" src="" alt="Preview" class="rounded" style="width:48px;height:48px;object-fit:cover;border:1px solid #e2e8f0;cursor:pointer;" onclick="$('#cmPreviewModalImg').attr('src', this.src); $('#cmPreviewModal').modal('show');" />
                </div>
              </div>

              <div class="col-12 d-flex justify-content-end gap-2">
                <button type="button" id="cmCancelBtn" class="mc-cancel-btn hidden">Cancel</button>
                <button type="submit" id="cmSubmitBtn" class="mc-submit-btn">Add City</button>
              </div>
            </div>
          </form>
        </div>
      </div>

      <!-- Filter and Search Bar -->
      <div class="mc-filter-bar">
        <div class="mc-search-wrap">
          <i class="bi bi-search mc-search-icon"></i>
          <input type="text" id="cmSearchInput" placeholder="Search cities...">
        </div>
        <div class="mc-select-wrap">
          <select class="select2 w-full" id="cmStateFilter">
            <option value="">All States</option>
          </select>
        </div>
        <button id="cmBulkDeleteBtn" class="btn-mc-bulk-del hidden">Delete Selected</button>
      </div>

      <!-- City Cards -->
      <div class="mc-card-grid" id="cmCityGrid"></div>
      <div class="flex justify-end mt-3">
        <button id="cmSaveOrderBtn" class="px-4 py-1.5 bg-gradient-to-r from-green-600 to-green-700 text-white rounded-md hover:from-green-700 hover:to-green-800 text-sm font-medium hidden">Save Order</button>
      </div>

  </div>

  <!-- Image Preview Modal -->
  <div class="modal fade" id="cmPreviewModal" tabindex="-1" aria-labelledby="cmPreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title text-base font-semibold">Image Preview</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body text-center">
          <img id="cmPreviewModalImg" src="#" class="max-h-[60vh] w-auto mx-auto transform transition-transform duration-200 hover:scale-105" />
        </div>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div class="modal fade" id="cmDeleteConfirmModal" tabindex="-1" aria-labelledby="cmDeleteConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title text-base font-semibold">Confirm Delete</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body text-sm">
          Are you sure you want to delete the selected city(ies)?
        </div>
        <div class="modal-footer">
          <button type="button" class="px-3 py-1.5 bg-gray-200 text-gray-800 rounded-md hover:bg-gray-300 text-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="button" id="cmConfirmDeleteBtn" class="px-3 py-1.5 bg-red-600 text-white rounded-md hover:bg-red-700 text-sm">Delete</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Crop Image Modal -->
  <div class="modal fade cm-crop-modal" id="cmCropModal" tabindex="-1" aria-labelledby="cmCropModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title text-base font-semibold" id="cmCropModalLabel">Crop Image</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body text-center">
          <div class="mt-2 mb-4">
            <label for="cmCropRatio" class="block text-sm font-semibold text-gray-700">Crop Ratio</label>
            <select id="cmCropRatio" name="cropMode" class="border border-gray-300 rounded-md p-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
              <option value="1" selected>1:1 (Square)</option>
              <option value="1.333">4:3</option>
              <option value="1.777">16:9</option>
              <option value="free">Free Crop</option>
            </select>
          </div>
          <img id="cmCropImage" class="cm-crop-image" />
        </div>
        <div class="modal-footer">
          <button type="button" class="px-3 py-1.5 bg-gray-200 text-gray-800 rounded-md hover:bg-gray-300 text-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="button" id="cmCropConfirmBtn" class="px-3 py-1.5 bg-blue-600 text-white rounded-md hover:bg-blue-700 text-sm">Crop & Save</button>
        </div>
      </div>
    </div>
  </div>

  <%- include('../../partials/footer'); %>
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/select2@4.0.13/dist/js/select2.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.js"></script>
  <script>
    // Initialize state
    let cities = <%- JSON.stringify(cities) %>;
    let filteredCities = [...cities];
    let selectedCities = [];
    let cropper = null;

    // Initialize Select2 for dropdowns
    $(document).ready(function() {
      $(".select2").select2({
        placeholder: "Select an option",
        allowClear: true,
        width: '100%'
      });

      // Initialize international city dropdown with tags support
      $('#cmIntlCityName').select2({
        placeholder: 'Select or type a city',
        allowClear: true,
        width: '100%',
        tags: true,
        createTag: function(params) {
          const term = $.trim(params.term);
          if (!term) return null;
          return { id: term, text: term, newTag: true };
        }
      });

      // Populate state dropdowns (India states from statecities.json)
      const stateCities = <%- JSON.stringify(stateCities) %>;
      const stateDropdown = $('#cmState');
      const stateFilter = $('#cmStateFilter');
      Object.keys(stateCities).forEach(state => {
        stateDropdown.append(`<option value="${state}">${state}</option>`);
        stateFilter.append(`<option value="${state}">${state}</option>`);
      });
      // Also include any international states already in DB
      cities.forEach(c => {
        if (c.countryCode && c.countryCode !== 'IN') {
          if (!stateFilter.find(`option[value="${c.state}"]`).length) {
            stateFilter.append(`<option value="${c.state}">${c.state} (${c.countryCode})</option>`);
          }
        }
      });
      stateFilter.select2({ placeholder: 'All States', allowClear: true, width: '100%' });

      // Update city dropdown based on state selection (India mode)
      $('#cmState').on('change', function() {
        const selectedState = $(this).val();
        const cityDropdown = $('#cmCityName');
        cityDropdown.empty().append('<option value="">Select City</option>');
        if (selectedState && stateCities[selectedState]) {
          stateCities[selectedState].forEach(city => {
            cityDropdown.append(`<option value="${city}">${city}</option>`);
          });
        }
        cityDropdown.select2();
        updateImagePreview();
      });

      // Auto-update image preview on city selection (India mode)
      $('#cmCityName').on('change', updateImagePreview);

      function updateImagePreview() {
        const isIntl = $('input[name="countryType"]:checked').val() === 'INTL';
        let selectedState, selectedCity;
        if (isIntl) {
          selectedState = $('#cmIntlState').val();
          selectedCity = $('#cmIntlCityName').val();
        } else {
          selectedState = $('#cmState').val();
          selectedCity = $('#cmCityName').val();
        }
        if (selectedState && selectedCity) {
          const city = cities.find(c => c.state === selectedState && c.name === selectedCity);
          if (city && city.image) {
            $('#cmImagePreview').attr('src', city.image).show();
            $('#cmOldImage').val(city.image);
          } else {
            $('#cmImagePreview').attr('src', '').hide();
            $('#cmOldImage').val('');
          }
        } else {
          $('#cmImagePreview').attr('src', '').hide();
          $('#cmOldImage').val('');
        }
      }

      // ── Country type toggle ──────────────────────────────────────────────
      $('input[name="countryType"]').on('change', function() {
        const isIntl = $(this).val() === 'INTL';

        // ── Clear ALL fields in both sections when switching mode ──
        // India fields
        $('#cmState').val(null).trigger('change.select2');
        const indCityDrop = $('#cmCityName');
        indCityDrop.empty().append('<option value="">Select City</option>');
        if (indCityDrop.data('select2')) indCityDrop.trigger('change.select2');

        // International country
        if ($('#cmIntlCountry').data('select2')) $('#cmIntlCountry').val(null).trigger('change.select2');
        $('#cmCountryCode').val('IN');

        // International state — reset to empty select
        const stIntl = $('#cmIntlState');
        if (stIntl.is('input')) {
          $('#cmIntlStateWrapper').html(
            '<label for="cmIntlState" class="block text-sm font-semibold text-gray-700">State / Region</label>' +
            '<select class="select2 w-full" id="cmIntlState" name="state">' +
            '<option value="">Select State / Region</option></select>'
          );
          $('#cmIntlState').select2({ placeholder: 'Select State / Region', allowClear: true, width: '100%' });
        } else {
          if (stIntl.data('select2')) stIntl.val(null).trigger('change.select2');
          else stIntl.val('');
        }

        // International city
        resetIntlCityDropdown();

        // Shared fields
        $('#cmCityId').val('');
        $('#cmOldImage').val('');
        $('#cmImagePreview').attr('src', '').hide();
        $('#cmSubmitBtn').text('Add City').removeClass('update');
        $('#cmCancelBtn').addClass('hidden');

        if (isIntl) {
          $('#cmIndiaSection').addClass('hidden');
          $('#cmIntlSection').removeClass('hidden');
          $('#cmState').removeAttr('name');
          $('#cmCityName').removeAttr('name');
          $('#cmIntlState').attr('name', 'state');
          $('#cmIntlCityName').attr('name', 'name');
          loadCountriesForIntl();
        } else {
          $('#cmIntlSection').addClass('hidden');
          $('#cmIndiaSection').removeClass('hidden');
          $('#cmState').attr('name', 'state');
          $('#cmCityName').attr('name', 'name');
          $('#cmIntlState').removeAttr('name');
          $('#cmIntlCityName').removeAttr('name');
          $('#cmCountryCode').val('IN');
        }
      });

      // Countries+states cache — loaded once, reused for both country dropdown and state loading
      let countriesLoaded = false;
      let countriesCache = null;

      // Load country list. Uses /countries/states (has iso2 + name). Callback fires when done.
      function loadCountriesForIntl(callback) {
        if (countriesLoaded) { if (callback) callback(); return; }
        // /countries/states returns {name, iso2, iso3, states[]} — has iso2
        $.getJSON('https://countriesnow.space/api/v0.1/countries/states', function(data) {
          if (data && data.data) {
            countriesCache = data.data;
            const intlCountry = $('#cmIntlCountry');
            intlCountry.empty().append('<option value="">Select Country</option>');
            data.data
              .filter(c => c.iso2 && c.iso2 !== 'IN')
              .sort((a, b) => a.name.localeCompare(b.name))
              .forEach(c => {
                intlCountry.append('<option value="' + c.iso2 + '" data-name="' + c.name + '">' + c.name + '</option>');
              });
            intlCountry.select2({ placeholder: 'Select Country', allowClear: true, width: '100%' });
            countriesLoaded = true;
          }
          if (callback) callback();
        }).fail(function() {
          // API down — show free-text ISO2 input as fallback
          $('#cmIntlCountryWrapper').html(
            '<label class="block text-sm font-semibold text-gray-700">Country (ISO2 code)</label>' +
            '<input type="text" id="cmIntlCountry" placeholder="e.g. AE, US, VN" maxlength="3" ' +
            'class="w-full border border-gray-300 rounded-md p-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />'
          );
          countriesLoaded = true;
          if (callback) callback();
        });
      }

      // Populate states for a given countryCode using cache (or empty select on failure)
      function populateStatesForCountry(countryCode, countryName) {
        const wrapper = $('#cmIntlStateWrapper');
        // Restore to select if it was a text input
        if ($('#cmIntlState').is('input')) {
          wrapper.html(
            '<label for="cmIntlState" class="block text-sm font-semibold text-gray-700">State / Region</label>' +
            '<select class="select2 w-full" id="cmIntlState" name="state">' +
            '<option value="">Select State / Region</option></select>'
          );
        }
        const stEl = $('#cmIntlState');
        if (stEl.data('select2')) stEl.select2('destroy');

        if (!countryCode) {
          stEl.empty().append('<option value="">Select State / Region</option>');
          stEl.select2({ placeholder: 'Select State / Region', allowClear: true, width: '100%' });
          return;
        }

        function applyStates(allCountries) {
          const match = allCountries && (
            allCountries.find(c => c.iso2 === countryCode) ||
            (countryName ? allCountries.find(c => c.name === countryName) : null)
          );
          if ($('#cmIntlState').data('select2')) $('#cmIntlState').select2('destroy');
          if (match && match.states && match.states.length) {
            const sel = $('#cmIntlState').length ? $('#cmIntlState') : $('<select class="select2 w-full" id="cmIntlState" name="state"></select>');
            sel.empty().append('<option value="">Select State / Region</option>');
            match.states.forEach(s => sel.append('<option value="' + s.name + '" data-country="' + match.name + '">' + s.name + '</option>'));
            if (!$('#cmIntlState').length) wrapper.append(sel);
            $('#cmIntlState').select2({ placeholder: 'Select State / Region', allowClear: true, width: '100%' });
          } else {
            // No state divisions — replace with text input
            wrapper.html(
              '<label for="cmIntlState" class="block text-sm font-semibold text-gray-700">State / Region</label>' +
              '<input type="text" id="cmIntlState" name="state" placeholder="Enter state/region name" ' +
              'class="w-full border border-gray-300 rounded-md p-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />'
            );
          }
        }

        if (countriesCache) {
          applyStates(countriesCache);
        } else {
          stEl.empty().append('<option value="">Loading...</option>');
          stEl.select2({ placeholder: 'Loading...', width: '100%' });
          $.getJSON('https://countriesnow.space/api/v0.1/countries/states', function(data) {
            if (data && data.data) countriesCache = data.data;
            applyStates(countriesCache);
          }).fail(function() {
            wrapper.html(
              '<label for="cmIntlState" class="block text-sm font-semibold text-gray-700">State / Region</label>' +
              '<input type="text" id="cmIntlState" name="state" placeholder="Enter state/region name" ' +
              'class="w-full border border-gray-300 rounded-md p-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />'
            );
          });
        }
      }

      // Helper: reset city field back to a fresh select2 with tags (add mode)
      function resetIntlCityDropdown() {
        const wrapper = $('#cmIntlCityWrapper');
        // Restore to select if edit mode left a text input
        if ($('#cmIntlCityName').is('input')) {
          wrapper.html(
            '<label for="cmIntlCityName" class="block text-sm font-semibold text-gray-700">City</label>' +
            '<select class="w-full" id="cmIntlCityName" name="name">' +
            '<option value="">Select or type a city</option></select>' +
            '<p class="text-xs text-gray-400 mt-1">Select from list or type to search. If city is not listed, type the name and press Enter to add it.</p>'
          );
        } else {
          if ($('#cmIntlCityName').data('select2')) $('#cmIntlCityName').select2('destroy');
          $('#cmIntlCityName').empty().append('<option value="">Select or type a city</option>');
        }
        $('#cmIntlCityName').select2({
          placeholder: 'Select or type a city', allowClear: true, width: '100%', tags: true,
          createTag: function(params) {
            const term = $.trim(params.term);
            if (!term) return null;
            return { id: term, text: term, newTag: true };
          }
        });
      }

      // Helper: load cities for a given country name + state name (add mode cascade)
      function loadIntlCities(countryName, stateName) {
        resetIntlCityDropdown();
        const cityEl = $('#cmIntlCityName');
        if (cityEl.data('select2')) cityEl.select2('destroy');
        cityEl.empty().append('<option value="">Loading cities...</option>');
        cityEl.select2({ placeholder: 'Loading cities...', width: '100%' });

        const citiesUrl = 'https://countriesnow.space/api/v0.1/countries/state/cities/q'
          + '?country=' + encodeURIComponent(countryName)
          + '&state=' + encodeURIComponent(stateName);
        $.getJSON(citiesUrl, function(res) {
          if (cityEl.data('select2')) cityEl.select2('destroy');
          cityEl.empty().append('<option value="">Select or type a city</option>');
          if (res && res.data && res.data.length) {
            res.data.sort().forEach(function(city) { cityEl.append('<option value="' + city + '">' + city + '</option>'); });
          }
          cityEl.select2({
            placeholder: 'Select or type a city', allowClear: true, width: '100%', tags: true,
            createTag: function(params) {
              const term = $.trim(params.term);
              if (!term) return null;
              return { id: term, text: term, newTag: true };
            }
          });
        }).fail(function() { resetIntlCityDropdown(); });
      }

      // Load states when country is selected
      $(document).on('change', '#cmIntlCountry', function() {
        const countryCode = $(this).val();
        const countryName = $(this).find(':selected').data('name') || '';
        $('#cmCountryCode').val(countryCode || '');
        resetIntlCityDropdown();
        populateStatesForCountry(countryCode, countryName);
      });

      // Load cities when state is selected
      $(document).on('change', '#cmIntlState', function() {
        const stateName = $(this).val() || $(this).is('input') && $(this).val();
        const selectedOpt = $(this).find(':selected');
        const countryName = selectedOpt.data('country') || $('#cmIntlCountry').find(':selected').data('name') || '';
        if (stateName && countryName) {
          loadIntlCities(countryName, stateName);
        } else {
          resetIntlCityDropdown();
        }
      });

      $('#cmCityForm').on('submit', function(e) {
        e.preventDefault();

        const id = $('#cmCityId').val();
        const isIntl = $('input[name="countryType"]:checked').val() === 'INTL';

        // Validate required fields for international mode
        if (isIntl) {
          // Sync countryCode from dropdown only if it's a real ISO2 value (not empty/undefined)
          const liveCC = $('#cmIntlCountry').val();
          if (liveCC && liveCC !== 'undefined' && liveCC.length >= 2) $('#cmCountryCode').val(liveCC);

          const intlState = $('#cmIntlState').val();
          const intlCity = $('#cmIntlCityName').val();
          const intlCC = $('#cmCountryCode').val();
          if (!intlCC || intlCC === 'IN' || !intlState || !intlCity) {
            Toastify({ text: 'Please select a country, state/region, and city.', className: 'cm-toast', style: { background: '#F59E0B' }, duration: 3000 }).showToast();
            return;
          }
        }

        // Validate image for new cities
        if (!id && !$('#cmImage')[0].files.length) {
          Toastify({
            text: 'An image is required for new cities.',
            className: 'cm-toast',
            style: { background: '#F59E0B' },
            duration: 3000
          }).showToast();
          return;
        }

        $('#cmLoadingOverlay').show();
        const formData = new FormData(this);

        // Explicitly append the image if a new one was cropped
        if ($('#cmImage')[0].files.length > 0) {
          formData.set('image', $('#cmImage')[0].files[0]); // Use set to ensure only one image is sent
        } else if ($('#cmOldImage').val() && id) {
          formData.set('oldImage', $('#cmOldImage').val()); // Only include oldImage for updates with no new image
        }

        $.ajax({
          url: '/cities',
          method: 'POST',
          data: formData,
          processData: false,
          contentType: false,
          success: function(response) {
            $('#cmLoadingOverlay').hide();
            if (response.success) {
              Toastify({
                text: response.message,
                className: 'cm-toast',
                style: {
                  background: '#10B981'
                },
                duration: 3000
              }).showToast();
              setTimeout(() => location.reload(), 1000);
            } else {
              Toastify({
                text: response.message || 'Failed to process city.',
                className: 'cm-toast',
                style: {
                  background: '#EF4444'
                },
                duration: 3000
              }).showToast();
            }
          },
          error: function(xhr) {
            $('#cmLoadingOverlay').hide();
            const message = xhr.responseJSON?.message || 'Error processing request.';
            Toastify({
              text: message,
              className: 'cm-toast',
              style: {
                background: '#EF4444'
              },
              duration: 3000
            }).showToast();
          }
        });
      });
      // Delete city with AJAX
      $(document).on('submit', '.cm-delete-form', function(e) {
        e.preventDefault();
        const form = $(this);
        $('#cmDeleteConfirmModal').modal('show');
        $('#cmConfirmDeleteBtn').off('click').on('click', function() {
          $('#cmLoadingOverlay').show();
          $.ajax({
            url: form.attr('action'),
            method: 'POST',
            data: form.serialize(),
            success: function(response) {
              $('#cmLoadingOverlay').hide();
              $('#cmDeleteConfirmModal').modal('hide');
              if (response.success) {
                Toastify({
                  text: response.message,
                  className: 'cm-toast',
                  style: {
                    background: '#10B981'
                  },
                  duration: 3000
                }).showToast();
                setTimeout(() => location.reload(), 1000);
              } else {
                Toastify({
                  text: response.message || 'Failed to delete city.',
                  className: 'cm-toast',
                  style: {
                    background: '#EF4444'
                  },
                  duration: 3000
                }).showToast();
              }
            },
            error: function() {
              $('#cmLoadingOverlay').hide();
              $('#cmDeleteConfirmModal').modal('hide');
              Toastify({
                text: 'Error deleting city.',
                className: 'cm-toast',
                style: {
                  background: '#EF4444'
                },
                duration: 3000
              }).showToast();
            }
          });
        });
      });

      // Bulk delete
      $('#cmBulkDeleteBtn').on('click', function() {
        if (selectedCities.length === 0) {
          Toastify({
            text: 'No cities selected.',
            className: 'cm-toast',
            style: {
              background: '#F59E0B'
            },
            duration: 3000
          }).showToast();
          return;
        }
        $('#cmDeleteConfirmModal').modal('show');
        $('#cmConfirmDeleteBtn').off('click').on('click', function() {
          $('#cmLoadingOverlay').show();
          const promises = selectedCities.map(id => {
            return $.ajax({
              url: `/cities/delete/${id}`,
              method: 'POST',
              data: {
                _csrf: '<%= csrfToken %>'
              }
            });
          });
          Promise.all(promises)
            .then(responses => {
              $('#cmLoadingOverlay').hide();
              $('#cmDeleteConfirmModal').modal('hide');
              if (responses.every(res => res.success)) {
                Toastify({
                  text: 'Selected cities deleted successfully.',
                  className: 'cm-toast',
                  style: {
                    background: '#10B981'
                  },
                  duration: 3000
                }).showToast();
                setTimeout(() => location.reload(), 1000);
              } else {
                Toastify({
                  text: 'Failed to delete some cities.',
                  className: 'cm-toast',
                  style: {
                    background: '#EF4444'
                  },
                  duration: 3000
                }).showToast();
              }
            })
            .catch(() => {
              $('#cmLoadingOverlay').hide();
              $('#cmDeleteConfirmModal').modal('hide');
              Toastify({
                text: 'Error deleting cities.',
                className: 'cm-toast',
                style: {
                  background: '#EF4444'
                },
                duration: 3000
              }).showToast();
            });
        });
      });

      // Initialize drag-and-drop
      const cityGrid = document.getElementById('cmCityGrid');
      let orderChanged = false;
      Sortable.create(cityGrid, {
        animation: 150,
        handle: '.cm-card',
        touchStartThreshold: 5,
        onEnd: function(evt) {
          orderChanged = true;
          $('#cmSaveOrderBtn').removeClass('hidden');
          updateOrderInputs();
        }
      });

      // Save order with duplicate check
      $('#cmSaveOrderBtn').on('click', function() {
        if (checkDuplicateOrders()) {
          Toastify({
            text: 'Duplicate display orders detected. Please fix before saving.',
            className: 'cm-toast',
            style: {
              background: '#F59E0B'
            },
            duration: 3000
          }).showToast();
          return;
        }
        const newOrder = Array.from(cityGrid.children).map(card => card.dataset.id);
        $('#cmLoadingOverlay').show();
        $.ajax({
          url: '/cities/update-order',
          method: 'POST',
          contentType: 'application/json',
          data: JSON.stringify({
            _csrf: '<%= csrfToken %>',
            order: newOrder
          }),
          success: function(response) {
            $('#cmLoadingOverlay').hide();
            if (response.success) {
              Toastify({
                text: response.message,
                className: 'cm-toast',
                style: {
                  background: '#10B981'
                },
                duration: 3000
              }).showToast();
              orderChanged = false;
              $('#cmSaveOrderBtn').addClass('hidden');
              const orderedCities = [];
              newOrder.forEach(id => {
                const city = cities.find(c => c._id === id);
                if (city) orderedCities.push(city);
              });
              cities = orderedCities;
              filteredCities = [...cities];
              renderCities();
            } else {
              Toastify({
                text: response.message || 'Failed to update city order.',
                className: 'cm-toast',
                style: {
                  background: '#EF4444'
                },
                duration: 3000
              }).showToast();
            }
          },
          error: function(xhr) {
            $('#cmLoadingOverlay').hide();
            const message = xhr.responseJSON?.message || 'Error updating city order.';
            Toastify({
              text: message,
              className: 'cm-toast',
              style: {
                background: '#EF4444'
              },
              duration: 3000
            }).showToast();
          }
        });
      });

      // Client-side search and filter
      let searchTimeout;

      function applyFilters() {
        const searchTerm = $('#cmSearchInput').val().toLowerCase();
        const selectedState = $('#cmStateFilter').val();
        filteredCities = cities.filter(city => {
          const matchesSearch = city.name.toLowerCase().includes(searchTerm) || city.state.toLowerCase().includes(searchTerm);
          const matchesState = !selectedState || city.state === selectedState;
          return matchesSearch && matchesState;
        });
        renderCities();
      }

      $('#cmSearchInput').on('input', function() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(applyFilters, 300);
      });

      $('#cmStateFilter').on('change', applyFilters);

      // Render cities
      function renderCities() {
        const cityGrid = $('#cmCityGrid');
        cityGrid.empty();
        filteredCities.forEach(city => {
          const cc = city.countryCode || 'IN';
          const intlBadge = cc !== 'IN'
            ? `<span class="mc-badge intl ms-1">${cc}</span>`
            : '';
          const card = `
            <div class="mc-card cm-card" data-id="${city._id}">
              <input type="checkbox" class="mc-card-check cm-checkbox" data-id="${city._id}">
              <img src="${city.image || '/img/placeholder.jpg'}" alt="${city.name}" class="mc-card-img" data-src="${city.image}">
              <div class="mc-card-body">
                <div class="mc-card-name" title="${city.name}">${city.name}${intlBadge}</div>
                <div class="mc-card-meta">${city.state || ''}</div>
                <div class="mc-badge-row">
                  <span class="mc-badge active">Active</span>
                </div>
              </div>
              <div class="mc-card-footer">
                <input type="number" class="mc-order-input cm-order-input" value="${city.displayOrder || 0}" min="0" data-id="${city._id}" title="Display Order">
                <button type="button" class="mc-btn-edit" onclick="editCity('${city._id}', '${city.name}', '${city.state}', '${city.image}', '${cc}')"><i class="bi bi-pencil-fill"></i></button>
                <form action="/cities/delete/${city._id}" method="POST" class="d-inline cm-delete-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="mc-btn-delete"><i class="bi bi-trash-fill"></i></button>
                </form>
              </div>
            </div>
          `;
          cityGrid.append(card);
        });

        // Lazy load images
        $('.lazy').each(function() {
          const img = $(this);
          if (img[0].getBoundingClientRect().top < window.innerHeight) {
            img.attr('src', img.data('src')).removeClass('lazy');
          }
        });

        $('#cmBulkDeleteBtn').toggle(selectedCities.length > 0);
        checkDuplicateOrders();
      }

      // Check for duplicate display orders
      function checkDuplicateOrders() {
        const orderInputs = $('.cm-order-input');
        const orderValues = {};
        let hasDuplicates = false;
        orderInputs.each(function() {
          const value = parseInt($(this).val()) || 0;
          if (orderValues[value]) {
            $(this).addClass('error');
            hasDuplicates = true;
          } else {
            $(this).removeClass('error');
            orderValues[value] = true;
          }
        });
        return hasDuplicates;
      }

      // Update order inputs after drag
      function updateOrderInputs() {
        const cards = Array.from(cityGrid.children);
        cards.forEach((card, index) => {
          const id = card.dataset.id;
          const input = $(card).find('.cm-order-input');
          input.val(index);
          const city = cities.find(c => c._id === id);
          if (city) city.displayOrder = index;
        });
        checkDuplicateOrders();
      }

      // Checkbox selection
      $(document).on('change', '.cm-checkbox', function() {
        const id = $(this).data('id');
        if ($(this).is(':checked')) {
          selectedCities.push(id);
        } else {
          selectedCities = selectedCities.filter(cid => cid !== id);
        }
        $('#cmBulkDeleteBtn').toggle(selectedCities.length > 0);
      });

      // Inline order update
      $(document).on('change', '.cm-order-input', function() {
        const id = $(this).data('id');
        const newOrder = parseInt($(this).val()) || 0;
        orderChanged = true;
        $('#cmSaveOrderBtn').removeClass('hidden');
        const city = cities.find(c => c._id === id);
        if (city) city.displayOrder = newOrder;
        renderCities();
      });

      // ── Callback-driven cascade for editing international cities ──
      // Drives country → state → city without relying on event handlers or setTimeout races
      function populateIntlForEdit(countryCode, stateName, cityName) {
        const intlCountry = $('#cmIntlCountry');

        function setCountryThenLoadStates() {
          $('#cmCountryCode').val(countryCode);
          intlCountry.val(countryCode).trigger('change.select2'); // update UI only, don't fire our handler
          loadStatesForEdit();
        }

        function loadStatesForEdit() {
          const countryName = intlCountry.find(`option[value="${countryCode}"]`).data('name') || '';
          const stateDropIntl = $('#cmIntlState');
          if (stateDropIntl.data('select2')) stateDropIntl.select2('destroy');
          stateDropIntl.empty().append('<option value="">Loading states...</option>');
          stateDropIntl.select2({ placeholder: 'Loading states...', width: '100%' });

          $.getJSON('https://countriesnow.space/api/v0.1/countries/states', function(data) {
            // Match strictly by iso2 first; only fall back to name if countryName is non-empty.
            // Prevents false India match when countryCode is accidentally 'IN'.
            const match = data.data && (
              data.data.find(c => c.iso2 === countryCode) ||
              (countryName ? data.data.find(c => c.name === countryName) : null)
            );
            if (stateDropIntl.data('select2')) stateDropIntl.select2('destroy');
            stateDropIntl.empty().append('<option value="">Select State / Region</option>');
            let resolvedCountryName = countryName;
            if (match && match.states && match.states.length) {
              resolvedCountryName = match.name;
              match.states.forEach(s => stateDropIntl.append(`<option value="${s.name}" data-country="${match.name}">${s.name}</option>`));
              stateDropIntl.select2({ placeholder: 'Select State / Region', allowClear: true, width: '100%' });
              stateDropIntl.val(stateName).trigger('change.select2'); // update UI only
            } else {
              // Replace with text input for countries with no state divisions
              stateDropIntl.closest('div').html(`
                <label class="block text-sm font-semibold text-gray-700 mt-2">State / Region</label>
                <input type="text" id="cmIntlState" name="state" value="${stateName}"
                  class="w-full border border-gray-300 rounded-md p-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              `);
            }
            loadCitiesForEdit(resolvedCountryName, stateName);
          }).fail(function() {
            if (stateDropIntl.data('select2')) stateDropIntl.select2('destroy');
            stateDropIntl.closest('div').html(`
              <label class="block text-sm font-semibold text-gray-700 mt-2">State / Region</label>
              <input type="text" id="cmIntlState" name="state" value="${stateName}"
                class="w-full border border-gray-300 rounded-md p-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            `);
            loadCitiesForEdit('', stateName);
          });
        }

        function loadCitiesForEdit(countryName, stateName) {
          const cityEl = $('#cmIntlCityName');
          if (cityEl.data('select2')) cityEl.select2('destroy');
          cityEl.empty().append('<option value="">Loading cities...</option>');
          cityEl.select2({ placeholder: 'Loading cities...', width: '100%' });

          function setCityValue() {
            if (!cityEl.find(`option[value="${cityName}"]`).length) {
              cityEl.append(new Option(cityName, cityName, true, true));
            } else {
              cityEl.val(cityName);
            }
            cityEl.trigger('change.select2');
          }

          if (!countryName) {
            resetIntlCityDropdown();
            setCityValue();
            return;
          }

          // Use GET endpoint directly — API redirects POST to this GET endpoint anyway
          const citiesUrl = 'https://countriesnow.space/api/v0.1/countries/state/cities/q'
            + '?country=' + encodeURIComponent(countryName)
            + '&state=' + encodeURIComponent(stateName);
          $.getJSON(citiesUrl, function(res) {
            if (cityEl.data('select2')) cityEl.select2('destroy');
            cityEl.empty().append('<option value="">Select or type a city</option>');
            if (res && res.data && res.data.length) {
              res.data.sort().forEach(c => cityEl.append(`<option value="${c}">${c}</option>`));
            }
            cityEl.select2({ placeholder: 'Select or type a city', allowClear: true, width: '100%', tags: true,
              createTag: function(params) {
                const term = $.trim(params.term);
                return term ? { id: term, text: term + ' (custom)', newTag: true } : null;
              }
            });
            setCityValue();
          }).fail(function() {
            resetIntlCityDropdown();
            setCityValue();
          });
        }

        // Kick off: ensure country list is loaded first, then cascade
        if (!countriesLoaded) {
          $.getJSON('https://countriesnow.space/api/v0.1/countries', function(data) {
            if (data && data.data) {
              intlCountry.empty().append('<option value="">Select Country</option>');
              data.data.filter(c => c.iso2 !== 'IN').sort((a, b) => a.country.localeCompare(b.country))
                .forEach(c => intlCountry.append(`<option value="${c.iso2}" data-name="${c.country}">${c.country}</option>`));
              intlCountry.select2({ placeholder: 'Select Country', allowClear: true, width: '100%' });
              countriesLoaded = true;
            }
            setCountryThenLoadStates();
          }).fail(function() {
            countriesLoaded = true;
            setCountryThenLoadStates();
          });
        } else {
          setCountryThenLoadStates();
        }
      }

      // Edit city
      window.editCity = function(id, name, state, image, countryCode) {
        countryCode = countryCode || 'IN';
        $('#cmCityId').val(id);
        $('#cmImagePreview').attr('src', image).show();
        $('#cmOldImage').val(image);
        $('#cmSubmitBtn').text('Update City').addClass('update');
        $('#cmCancelBtn').removeClass('hidden');
        $('#cmCityFormContainer').removeClass('collapsed');
        $('#cmFormToggle').text('Hide Form');

        const isIndiaState = !!stateCities[state];
        if (countryCode === 'IN' && isIndiaState) {
          // India mode — switch without clearing (we're about to set values)
          $('input[name="countryType"][value="IN"]').prop('checked', true);
          $('#cmIndiaSection').removeClass('hidden');
          $('#cmIntlSection').addClass('hidden');
          $('#cmState').attr('name', 'state');
          $('#cmCityName').attr('name', 'name');
          $('#cmIntlState').removeAttr('name');
          $('#cmIntlCityName').removeAttr('name');
          $('#cmCountryCode').val('IN');
          // Set state → populate city dropdown → set city
          $('#cmState').val(state).trigger('change');
          setTimeout(() => {
            if ($('#cmCityName option[value="' + name + '"]').length > 0) {
              $('#cmCityName').val(name).trigger('change');
            } else {
              Toastify({ text: 'City not found in dropdown. Check state selection.', className: 'cm-toast', style: { background: '#F59E0B' }, duration: 3000 }).showToast();
            }
          }, 300);
        } else {
          // International mode — fill directly from saved DB data, no API calls needed
          $('input[name="countryType"][value="INTL"]').prop('checked', true);
          $('#cmIndiaSection').addClass('hidden');
          $('#cmIntlSection').removeClass('hidden');
          $('#cmState').removeAttr('name');
          $('#cmCityName').removeAttr('name');
          $('#cmIntlState').attr('name', 'state');
          $('#cmIntlCityName').attr('name', 'name');

          // Set countryCode hidden field — this is what gets submitted
          $('#cmCountryCode').val(countryCode);

          // State: plain text input pre-filled with saved value (directly editable)
          $('#cmIntlStateWrapper').html(
            '<label for="cmIntlState" class="block text-sm font-semibold text-gray-700">State / Region</label>' +
            '<input type="text" id="cmIntlState" name="state" value="' + state.replace(/"/g, '&quot;') + '" ' +
            'class="w-full border border-gray-300 rounded-md p-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />'
          );

          // City: plain text input pre-filled with saved value (directly editable)
          $('#cmIntlCityWrapper').html(
            '<label for="cmIntlCityName" class="block text-sm font-semibold text-gray-700">City</label>' +
            '<input type="text" id="cmIntlCityName" name="name" value="' + name.replace(/"/g, '&quot;') + '" ' +
            'class="w-full border border-gray-300 rounded-md p-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />' +
            '<p class="text-xs text-gray-400 mt-1">Edit city name directly. Save to update.</p>'
          );

          // Country dropdown: load list then select the correct country
          loadCountriesForIntl(function() {
            const opt = $('#cmIntlCountry').find('option[value="' + countryCode + '"]');
            if (opt.length) {
              $('#cmIntlCountry').val(countryCode).trigger('change.select2');
            } else if ($('#cmIntlCountry').is('input')) {
              // API failed, text input fallback — just pre-fill with the code
              $('#cmIntlCountry').val(countryCode);
            }
          });
        }
      };

      // Cancel edit
      $('#cmCancelBtn').on('click', function() {
        $('#cmCityForm')[0].reset();
        // Reset to India mode
        $('input[name="countryType"][value="IN"]').prop('checked', true);
        $('#cmIndiaSection').removeClass('hidden');
        $('#cmIntlSection').addClass('hidden');
        $('#cmState').attr('name', 'state');
        $('#cmCityName').attr('name', 'name');
        // Restore intl state wrapper if it was replaced with text input
        if ($('#cmIntlState').is('input')) {
          $('#cmIntlStateWrapper').html(
            '<label for="cmIntlState" class="block text-sm font-semibold text-gray-700">State / Region</label>' +
            '<select class="select2 w-full" id="cmIntlState">' +
            '<option value="">Select State / Region</option></select>'
          );
          $('#cmIntlState').select2({ placeholder: 'Select State / Region', allowClear: true, width: '100%' });
        } else {
          if ($('#cmIntlState').data('select2')) $('#cmIntlState').val(null).trigger('change.select2');
        }
        $('#cmIntlState').removeAttr('name');
        $('#cmIntlCityName').removeAttr('name');
        $('#cmCountryCode').val('IN');
        $('#cmState').val('').trigger('change');
        $('#cmCityName').val('').trigger('change');
        resetIntlCityDropdown(); // also restores city to select if it was text input
        $('#cmCityId').val('');
        $('#cmOldImage').val('');
        $('#cmImagePreview').attr('src', '').hide();
        $('#cmSubmitBtn').text('Add City').removeClass('update');
        $('#cmCancelBtn').addClass('hidden');
        $('#cmCityFormContainer').addClass('collapsed');
        $('#cmFormToggle').text('Show Form');
      });

      // Image crop handling
      $('#cmImage').on('change', function(event) {
        const file = event.target.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = function(e) {
            $('#cmCropImage').attr('src', e.target.result);
            $('#cmCropModal').modal('show');
            setTimeout(() => {
              if (cropper) cropper.destroy();
              const cropMode = $('#cmCropRatio').val() || '1'; // Default to 1:1
              const aspectRatio = cropMode === 'free' ? NaN : parseFloat(cropMode);
              cropper = new Cropper(document.getElementById('cmCropImage'), {
                aspectRatio: aspectRatio,
                viewMode: 1,
                autoCropArea: 0.8,
                responsive: true
              });
            }, 200);
          };
          reader.readAsDataURL(file);
        }
      });

      $('#cmCropRatio').on('change', function() {
        if (cropper) {
          cropper.destroy();
          const cropMode = $(this).val();
          const aspectRatio = cropMode === 'free' ? NaN : parseFloat(cropMode);
          cropper = new Cropper(document.getElementById('cmCropImage'), {
            aspectRatio: aspectRatio,
            viewMode: 1,
            autoCropArea: 0.8,
            responsive: true
          });
        }
      });

      $('#cmCropConfirmBtn').on('click', function() {
        if (cropper) {
          cropper.getCroppedCanvas({
            width: 300,
            height: 300
          }).toBlob(function(blob) {
            const url = URL.createObjectURL(blob);
            $('#cmImagePreview').attr('src', url).show(); // Ensure preview is visible
            const file = new File([blob], `cropped-image-${Date.now()}.jpg`, {
              type: 'image/jpeg'
            });
            const dataTransfer = new DataTransfer();
            dataTransfer.items.add(file);
            $('#cmImage')[0].files = dataTransfer.files; // Set the cropped image to the input
            $('#cmOldImage').val(''); // Clear oldImage to ensure new image takes precedence
            $('#cmCropModal').modal('hide');
            cropper.destroy();
            cropper = null;
          }, 'image/jpeg', 0.8); // Added quality parameter for better compression
        }
      });

      $('#cmCropModal').on('hidden.bs.modal', function() {
        if (cropper) {
          cropper.destroy();
          cropper = null;
        }
        // $('#cmImage').val('');
      });

      // Form toggle
      $('#cmFormToggle').on('click', function() {
        $('#cmCityFormContainer').toggleClass('collapsed');
        $(this).text($('#cmCityFormContainer').hasClass('collapsed') ? 'Show Form' : 'Hide Form');
      });


      // Lazy load images on scroll
      $(window).on('scroll', function() {
        $('.lazy').each(function() {
          const img = $(this);
          if (img[0].getBoundingClientRect().top < window.innerHeight) {
            img.attr('src', img.data('src')).removeClass('lazy');
          }
        });
      });

      // Initial render
      renderCities();
    });
  </script>
  </main>
</body>

</html>